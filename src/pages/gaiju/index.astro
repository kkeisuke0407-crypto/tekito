---
const PAGE_TITLE = "害獣駆除の費用・相場を比較｜ネズミ・コウモリ・ハクビシン";
const PAGE_DESC  = "ネズミ・コウモリ・ハクビシンなどの害獣駆除にかかる費用の相場を解説。業者によって同じ作業でも費用が大きく変わります。無料見積もりを比較してから依頼してください。";
const CANONICAL  = "https://tekito-domain.com/gaiju/";
const OGP_IMAGE  = "https://tekito-domain.com/og-default.svg";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <!-- OGP -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="害獣駆除の相場ナビ" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <!-- Page CSS -->
  <link rel="stylesheet" href="/gaiju/styles.css" />

  <!-- GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<header class="gj-header">
  <div class="gj-header-inner">
    <a href="/gaiju/" class="gj-logo">
      <div class="gj-logo-icon">🐀</div>
      <div class="gj-logo-wrap">
        <span>害獣駆除の相場ナビ</span>
        <span class="gj-logo-sub">費用・業者を正直に比較</span>
      </div>
    </a>
    <a href="#ranking" class="gj-header-cta" data-scroll-to="#ranking" data-track="header_ranking">
      無料見積もりで比較する ›
    </a>
  </div>
</header>

<!-- ══ HERO ════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="gj-container hero-inner">
    <div class="hero-eyebrow">ネズミ・コウモリ・ハクビシンの駆除費用を比較</div>
    <h1>その業者、<em>相場より高く</em><br/>払っていませんか？</h1>
    <p class="hero-sub">
      害獣駆除は業者によって同じ作業でも費用が<strong style="color:#fff">2〜5倍</strong>変わることがあります。<br/>
      見積もりは無料です。複数社に依頼して比較してから決めてください。
    </p>
    <div class="hero-badges">
      <div class="hero-badge-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
        <span>見積もり無料</span>
      </div>
      <div class="hero-badge-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>最短即日対応</span>
      </div>
      <div class="hero-badge-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>関東〜九州対応</span>
      </div>
      <div class="hero-badge-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>再発保証あり</span>
      </div>
    </div>
    <a href="#ranking" class="hero-cta" data-scroll-to="#ranking" data-track="hero_ranking">
      <span class="hero-cta-free">無料</span>
      見積もりを依頼して費用を比較する
      <span>›</span>
    </a>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f5f6f8"/>
    </svg>
  </div>
</section>

<!-- ══ 放置リスク ════════════════════════════════════════════════ -->
<section class="gj-section risk-section" id="risk">
  <div class="gj-container">
    <div class="risk-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      放置すると被害は広がります
    </div>
    <div class="section-head" style="text-align:left;margin-bottom:1.25rem;">
      <h2>「そのうち何とかなる」は危険です</h2>
      <p>害獣は放置するほど駆除費用が上がり、家屋の損傷も深刻になります。</p>
    </div>
    <div class="risk-cards">
      <div class="risk-card">
        <div class="risk-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span class="risk-card-title">家屋への直接被害</span>
        </div>
        <p>ネズミは前歯が伸び続けるため必ず電線・木材をかじる習性があります。絶縁体が剥がれると漏電・ショートが発生し、火災につながるリスクがあります。断熱材の損傷は防寒・防暑効果の低下を招き、修繕費が高額になることがあります。</p>
      </div>
      <div class="risk-card">
        <div class="risk-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="risk-card-title">衛生・感染リスク</span>
        </div>
        <p>ネズミはサルモネラ菌・レプトスピラ症（重症化すると腎不全・黄疸の恐れ）の感染源になることがあります。ハクビシンはSFTS（重症熱性血小板減少症候群）を媒介するマダニの宿主となることがあり、放置は衛生リスクを高めます。</p>
      </div>
      <div class="risk-card">
        <div class="risk-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="risk-card-title">繁殖による被害拡大</span>
        </div>
        <p>ネズミは約2ヶ月で繁殖が可能になり、1年で数十匹に増えることも。発見が遅れるほど侵入ルートが増え、駆除コストが跳ね上がります。</p>
      </div>
      <div class="risk-card">
        <div class="risk-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span class="risk-card-title">駆除費用の増加</span>
        </div>
        <p>ハクビシンは天井裏に糞を溜める「溜めフン」の習性があり、放置すると天井に染みが広がり腐食が進みます。最悪の場合は天井崩落につながるケースもあります。被害が拡大するほど駆除・修繕費用は急増します。</p>
      </div>
    </div>
    <p class="risk-footer">だから「まず無料見積もり」で状況を把握することが最初の一歩です。</p>
  </div>
</section>

<!-- ══ 費用の目安 ═══════════════════════════════════════════════ -->
<div class="divider"></div>
<section class="gj-section section-white" id="cost">
  <div class="gj-container">
    <div class="section-head">
      <span class="kicker">COST GUIDE</span>
      <h2>害獣別・駆除費用の目安</h2>
      <p>以下は参考相場です。実際の費用は現地調査後の見積もりで確認してください。</p>
    </div>
    <div class="cost-grid">
      <div class="cost-card">
        <div class="cost-card-head">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          ネズミ駆除
        </div>
        <div class="cost-card-body">
          <div class="cost-range">30,000 〜 200,000円<small>（税込・目安）</small></div>
          <div class="cost-note-list">
            <div class="cost-note-item">侵入口の数・封鎖難易度で変動</div>
            <div class="cost-note-item">屋根裏・床下は追加料金が発生しやすい</div>
            <div class="cost-note-item">再発防止工事込みの場合は高額になることも</div>
          </div>
        </div>
      </div>
      <div class="cost-card">
        <div class="cost-card-head">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          コウモリ追い出し
        </div>
        <div class="cost-card-body">
          <div class="cost-range">10,000 〜 400,000円+<small>（税込・目安）</small></div>
          <div class="cost-note-list">
            <div class="cost-note-item">通気口など簡単な場所：1〜10万円程度</div>
            <div class="cost-note-item">足場が必要な場合：40万円以上になることも</div>
            <div class="cost-note-item">糞の清掃・消毒は追加費用（5,000〜1万円〜）</div>
          </div>
        </div>
      </div>
      <div class="cost-card">
        <div class="cost-card-head">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          ハクビシン駆除
        </div>
        <div class="cost-card-body">
          <div class="cost-range">50,000 〜 300,000円<small>（税込・目安）</small></div>
          <div class="cost-note-list">
            <div class="cost-note-item">捕獲・搬出には行政手続きが必要な場合あり</div>
            <div class="cost-note-item">溜めフンの清掃・消毒は別途費用（高額になりやすい）</div>
            <div class="cost-note-item">再侵入防止の封鎖工事を含むと30万円超になることも</div>
          </div>
        </div>
      </div>
    </div>

    <div class="cost-factors">
      <div class="cost-factors-title">💡 費用が変わる主な4つの要因</div>
      <div class="cost-factors-grid">
        <div class="cost-factor">
          <div class="cost-factor-num">1</div>
          <span>侵入経路の数と封鎖の難易度（屋根形状・老朽化など）</span>
        </div>
        <div class="cost-factor">
          <div class="cost-factor-num">2</div>
          <span>被害の広がり・駆除規模（1匹 vs コロニー化）</span>
        </div>
        <div class="cost-factor">
          <div class="cost-factor-num">3</div>
          <span>再発防止工事・消毒・清掃の有無</span>
        </div>
        <div class="cost-factor">
          <div class="cost-factor-num">4</div>
          <span>業者のコスト構造（外注 vs 直営・地域差）</span>
        </div>
      </div>
    </div>

    <div class="bat-warning">
      <strong>🦇 コウモリについての注意</strong><br/>
      コウモリは鳥獣保護管理法により日本に生息する全種が保護されており、許可なく捕獲・殺傷することは法律で禁止されています。<strong>違反した場合の罰則は「1年以下の懲役または100万円以下の罰金」。</strong>専門業者が行う「追い出し＋侵入口封鎖」のみが適法な対処法です。自己判断での捕獲・殺傷は知らなかった場合でも罰則対象になりうるため、必ず専門業者にご相談ください。
    </div>
  </div>
</section>

<!-- ══ RANKING ══════════════════════════════════════════════════ -->
<div class="divider"></div>
<section class="gj-section ranking-section" id="ranking">
  <div class="gj-container">
    <div class="ranking-header">
      <span class="kicker kicker-white">SELECTED COMPANIES</span>
      <h2>
        <span class="heading-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        </span>
        無料見積もりを依頼できる業者 2選
      </h2>
      <p class="ranking-header-sub">対応実績・サービス内容・費用の透明性をもとに選定。費用は必ず公式サイトで最新情報を確認してください。</p>
    </div>

    <div class="ranking-cards">

      <!-- No.1 駆除の達人 -->
      <div class="ranking-card rank-1">
        <span class="card-pr-badge">PR</span>
        <div class="card-best-ribbon">編集部イチオシ</div>
        <div class="rank-badge">
          <div class="rank-num">1</div>
          <div>
            <div style="font-size:.72rem;font-weight:800;color:#c2410c">No.1</div>
            <div class="rank-label">即日対応・全国対応</div>
          </div>
        </div>
        <div class="ranking-card-body">
          <div class="ranking-name">駆除の達人</div>
          <div class="ranking-tags">
            <span class="tag good">Google★4.7</span>
            <span class="tag good">最長10年保証</span>
            <span class="tag">完全自社施工</span>
            <span class="tag">中国・九州8県対応</span>
          </div>
          <div class="eval-bars">
            <div class="eval-bar-row">
              <span class="eval-bar-label">対応スピード</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:95%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">実績・信頼</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:80%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">費用の透明性</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:85%"></div></div>
            </div>
          </div>
          <div class="ranking-features">
            <div class="ranking-feature">ネズミ・ハクビシン・コウモリ・イタチなど幅広く対応</div>
            <div class="ranking-feature">完全自社施工でコミコミ料金・見積もり後の追加費用なし</div>
            <div class="ranking-feature">最長10年の再発防止保証（保証期間中は何度でも無料再対応）</div>
          </div>
          <div class="ranking-reward">
            <div class="ranking-reward-label">📊 実績・評価（公式情報）</div>
            <div class="ranking-reward-val">Google ★4.7 ／ 累計施工1万件以上 ／ 日本ビジネスリサーチ支持率90%・信頼89%・安心87%</div>
          </div>
          <div class="ranking-comment">
            <div class="ranking-comment-label">選んだ理由</div>
            <p>累計1万件以上の施工実績を持ち、Googleレビューでも★4.7の高評価。完全自社施工でコミコミ料金のため追加費用の心配がなく、最長10年保証で長期的な安心を提供しています。<em>対応エリアは広島・山口・岡山・島根・福岡・佐賀・熊本・大分の8県です。エリア外の方は害獣プロテックへ。</em></p>
          </div>
          <p class="ranking-for">対応エリア：中国・九州8県（広島・山口・岡山・島根・福岡・佐賀・熊本・大分）</p>
          <a href="#" class="ranking-cta" data-affiliate="kujo_tatsujin" data-track="ranking_tatsujin" rel="nofollow sponsored">
            無料で見積もりを依頼する ›
          </a>
        </div>
      </div>

      <!-- No.2 害獣プロテック -->
      <div class="ranking-card rank-2">
        <span class="card-pr-badge">PR</span>
        <div class="rank-badge">
          <div class="rank-num">2</div>
          <div>
            <div style="font-size:.72rem;font-weight:800;color:#64748b">No.2</div>
            <div class="rank-label">建築知識×駆除の専門性</div>
          </div>
        </div>
        <div class="ranking-card-body">
          <div class="ranking-name">害獣プロテック</div>
          <div class="ranking-tags">
            <span class="tag good">工務店50年の専門知識</span>
            <span class="tag good">TV取材実績あり</span>
            <span class="tag">24時間365日受付</span>
            <span class="tag">関東・東海・関西・九州</span>
          </div>
          <div class="eval-bars">
            <div class="eval-bar-row">
              <span class="eval-bar-label">対応スピード</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:80%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">実績・信頼</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:90%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">費用の透明性</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:80%"></div></div>
            </div>
          </div>
          <div class="ranking-features">
            <div class="ranking-feature">工務店歴50年以上の母体が持つ建物構造知識で侵入口を根本封鎖</div>
            <div class="ranking-feature">全スタッフ正社員・外注なしのワンストップ対応</div>
            <div class="ranking-feature">フジテレビ・テレビ朝日の取材実績があるメディア掲載業者</div>
          </div>
          <div class="ranking-reward">
            <div class="ranking-reward-label">📊 実績・評価（公式情報）</div>
            <div class="ranking-reward-val">Google口コミ1,200件以上 ／ フジテレビ・テレ朝TV取材実績 ／ 24時間365日コールセンター受付</div>
          </div>
