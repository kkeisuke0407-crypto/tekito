---
import Base from '@/layouts/Base.astro';
import PlanTable from '@/components/PlanTable.astro';
import AffDisclosure from '@/components/AffDisclosure.astro';
import { loadProviders, applyAffiliate, cheapestPlan, loadSite } from '@/lib/data.ts';

export async function getStaticPaths() {
  return loadProviders().map((p) => ({ params: { slug: p.slug }, props: { provider: p } }));
}

const { provider } = Astro.props;
const site = loadSite();
const cheap = cheapestPlan(provider);
const link = applyAffiliate(provider.signupUrl, provider.slug);
const others = loadProviders().filter((p) => p.slug !== provider.slug).slice(0, 5);

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: provider.name,
  description: provider.description,
  brand: { '@type': 'Brand', name: provider.name },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: Math.min(...provider.plans.map((p: any) => p.monthlyPrice)).toFixed(2),
    highPrice: Math.max(...provider.plans.map((p: any) => p.monthlyPrice)).toFixed(2),
    offerCount: provider.plans.length,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Providers', item: `${site.url}/providers` },
    { '@type': 'ListItem', position: 3, name: provider.name },
  ],
};
---
<Base
  title={`${provider.name} VPS Pricing & Plans`}
  description={`${provider.name} VPS plans, pricing, regions, pros and cons. Cheapest plan starts at $${cheap.monthlyPrice.toFixed(2)}/month.`}
  jsonLd={[productLd, breadcrumbLd]}
>
  <p class="muted"><a href="/providers">&larr; All providers</a></p>
  <h1>{provider.name}</h1>
  <p class="lead">{provider.description}</p>
  <p class="last-updated">Pricing data refreshed: {provider.lastUpdated.slice(0, 10)} (source: {provider.source})</p>

  <p>
    <a class="cta" href={link} rel="sponsored nofollow noopener" target="_blank">Visit {provider.name} &rarr;</a>
  </p>

  <h2>Plans</h2>
  <PlanTable plans={provider.plans} />

  <div class="pros-cons">
    <div class="pros">
      <h3>Pros</h3>
      <ul>{provider.pros.map((x: string) => <li>{x}</li>)}</ul>
    </div>
    <div class="cons">
      <h3>Cons</h3>
      <ul>{provider.cons.map((x: string) => <li>{x}</li>)}</ul>
    </div>
  </div>

  <h2>At a glance</h2>
  <table>
    <tbody>
      <tr><td><strong>HQ</strong></td><td>{provider.hqCountry}</td></tr>
      <tr><td><strong>Founded</strong></td><td>{provider.founded}</td></tr>
      <tr><td><strong>Free credit</strong></td><td>{provider.freeTrialUSD ? `$${provider.freeTrialUSD}` : '-'}</td></tr>
      <tr><td><strong>Payment methods</strong></td><td>{provider.paymentMethods.join(', ')}</td></tr>
      <tr><td><strong>Best for</strong></td><td>{provider.bestFor.join(', ')}</td></tr>
      <tr><td><strong>Regions ({provider.regions.length})</strong></td><td>{provider.regions.join(', ')}</td></tr>
    </tbody>
  </table>

  <h2>Compare {provider.name} to other providers</h2>
  <ul>
    {others.map((o) => (
      <li><a href={`/compare/${provider.slug}-vs-${o.slug}`}>{provider.name} vs {o.name}</a></li>
    ))}
  </ul>

  <AffDisclosure />
</Base>
