---
const PAGE_TITLE = "浄水型・宅配水ウォーターサーバー比較｜水代見直しナビ";
const PAGE_DESC  = "浄水型・宅配水・天然水ウォーターサーバーを、月額料金、ボトル交換、置き場所、最低利用期間、解約条件で比較。生活スタイルに合う水まわりの選び方を整理します。";
const CANONICAL  = "https://vpscomparehub.com/water-server/";
const OGP_IMAGE  = "https://vpscomparehub.com/og-default.svg";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "浄水型と宅配水は何が違いますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "浄水型は水道水を本体内でろ過して使うタイプ、宅配水はボトルやパックで届く水を使うタイプです。料金、交換の手間、置き場所が異なります。" }
    },
    {
      "@type": "Question",
      "name": "一人暮らしでもウォーターサーバーは必要ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "使用量や置き場所によります。ペットボトルをよく買う人、重い買い物を減らしたい人は比較する価値があります。" }
    },
    {
      "@type": "Question",
      "name": "解約金はありますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "最低利用期間や解約金はサービスごとに異なります。申し込み前に公式サイトで最新条件を確認してください。" }
    },
    {
      "@type": "Question",
      "name": "このページは広告ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "このページには広告・アフィリエイトリンクを含みます。掲載順は報酬額だけでなく、サービス内容、比較しやすさ、確認すべき条件をもとに構成しています。" }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <!-- OGP -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="水代見直しナビ" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <!-- Page CSS -->
  <link rel="stylesheet" href="/water-server/styles.css" />

  <!-- Google Ads / GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
