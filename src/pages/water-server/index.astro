</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<header class="ws-header">
  <div class="ws-header-inner">
    <a href="/water-server/" class="ws-logo">
      <div class="ws-logo-icon">💧</div>
      水代見直しナビ
