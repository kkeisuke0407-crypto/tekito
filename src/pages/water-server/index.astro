---
const PAGE_TITLE = "浄水型・宅配水ウォーターサーバー比較｜水代見直しナビ";
const PAGE_DESC  = "浄水型・宅配水・天然水ウォーターサーバーを、月額料金、ボトル交換、置き場所、最低利用期間、解約条件で比較。生活スタイルに合う水まわりの選び方を整理します。";
const CANONICAL  = "https://vpscomparehub.com/water-server/";
const OGP_IMAGE  = "https://vpscomparehub.com/og-default.svg";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "浄水型と宅配水は何が違いますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "浄水型は水道水を本体内でろ過して使うタイプ、宅配水はボトルやパックで届く水を使うタイプです。料金、交換の手間、置き場所が異なります。" }
    },
    {
      "@type": "Question",
      "name": "一人暮らしでもウォーターサーバーは必要ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "使用量や置き場所によります。ペットボトルをよく買う人、重い買い物を減らしたい人は比較する価値があります。" }
    },
    {
      "@type": "Question",
      "name": "解約金はありますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "最低利用期間や解約金はサービスごとに異なります。申し込み前に公式サイトで最新条件を確認してください。" }
    },
    {
      "@type": "Question",
      "name": "このページは広告ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "このページには広告・アフィリエイトリンクを含みます。掲載順は報酬額だけでなく、サービス内容、比較しやすさ、確認すべき条件をもとに構成しています。" }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <!-- OGP -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="水代見直しナビ" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <!-- Page CSS -->
  <link rel="stylesheet" href="/water-server/styles.css" />

  <!-- Google Ads / GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18129603657"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'AW-18129603657');
  </script>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<header class="ws-header">
  <div class="ws-header-inner">
    <a href="/water-server/" class="ws-logo">
      <div class="ws-logo-icon">💧</div>
      水代見直しナビ
    </a>
    <nav class="ws-nav">
      <a href="#compare"    data-scroll-to="#compare">比較表</a>
      <a href="#recommend"  data-scroll-to="#recommend">条件別</a>
      <a href="#cards"      data-scroll-to="#cards">詳細</a>
      <a href="#faq"        data-scroll-to="#faq">FAQ</a>
    </nav>
  </div>
</header>

<!-- ══ HERO ════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="ws-container hero-inner">
    <div class="hero-copy">
      <div class="hero-badge">2026年4月 更新</div>
      <h1>ウォーターサーバー比較<br/>料金・解約条件まで確認</h1>
      <p class="hero-sub">
        浄水型・宅配水・天然水サーバーを、月額料金、交換のラクさ、
        置き場所、契約条件で比較。家族構成や使い方に合うサービスを選べます。
      </p>
      <div class="hero-ctas">
        <a href="#compare" class="btn-primary" data-scroll-to="#compare"
           data-track="hero_compare">
          料金・条件で比較する
        </a>
        <a href="#solo" class="btn-ghost" data-scroll-to="#solo"
           data-track="hero_solo">
          一人暮らし向けを見る
        </a>
        <a href="#family" class="btn-ghost" data-scroll-to="#family"
           data-track="hero_family">
          家族向けを見る
        </a>
      </div>
    </div>
    <div class="hero-media" aria-label="ウォーターサーバー比較のイメージ">
      <div class="hero-media-card">
        <img
          src="/water-server/images/hero-water-server-photo.png"
          alt="明るい室内でウォーターサーバーを利用する家族のイメージ"
          width="1576"
          height="998"
          decoding="async"
        />
      </div>
    </div>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f8fafc"/>
    </svg>
  </div>
</section>

<!-- ══ PR DISCLOSURE ═══════════════════════════════════════════ -->
<div style="background:#f8fafc;padding-bottom:.5rem">
  <p class="pr-bar">
    【PR・広告表記】このページにはアフィリエイトリンクを含みます。
    掲載順は報酬額だけでなく、サービス内容・比較しやすさ・確認すべき条件をもとに構成しています。
    料金・契約条件は変更になる場合があるため、申し込み前に必ず公式サイトでご確認ください。
  </p>
</div>

<!-- ══ 迷ったときの入口 ═══════════════════════════════════════ -->
<section class="ws-section section-white intent-section" id="intent">
  <div class="ws-container">
    <div class="section-head">
      <span class="kicker">START HERE</span>
      <h2>迷ったら、まず近い使い方から選ぶ</h2>
      <p>比較に入る前に、よくある目的別の入口を整理しました。</p>
    </div>
    <div class="intent-grid">
      <a class="intent-card" href="#solo" data-scroll-to="#solo" data-track="intent_solo">
        <span class="intent-label">一人暮らし・賃貸</span>
        <strong>省スペースで置きたい</strong>
        <p>卓上対応やボトル交換なしを優先。月額の見通しと置き場所を先に確認します。</p>
        <div class="intent-services">
          <span>every frecious</span>
          <span>OCEAN</span>
          <span>ウォーターワン</span>
        </div>
      </a>
      <a class="intent-card" href="#family" data-scroll-to="#family" data-track="intent_family">
        <span class="intent-label">家族で使う</span>
        <strong>使用量と水代を見たい</strong>
        <p>水の消費量が多い家庭向けに、宅配水の使いやすさと契約条件を見比べます。</p>
        <div class="intent-services">
          <span>オーケン</span>
          <span>ウォーターワン</span>
          <span>フレシャス</span>
        </div>
      </a>
      <a class="intent-card" href="#no-bottle" data-scroll-to="#no-bottle" data-track="intent_no_bottle">
        <span class="intent-label">ボトル交換なし</span>
        <strong>重い水を持ちたくない</strong>
        <p>浄水型を中心に、タンク給水か水道直結か、設置条件まで確認します。</p>
        <div class="intent-services">
          <span>every frecious</span>
          <span>OCEAN</span>
        </div>
      </a>
      <a class="intent-card" href="#natural-water" data-scroll-to="#natural-water" data-track="intent_natural_water">
        <span class="intent-label">天然水・宅配水</span>
        <strong>水の種類で選びたい</strong>
        <p>天然水やRO水など、水の種類と配送・保管のしやすさを確認します。</p>
        <div class="intent-services">
          <span>ウォーターワン</span>
          <span>フレシャス</span>
          <span>オーケン</span>
        </div>
      </a>
    </div>
    <p class="intent-note">迷った場合は、料金だけでなく最低利用期間・解約金まで見てから公式サイトへ進むのがおすすめです。</p>
  </div>
</section>

<!-- ══ 3秒でわかる選び方 ═══════════════════════════════════════ -->
<section class="ws-section section-white" id="guide">
  <div class="ws-container">
    <div class="section-head">
      <span class="kicker">TYPE GUIDE</span>
      <h2>3秒でわかる、タイプ別の選び方</h2>
      <p>まずウォーターサーバーのタイプを整理しましょう</p>
    </div>
    <div class="quick-grid">
      <div class="quick-card">
        <div class="quick-icon">🔩</div>
        <h3>浄水型</h3>
        <p>水道直結またはタンク給水で、本体内のフィルターでろ過。ボトル交換の手間がなく、水の買い置きも不要。設置スペースや月額コストの構造が宅配水と異なります。</p>
        <div class="tags">
          <span class="qtag">ボトル交換なし</span>
          <span class="qtag">水道水使用</span>
          <span class="qtag">フィルター交換あり</span>
        </div>
      </div>
      <div class="quick-card">
        <div class="quick-icon">🚚</div>
        <h3>宅配水（天然水含む）</h3>
        <p>ボトルやパックで水が届くタイプ。天然水・RO水など水の種類を選べます。使う量によって月額が変動するため、使用量の見積もりが重要です。</p>
        <div class="tags">
          <span class="qtag">ボトル交換あり</span>
          <span class="qtag">水の種類を選べる</span>
          <span class="qtag">使用量で料金変動</span>
        </div>
      </div>
      <div class="quick-card">
        <div class="quick-icon">📐</div>
        <h3>卓上・小型タイプ</h3>
        <p>床置きが難しい一人暮らしや狭いキッチン向け。浄水型・宅配水どちらにも卓上対応モデルがあります。設置可否は公式サイトの仕様で確認してください。</p>
        <div class="tags">
          <span class="qtag">卓上設置</span>
          <span class="qtag">スペース節約</span>
          <span class="qtag">一人暮らし向き</span>
        </div>
      </div>
    </div>
  </div>
</section>

