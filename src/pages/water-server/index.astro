---
const PAGE_TITLE = "浄水型・宅配水ウォーターサーバー比較｜水代見直しナビ";
const PAGE_DESC  = "浄水型・宅配水・天然水ウォーターサーバーを、月額料金、ボトル交換、置き場所、最低利用期間、解約条件で比較。生活スタイルに合う水まわりの選び方を整理します。";
const CANONICAL  = "https://vpscomparehub.com/water-server/";
const OGP_IMAGE  = "https://vpscomparehub.com/og-default.svg";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "浄水型と宅配水は何が違いますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "浄水型は水道水を本体内でろ過して使うタイプ、宅配水はボトルやパックで届く水を使うタイプです。料金、交換の手間、置き場所が異なります。" }
    },
    {
      "@type": "Question",
      "name": "一人暮らしでもウォーターサーバーは必要ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "使用量や置き場所によります。ペットボトルをよく買う人、重い買い物を減らしたい人は比較する価値があります。" }
    },
    {
      "@type": "Question",
      "name": "解約金はありますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "最低利用期間や解約金はサービスごとに異なります。申し込み前に公式サイトで最新条件を確認してください。" }
    },
    {
      "@type": "Question",
      "name": "このページは広告ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "このページには広告・アフィリエイトリンクを含みます。掲載順は報酬額だけでなく、サービス内容、比較しやすさ、確認すべき条件をもとに構成しています。" }
    }
  ]
};
