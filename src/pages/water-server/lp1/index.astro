    .lp1-purpose-items {
      display: grid;
      gap: .7rem;
      padding: 0 1rem 1rem 1.25rem;
    }
    .lp1-purpose-item {
      display: grid;
      grid-template-columns: 64px minmax(0, 1fr) auto;
      gap: .85rem;
      align-items: center;
      padding: .8rem;
      background: #fff;
      border: 1px solid #d8eef2;
      border-radius: 14px;
    }
    .lp1-purpose-rank {
      display: grid;
      place-items: center;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      color: #563500;
      background: radial-gradient(circle at 35% 30%, #fff2a8, #ffb72f 72%);
      font-weight: 900;
      font-size: .9rem;
      box-shadow: inset 0 -4px 0 rgba(0,0,0,.1);
    }
    .lp1-purpose-name {
      display: flex;
      flex-wrap: wrap;
      gap: .45rem .65rem;
      align-items: baseline;
      margin-bottom: .3rem;
    }
    .lp1-purpose-name strong {
      color: var(--lp-blue);
      font-size: 1.05rem;
      font-weight: 900;
    }
    .lp1-purpose-name span {
      color: var(--lp-teal-dark);
      font-size: .8rem;
      font-weight: 900;
    }
    .lp1-purpose-body p {
      margin: 0;
      color: #405763;
      line-height: 1.7;
      font-weight: 700;
    }
    .lp1-purpose-metrics {
      display: flex;
      flex-wrap: wrap;
      gap: .45rem;
      margin: .55rem 0 .35rem;
    }
    .lp1-purpose-metrics span {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: .28rem .6rem;
      color: var(--lp-teal-dark);
      background: #e9fbff;
      border: 1px solid #bfeaf0;
      font-size: .78rem;
      font-weight: 900;
    }
    .lp1-purpose-body small {
      display: block;
      color: var(--lp-muted);
      line-height: 1.55;
      font-weight: 700;
    }
    .lp1-purpose-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 112px;
      min-height: 44px;
      padding: .65rem .8rem;
      color: #fff;
      background: linear-gradient(180deg, #ff6a95, #f23978);
      border-radius: 999px;
      box-shadow: 0 5px 0 #c7235d;
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
      transition: transform .18s ease, box-shadow .18s ease;
    }
    .lp1-purpose-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 7px 0 #c7235d, 0 12px 20px rgba(242,57,120,.2);
      text-decoration: none;
    }

    .lp1-faq {
      background: #fff;
      border: 2px solid var(--lp-line);
      border-radius: 16px;
      box-shadow: 0 12px 32px rgba(7, 119, 131, .08);
      overflow: hidden;
    }
    .lp1-faq h2 {
      margin: 0;
      padding: 1rem;
      color: #fff;
      background: var(--lp-teal);
      text-align: center;
      font-size: 1.35rem;
    }
    .lp1-faq-item {
      padding: 1rem 1.2rem;
      border-top: 1px solid #e2f3f6;
    }
    .lp1-faq-item strong {
      display: block;
      color: var(--lp-teal-dark);
      margin-bottom: .35rem;
      font-size: 1.02rem;
    }
    .lp1-faq-item p {
      margin: 0;
      line-height: 1.8;
      color: #405763;
    }

    .lp1-final {
      text-align: center;
      background: linear-gradient(135deg, #0e9fab, #0f5f9e);
      color: #fff;
      border-radius: 20px;
      padding: 2rem 1rem;
      box-shadow: var(--lp-shadow);
    }
    .lp1-final h2 {
      margin: 0 0 .7rem;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      letter-spacing: 0;
    }
    .lp1-final p { margin: 0 auto 1rem; max-width: 720px; line-height: 1.8; color: rgba(255,255,255,.92); }
    .lp1-final .lp1-main-cta { background: #fff; color: #e02d68; box-shadow: 0 7px 0 rgba(0,0,0,.18); }

    .lp1-disclosure {
      font-size: .76rem;
      color: var(--lp-muted);
      line-height: 1.8;
      padding: 1rem 0 4rem;
      width: min(1120px, calc(100% - 28px));
      margin: 0 auto;
    }

    @keyframes lpPop {
      from { opacity: 0; transform: translateY(18px) scale(.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes lpPulse {
      0%, 100% { box-shadow: 0 8px 0 #c7235d, 0 18px 28px rgba(242,57,120,.22); }
      50% { box-shadow: 0 8px 0 #c7235d, 0 22px 36px rgba(242,57,120,.34); }
    }

    @media (max-width: 920px) {
      .lp1-wrap { grid-template-columns: 1fr; }
      .lp1-sidebar { position: static; order: 2; }
      .lp1-main { order: 1; }
      .lp1-side-box { display: none; }
      .lp1-usage-grid { grid-template-columns: 1fr; }
      .lp1-card-body { grid-template-columns: 1fr; }
      .lp1-card-media { max-width: 340px; }
      .lp1-chip-grid { grid-template-columns: repeat(2, 1fr); }
      .lp1-purpose-nav { grid-template-columns: repeat(2, 1fr); }
      .lp1-purpose-item { grid-template-columns: 56px minmax(0, 1fr); }
      .lp1-purpose-cta {
        grid-column: 2;
        justify-self: start;
      }
    }
    @media (max-width: 640px) {
      .lp1-top-inner { align-items: flex-start; flex-direction: column; gap: .35rem; }
      .lp1-nav-inner { grid-template-columns: repeat(2, 1fr); }
      .lp1-nav a { padding: .7rem .25rem; font-size: .84rem; }
      .lp1-hero {
        background:
          linear-gradient(180deg, rgba(238,254,255,.98), rgba(238,254,255,.84)),
          url("/water-server/images/hero-water-server-photo.png") 62% center / cover no-repeat;
      }
      .lp1-hero-inner { min-height: auto; padding: 2.1rem 0 3.5rem; }
      .lp1-hero-card { padding: 1.15rem; border-radius: 14px; }
      .lp1-hero h1 { font-size: 1.35rem; }
      .lp1-hero h1 strong { font-size: 2.15rem; }
      .lp1-hero-points { grid-template-columns: 1fr; }
      .lp1-cta-row { display: grid; grid-template-columns: 1fr; }
      .lp1-main-cta, .lp1-sub-cta { width: 100%; }
      .lp1-section-title {
        flex-wrap: wrap;
        line-height: 1.35;
        font-size: 1.02rem;
        padding: .85rem .55rem;
      }
      .lp1-card-head { grid-template-columns: auto 1fr; }
      .lp1-score { grid-column: 1 / -1; justify-self: start; }
      .lp1-card-rank { width: 54px; height: 54px; }
      .lp1-card-body { padding: .85rem; }
      .lp1-chip-grid { grid-template-columns: 1fr; }
      .lp1-purpose-intro { text-align: left; font-size: .93rem; }
      .lp1-purpose-nav { grid-template-columns: 1fr; }
      .lp1-purpose-head { grid-template-columns: 1fr; padding: .9rem .85rem .65rem 1rem; }
      .lp1-purpose-kicker {
        min-height: 44px;
        width: max-content;
        min-width: 92px;
        border-radius: 999px;
        box-shadow: none;
      }
      .lp1-purpose-verdict { margin: 0 .85rem .8rem 1rem; }
      .lp1-purpose-items { padding: 0 .85rem .9rem 1rem; }
      .lp1-purpose-item {
        grid-template-columns: 1fr;
        gap: .55rem;
      }
      .lp1-purpose-rank {
        width: auto;
        height: auto;
        border-radius: 999px;
        padding: .28rem .7rem;
        justify-self: start;
      }
      .lp1-purpose-cta {
        grid-column: 1;
        justify-self: stretch;
      }
      .lp1-disclosure { padding-bottom: 6rem; }
    }
  </style>
</head>
<body class="lp1">
  <header class="lp1-top">
    <div class="lp1-top-inner">
      <a class="lp1-logo" href="/water-server/lp1">
        <span class="lp1-logo-mark" aria-hidden="true"></span>
        <span>水代見直しナビ</span>
      </a>
      <span>※本ページにはPR・アフィリエイトリンクが含まれます</span>
    </div>
  </header>

  <nav class="lp1-nav" aria-label="ページ内メニュー">
    <div class="lp1-nav-inner">
      <a href="#quick" data-scroll-to="#quick">早見表</a>
      <a href="#usage" data-scroll-to="#usage">水量目安</a>
      <a href="#ranking" data-scroll-to="#ranking">ランキング</a>
      <a href="#search" data-scroll-to="#search">目的別</a>
      <a href="#faq" data-scroll-to="#faq">基礎情報</a>
    </div>
  </nav>

  <main>
    <section class="lp1-hero">
      <div class="lp1-hero-inner">
        <div class="lp1-hero-card">
          <span class="lp1-edition">2026年5月最新版</span>
          <h1><span>ウォーターサーバー</span><strong><em>総合評価</em><em>ランキング</em></strong></h1>
          <p class="lp1-hero-lead">
            「安いのはどれ？」「月いくら？」「契約して損しない？」を、申し込み前に一気に確認。
            料金・水代・契約条件まで見て、最初に公式で確認すべき候補を絞れます。
          </p>
          <div class="lp1-hero-points">
            <div class="lp1-hero-point">料金重視<small>水代・月額で比較</small></div>
            <div class="lp1-hero-point">条件重視<small>解約金まで確認</small></div>
            <div class="lp1-hero-point">目的別<small>一人暮らし・家族</small></div>
          </div>
          <div class="lp1-cta-row">
            <a class="lp1-main-cta" href="https://px.a8.net/svt/ejp?a8mat=4B1XE4+325A0A+1LOO+5Z6WY" data-affiliate="oken" data-track="lp1_hero_oken" rel="nofollow sponsored">1位の料金条件を確認する</a>
            <a class="lp1-sub-cta" href="#quick" data-scroll-to="#quick" data-track="lp1_hero_compare">比較表から見る</a>
          </div>
        </div>
      </div>
    </section>

    <div class="lp1-wrap">
      <aside class="lp1-sidebar" aria-label="サイドメニュー">
        <div class="lp1-side-box">
          <div class="lp1-side-title">目的別ページ</div>
          <a class="lp1-side-link" href="#quick" data-scroll-to="#quick"><span class="lp1-side-badge">総</span>総合評価ランキング</a>
          <a class="lp1-side-link" href="#usage" data-scroll-to="#usage"><span class="lp1-side-badge">量</span>水量・ボトル目安</a>
          <a class="lp1-side-link" href="/water-server/lp1/price"><span class="lp1-side-badge">安</span>料金重視</a>
          <a class="lp1-side-link" href="/water-server/lp1/jousui"><span class="lp1-side-badge">浄</span>浄水型・定額</a>
          <a class="lp1-side-link" href="/water-server/lp1/solo"><span class="lp1-side-badge">単</span>一人暮らし向け</a>
          <a class="lp1-side-link" href="/water-server/lp1/family"><span class="lp1-side-badge">家</span>家族向け</a>
          <a class="lp1-side-link" href="#faq" data-scroll-to="#faq"><span class="lp1-side-badge">基</span>基礎情報</a>
        </div>
        <div class="lp1-side-box lp1-brand">
          <div class="lp1-side-title">人気ブランド一覧</div>
          {services.map((service) => (
            <a class="lp1-side-link" href={`#${service.id}`} data-scroll-to={`#${service.id}`}>{service.name}</a>
          ))}
        </div>
      </aside>

      <div class="lp1-main">
        <section class="lp1-compare reveal-up" id="quick">
          <h2 class="lp1-section-title">まずはここだけ見ればOK 早見比較表</h2>
          <div class="lp1-update">
            <span>更新日：2026年5月14日</span>
            <span>キャンペーン確認日：2026年5月14日</span>
          </div>
          <div class="lp1-compare-scroll">
            <table>
              <thead>
                <tr>
                  <th>比較項目</th>
                  {services.map((service) => (
                    <th class={service.rank === 1 ? "lp1-winner" : ""}>
                      <span class="lp1-rank-medal">第{service.rank}位</span>
                      <a class="lp1-name" href={`#${service.id}`} data-scroll-to={`#${service.id}`}>{service.name}</a>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>最低料金目安</td>
                  {services.map((service) => (
                    <td class={service.rank === 1 ? "lp1-winner" : ""}>
                      <span class="lp1-price">{service.monthly}</span><br />
                      <small>{service.monthlyNote}</small>
                    </td>
                  ))}
                </tr>
                <tr>
                  <td>料金に含む水量</td>
                  {services.map((service) => <td>{service.priceBasis}</td>)}
                </tr>
                <tr>
                  <td>ボトル単価</td>
                  {services.map((service) => (
                    <td>
                      <strong>{service.bottleUnit}</strong><br />
                      <small>{service.bottlePrice}</small>
                    </td>
                  ))}
                </tr>
                <tr>
                  <td>お湯 / 冷水</td>
                  {services.map((service) => (
                    <td>
                      <strong>{service.hotTemp}</strong><br />
                      <small>{service.coldTemp}</small>
                    </td>
                  ))}
                </tr>
                <tr>
                  <td>最新キャンペーン</td>
                  {services.map((service) => <td class="lp1-campaign-cell">{service.campaign}</td>)}
                </tr>
                <tr>
                  <td>タイプ</td>
                  {services.map((service) => <td>{service.type}</td>)}
                </tr>
                <tr>
                  <td>サーバー</td>
                  {services.map((service) => <td>{service.style}</td>)}
                </tr>
                <tr>
                  <td>おすすめ</td>
                  {services.map((service) => <td>{service.fit}</td>)}
                </tr>
                <tr>
                  <td>公式確認</td>
                  {services.map((service) => (
                    <td>
                      <a class="lp1-mini-cta" href={service.link} data-affiliate={service.affiliate} data-track={`lp1_table_${service.id}`} rel="nofollow sponsored">詳しく見る</a>
                    </td>
                  ))}
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="lp1-usage reveal-up" id="usage">
          <h2 class="lp1-section-title">12Lボトルは何日持つ？人数別の水量目安</h2>
          <div class="lp1-usage-inner">
            <div class="lp1-formula">
              <span>計算式：12L ÷（人数 × 0.6〜1.2L/日）</span>
              <small>飲用中心のざっくり目安です。厚生労働省の「1日あと2杯」「飲み水1.2L」目安を上限側に置き、料理・お茶・ミルクに使う家庭は多めに見ます。</small>
            </div>
            <div class="lp1-usage-grid">
              {bottleUsageRows.map((row) => (
                <article class="lp1-usage-card">
                  <h3>{row.family}の場合</h3>
                  <dl>
                    <dt>使用量</dt><dd>{row.daily}</dd>
                    <dt>12L 1本</dt><dd>{row.oneBottle}</dd>
                    <dt>12L 2本</dt><dd>{row.twoBottles}</dd>
                    <dt>月の本数</dt><dd>{row.monthly}</dd>
                  </dl>
                  <p>{row.note}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="lp1-search reveal-up" id="search">
          <h2 class="lp1-section-title">目的別ページで最短チェック</h2>
          <p class="lp1-purpose-intro">
            総合ランキングだけで決めず、料金・浄水型・一人暮らし・家族利用の4ページに分けました。
            それぞれ見るべき費用や条件が違うので、今の目的に近いページから確認してください。
          </p>
          <div class="lp1-purpose-nav" aria-label="目的別ページ一覧">
            {purposePages.map((page) => (
              <a href={page.href}>
                <span>{page.label}</span>
                <small>{page.title}</small>
              </a>
            ))}
          </div>
          <div class="lp1-purpose-list">
            {purposePages.map((page) => (
              <section class="lp1-purpose-card reveal-up">
                <header class="lp1-purpose-head">
                  <span class="lp1-purpose-kicker">{page.badge}</span>
                  <div>
                    <h3>{page.title}</h3>
                    <p>{page.lead}</p>
                  </div>
                </header>
                <div class="lp1-purpose-verdict">{page.best}</div>
                <div class="lp1-purpose-items">
                  <article class="lp1-purpose-item">
                    <div class="lp1-purpose-rank">GO</div>
                    <div class="lp1-purpose-body">
                      <div class="lp1-purpose-name">
                        <strong>{page.title}</strong>
                        <span>専用ページで比較</span>
                      </div>
                      <p>{page.lead}</p>
                      <small>比較表・注意点・おすすめ候補をこの目的に合わせて整理しています。</small>
                    </div>
                    <a class="lp1-purpose-cta" href={page.href}>
                      ページを見る
                    </a>
                  </article>
                </div>
              </section>
            ))}
          </div>
        </section>

        <section id="ranking" class="lp1-ranking-list">
          <h2 class="lp1-section-title">2026年5月 最新ランキング</h2>
          {services.map((service) => (
            <article class="lp1-card service-card" id={service.id}>
              <header class="lp1-card-head">
                <div class="lp1-card-rank"><small>第</small>{service.rank}位</div>
                <div class="lp1-card-title">
                  <h3>{service.name}</h3>
                  <p>{service.catch}</p>
                </div>
                <div class="lp1-score">評価 {service.score}</div>
              </header>
              <div class="lp1-card-body">
                <div class="lp1-card-media">
                  <a class="lp1-banner" href={service.bannerLink} data-affiliate={service.bannerAffiliate} data-track={`lp1_banner_${service.id}`} rel="nofollow sponsored" referrerpolicy="no-referrer-when-downgrade">
                    <img src={service.bannerSrc} alt={service.bannerAlt} loading="lazy" width="300" height="250" />
                  </a>
                  <div class="lp1-badge-row">
                    <span class="lp1-pill">{service.badge}</span>
                    <span class="lp1-pill">{service.type}</span>
                    <span class="lp1-pill">{service.style}</span>
                  </div>
                </div>
                <div>
                  <table class="lp1-spec">
                    <tbody>
                      <tr><th>月額目安</th><td><strong class="lp1-price">{service.monthly}</strong><br /><small>{service.monthlyNote}</small></td></tr>
                      <tr><th>水量目安</th><td>{service.priceBasis}</td></tr>
                      <tr><th>水代単価</th><td><strong>{service.bottleUnit}</strong><br /><small>{service.bottlePrice}</small></td></tr>
                      <tr><th>温度</th><td>温水：{service.hotTemp}<br /><small>冷水：{service.coldTemp}</small></td></tr>
                      <tr><th>サーバー料</th><td>{service.serverFee}</td></tr>
                      <tr><th>タイプ</th><td>{service.type}</td></tr>
                      <tr><th>注文方法</th><td>{service.order}</td></tr>
                      <tr><th>メンテナンス</th><td>{service.maintenance}</td></tr>
                    </tbody>
                  </table>
                  <ul class="lp1-point-list">
                    {service.points.map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="lp1-campaign">{service.campaign}</div>
                  <div class="lp1-card-actions">
                    <a class="lp1-main-cta" href={service.link} data-affiliate={service.affiliate} data-track={`lp1_card_${service.id}`} rel="nofollow sponsored">{service.cta}</a>
                    <a class="lp1-sub-cta" href="#quick" data-scroll-to="#quick" data-track={`lp1_back_table_${service.id}`}>比較表へ戻る</a>
                  </div>
                  <p class="lp1-note">※ 料金・キャンペーン・最低利用期間・解約金は変更される場合があります。申し込み前に必ず公式サイトの最新情報をご確認ください。</p>
                </div>
              </div>
            </article>
          ))}
        </section>

        <section class="lp1-faq reveal-up" id="faq">
          <h2>申し込み前によくある確認ポイント</h2>
          <div class="lp1-faq-item">
            <strong>Q. 月額料金だけで選んでいい？</strong>
            <p>月額だけでは不十分です。水代、送料、サーバーレンタル料、注文ノルマ、最低利用期間、解約金まで見て総額で判断してください。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. 水代を抑えたいならどのタイプ？</strong>
            <p>水代重視ならRO水の宅配水、使用量が多いなら浄水型の定額制が候補です。少量利用か多量利用かで最適なタイプが変わります。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. 広告で見たキャンペーンは信じていい？</strong>
            <p>キャンペーンは期間や条件が変わります。このページでは公式サイトへの確認導線を置いているので、申し込み直前に最新条件を確認してください。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. 12Lボトル1本はどれくらい持つ？</strong>
            <p>1人なら飲用中心で約10〜20日、4人家族なら約2.5〜5日が目安です。お茶・料理・赤ちゃんのミルクにも使う家庭は消費が早くなるため、月2本だけで足りるか先に確認してください。</p>
          </div>
