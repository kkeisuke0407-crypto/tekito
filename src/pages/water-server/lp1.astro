      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      padding: .65rem 0;
    }
    .lp1-logo {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      color: #fff;
      text-decoration: none;
      font-weight: 900;
      letter-spacing: .02em;
      font-size: 1.1rem;
    }
    .lp1-logo-mark {
      width: 34px;
      height: 34px;
      border-radius: 50% 50% 45% 45%;
      background: linear-gradient(135deg, #6ee7f2, #10aeb9);
      box-shadow: inset 0 -5px 0 rgba(0, 0, 0, .12);
    }
    .lp1-nav {
      position: sticky;
