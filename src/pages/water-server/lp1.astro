      padding: .7rem .55rem;
      text-align: center;
      font-weight: 900;
      color: var(--lp-teal-dark);
    }
    .lp1-hero-point small {
      display: block;
      color: var(--lp-muted);
      font-size: .72rem;
      margin-top: .12rem;
    }
    .lp1-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: .7rem;
      align-items: center;
    }
    .lp1-main-cta,
    .lp1-sub-cta,
    .lp1-mini-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      border-radius: 999px;
      font-weight: 900;
      transition: transform .18s ease, box-shadow .18s ease;
    }
    .lp1-main-cta {
      min-height: 52px;
      padding: .9rem 1.5rem;
      color: #fff;
      background: linear-gradient(180deg, #ff6a95, #f23978);
      box-shadow: 0 8px 0 #c7235d, 0 18px 28px rgba(242,57,120,.22);
      animation: lpPulse 2.4s ease-in-out infinite;
    }
    .lp1-sub-cta {
      min-height: 48px;
      padding: .78rem 1.1rem;
      color: var(--lp-teal-dark);
      background: #fff;
      border: 2px solid var(--lp-teal);
    }
    .lp1-main-cta:hover,
    .lp1-sub-cta:hover,
    .lp1-mini-cta:hover { transform: translateY(-2px); text-decoration: none; }
    body.lp1 .sticky-cta-bar { display: none !important; }

    .lp1-wrap {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 1.25rem;
      padding: 2rem 0 4rem;
      align-items: start;
    }
    .lp1-sidebar {
      position: sticky;
      top: 68px;
      display: grid;
      gap: 1rem;
    }
    .lp1-side-box {
      background: #fff;
      border: 2px solid var(--lp-line);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 12px 26px rgba(7, 119, 131, .08);
    }
    .lp1-side-title {
      background: var(--lp-teal);
      color: #fff;
      font-weight: 900;
      text-align: center;
      padding: .7rem;
    }
    .lp1-side-link {
      display: flex;
      align-items: center;
      gap: .55rem;
      padding: .8rem .85rem;
      text-decoration: none;
      border-top: 1px dashed #c8dbe1;
      color: var(--lp-teal-dark);
      font-weight: 800;
      line-height: 1.45;
    }
    .lp1-side-badge {
