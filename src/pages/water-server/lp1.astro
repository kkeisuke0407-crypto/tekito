      display: block;
      color: var(--lp-blue);
      font-size: 1rem;
      font-weight: 900;
      text-decoration: underline;
    }
    .lp1-price {
      color: #f04d25;
      font-size: 1.15rem;
      font-weight: 900;
    }
    .lp1-mini-cta {
      padding: .58rem .85rem;
      color: #fff;
      background: var(--lp-pink);
      box-shadow: 0 4px 0 #c7235d;
      font-size: .84rem;
    }
    .lp1-winner {
      background: #fffceb !important;
      box-shadow: inset 0 0 0 3px rgba(255, 211, 64, .75);
    }

    .lp1-ranking-list {
      display: grid;
      gap: 1.2rem;
    }
    .lp1-card {
      background: #fff;
      border: 2px solid var(--lp-line);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--lp-shadow);
    }
    .lp1-card-head {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: .85rem;
      align-items: center;
      background: linear-gradient(90deg, var(--lp-teal), #55d4dc);
      color: #fff;
      padding: .85rem 1rem;
    }
    .lp1-card-rank {
      display: grid;
      place-items: center;
      width: 64px;
      height: 64px;
      color: #563500;
      background: linear-gradient(135deg, #ffe484, #ffb82f);
      clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
      font-weight: 900;
      line-height: 1.1;
      text-align: center;
    }
    .lp1-card-rank small { display: block; font-size: .67rem; }
    .lp1-card-title h3 {
      margin: 0;
      font-size: clamp(1.18rem, 2.4vw, 1.75rem);
      font-weight: 900;
      letter-spacing: 0;
    }
    .lp1-card-title p {
      margin: .25rem 0 0;
      color: rgba(255,255,255,.92);
      font-weight: 700;
    }
    .lp1-score {
      display: grid;
      place-items: center;
      background: #fff;
      color: var(--lp-teal-dark);
      border-radius: 999px;
      min-width: 82px;
      padding: .5rem .75rem;
      font-weight: 900;
    }
    .lp1-card-body {
      padding: 1rem;
      display: grid;
      grid-template-columns: minmax(230px, 300px) minmax(0, 1fr);
      gap: 1rem;
    }
    .lp1-card-media {
      display: grid;
      gap: .7rem;
      align-content: start;
    }
    .lp1-banner {
      background: #eefbfe;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--lp-line);
    }
    .lp1-banner img {
      width: 100%;
      aspect-ratio: 6 / 5;
      object-fit: contain;
      background: #fff;
    }
    .lp1-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: .45rem;
    }
    .lp1-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: .35rem .65rem;
      background: #e9fbff;
      color: var(--lp-teal-dark);
      border: 1px solid #bfeaf0;
      font-size: .78rem;
      font-weight: 900;
    }
    .lp1-spec {
      border-collapse: collapse;
      width: 100%;
      font-size: .9rem;
    }
    .lp1-spec th,
    .lp1-spec td {
      border: 1px solid #d8eef2;
      padding: .58rem .7rem;
      text-align: left;
    }
    .lp1-spec th {
      width: 118px;
      background: #dff8fb;
      color: var(--lp-teal-dark);
      font-weight: 900;
    }
    .lp1-point-list {
      margin: .9rem 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: .55rem;
    }
    .lp1-point-list li {
      position: relative;
      padding-left: 1.45rem;
      line-height: 1.65;
      font-weight: 700;
    }
    .lp1-point-list li::before {
      content: "";
      width: .68rem;
      height: .68rem;
      position: absolute;
      left: 0;
      top: .58rem;
      border-radius: 50%;
      background: var(--lp-teal);
      box-shadow: 0 0 0 4px #e6fbff;
    }
    .lp1-campaign {
      background: linear-gradient(90deg, #fff5c2, #fffbe8);
      border: 2px solid #ffe28a;
      border-radius: 12px;
      padding: .85rem;
      margin: .8rem 0 1rem;
      font-weight: 900;
      color: #735100;
    }
    .lp1-card-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem;
      align-items: center;
    }
    .lp1-card-actions .lp1-main-cta {
      flex: 1 1 280px;
      min-height: 56px;
    }
    .lp1-card-actions .lp1-sub-cta {
      flex: 0 1 160px;
    }
    .lp1-note {
      font-size: .76rem;
      color: var(--lp-muted);
      line-height: 1.7;
      margin: .8rem 0 0;
    }

    .lp1-search {
      background: #fff;
      border: 2px solid var(--lp-line);
      border-radius: 16px;
      padding: 1rem;
      box-shadow: 0 12px 32px rgba(7, 119, 131, .08);
    }
    .lp1-chip-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .65rem;
      margin-top: .85rem;
    }
    .lp1-chip-grid a {
      display: grid;
      place-items: center;
      min-height: 56px;
      padding: .55rem;
      border-radius: 12px;
      background: #effcff;
      border: 1px solid var(--lp-line);
      text-decoration: none;
      color: var(--lp-teal-dark);
      font-weight: 900;
      text-align: center;
    }

    .lp1-faq {
      background: #fff;
      border: 2px solid var(--lp-line);
      border-radius: 16px;
      box-shadow: 0 12px 32px rgba(7, 119, 131, .08);
      overflow: hidden;
    }
    .lp1-faq h2 {
      margin: 0;
      padding: 1rem;
      color: #fff;
      background: var(--lp-teal);
      text-align: center;
      font-size: 1.35rem;
    }
    .lp1-faq-item {
      padding: 1rem 1.2rem;
      border-top: 1px solid #e2f3f6;
    }
    .lp1-faq-item strong {
      display: block;
      color: var(--lp-teal-dark);
      margin-bottom: .35rem;
      font-size: 1.02rem;
    }
    .lp1-faq-item p {
      margin: 0;
      line-height: 1.8;
      color: #405763;
    }

    .lp1-final {
      text-align: center;
      background: linear-gradient(135deg, #0e9fab, #0f5f9e);
      color: #fff;
      border-radius: 20px;
      padding: 2rem 1rem;
      box-shadow: var(--lp-shadow);
    }
    .lp1-final h2 {
      margin: 0 0 .7rem;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      letter-spacing: 0;
    }
    .lp1-final p { margin: 0 auto 1rem; max-width: 720px; line-height: 1.8; color: rgba(255,255,255,.92); }
    .lp1-final .lp1-main-cta { background: #fff; color: #e02d68; box-shadow: 0 7px 0 rgba(0,0,0,.18); }

    .lp1-disclosure {
      font-size: .76rem;
      color: var(--lp-muted);
      line-height: 1.8;
      padding: 1rem 0 4rem;
      width: min(1120px, calc(100% - 28px));
      margin: 0 auto;
    }

    @keyframes lpPop {
      from { opacity: 0; transform: translateY(18px) scale(.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes lpPulse {
      0%, 100% { box-shadow: 0 8px 0 #c7235d, 0 18px 28px rgba(242,57,120,.22); }
      50% { box-shadow: 0 8px 0 #c7235d, 0 22px 36px rgba(242,57,120,.34); }
    }

    @media (max-width: 920px) {
      .lp1-wrap { grid-template-columns: 1fr; }
      .lp1-sidebar { position: static; order: 2; }
      .lp1-main { order: 1; }
      .lp1-side-box { display: none; }
      .lp1-card-body { grid-template-columns: 1fr; }
      .lp1-card-media { max-width: 340px; }
      .lp1-chip-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .lp1-top-inner { align-items: flex-start; flex-direction: column; gap: .35rem; }
      .lp1-nav-inner { grid-template-columns: repeat(2, 1fr); }
      .lp1-nav a { padding: .7rem .25rem; font-size: .84rem; }
      .lp1-hero {
        background:
          linear-gradient(180deg, rgba(238,254,255,.98), rgba(238,254,255,.84)),
          url("/water-server/images/hero-water-server-photo.png") 62% center / cover no-repeat;
      }
      .lp1-hero-inner { min-height: auto; padding: 2.1rem 0 3.5rem; }
      .lp1-hero-card { padding: 1.15rem; border-radius: 14px; }
      .lp1-hero h1 { font-size: 1.35rem; }
      .lp1-hero h1 strong { font-size: 2.15rem; }
      .lp1-hero-points { grid-template-columns: 1fr; }
      .lp1-cta-row { display: grid; grid-template-columns: 1fr; }
      .lp1-main-cta, .lp1-sub-cta { width: 100%; }
      .lp1-section-title {
        flex-wrap: wrap;
        line-height: 1.35;
        font-size: 1.02rem;
        padding: .85rem .55rem;
      }
      .lp1-card-head { grid-template-columns: auto 1fr; }
      .lp1-score { grid-column: 1 / -1; justify-self: start; }
      .lp1-card-rank { width: 54px; height: 54px; }
      .lp1-card-body { padding: .85rem; }
      .lp1-chip-grid { grid-template-columns: 1fr; }
      .lp1-disclosure { padding-bottom: 6rem; }
    }
  </style>
</head>
<body class="lp1">
  <header class="lp1-top">
    <div class="lp1-top-inner">
      <a class="lp1-logo" href="/water-server/lp1">
        <span class="lp1-logo-mark" aria-hidden="true"></span>
        <span>水代見直しナビ</span>
      </a>
      <span>※本ページにはPR・アフィリエイトリンクが含まれます</span>
    </div>
  </header>

  <nav class="lp1-nav" aria-label="ページ内メニュー">
    <div class="lp1-nav-inner">
      <a href="#quick" data-scroll-to="#quick">早見表</a>
      <a href="#ranking" data-scroll-to="#ranking">ランキング</a>
      <a href="#search" data-scroll-to="#search">目的別</a>
      <a href="#faq" data-scroll-to="#faq">基礎情報</a>
    </div>
  </nav>

  <main>
    <section class="lp1-hero">
      <div class="lp1-hero-inner">
        <div class="lp1-hero-card">
          <span class="lp1-edition">2026年5月最新版</span>
          <h1><span>ウォーターサーバー</span><strong><em>総合評価</em><em>ランキング</em></strong></h1>
          <p class="lp1-hero-lead">
            「安いのはどれ？」「月いくら？」「契約して損しない？」を、申し込み前に一気に確認。
            料金・水代・契約条件まで見て、最初に公式で確認すべき候補を絞れます。
          </p>
          <div class="lp1-hero-points">
            <div class="lp1-hero-point">料金重視<small>水代・月額で比較</small></div>
            <div class="lp1-hero-point">条件重視<small>解約金まで確認</small></div>
            <div class="lp1-hero-point">目的別<small>一人暮らし・家族</small></div>
          </div>
          <div class="lp1-cta-row">
            <a class="lp1-main-cta" href="https://px.a8.net/svt/ejp?a8mat=4B1XE4+325A0A+1LOO+5Z6WY" data-affiliate="oken" data-track="lp1_hero_oken" rel="nofollow sponsored">1位の料金条件を確認する</a>
            <a class="lp1-sub-cta" href="#quick" data-scroll-to="#quick" data-track="lp1_hero_compare">比較表から見る</a>
          </div>
        </div>
      </div>
    </section>

    <div class="lp1-wrap">
      <aside class="lp1-sidebar" aria-label="サイドメニュー">
        <div class="lp1-side-box">
          <div class="lp1-side-title">目的別ランキング</div>
          <a class="lp1-side-link" href="#quick" data-scroll-to="#quick"><span class="lp1-side-badge">総</span>総合評価ランキング</a>
          <a class="lp1-side-link" href="#low-cost" data-scroll-to="#low-cost"><span class="lp1-side-badge">安</span>価格が安い候補</a>
          <a class="lp1-side-link" href="#jousui" data-scroll-to="#jousui"><span class="lp1-side-badge">浄</span>浄水型サーバー</a>
          <a class="lp1-side-link" href="#solo" data-scroll-to="#solo"><span class="lp1-side-badge">単</span>一人暮らし向け</a>
          <a class="lp1-side-link" href="#faq" data-scroll-to="#faq"><span class="lp1-side-badge">基</span>基礎情報</a>
        </div>
        <div class="lp1-side-box lp1-brand">
          <div class="lp1-side-title">人気ブランド一覧</div>
          {services.map((service) => (
            <a class="lp1-side-link" href={`#${service.id}`} data-scroll-to={`#${service.id}`}>{service.name}</a>
          ))}
          <a class="lp1-side-link" href="#search" data-scroll-to="#search">OCEAN</a>
        </div>
      </aside>

      <div class="lp1-main">
        <section class="lp1-compare reveal-up" id="quick">
          <h2 class="lp1-section-title">まずはここだけ見ればOK 早見比較表</h2>
          <div class="lp1-update">
            <span>更新日：2026年5月13日</span>
            <span>料金・キャンペーンは公式サイトで最新確認</span>
          </div>
          <div class="lp1-compare-scroll">
            <table>
              <thead>
                <tr>
                  <th>比較項目</th>
                  {services.slice(0, 4).map((service) => (
                    <th class={service.rank === 1 ? "lp1-winner" : ""}>
                      <span class="lp1-rank-medal">第{service.rank}位</span>
                      <a class="lp1-name" href={`#${service.id}`} data-scroll-to={`#${service.id}`}>{service.name}</a>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>月額目安</td>
                  {services.slice(0, 4).map((service) => (
                    <td class={service.rank === 1 ? "lp1-winner" : ""}>
                      <span class="lp1-price">{service.monthly}</span><br />
                      <small>{service.monthlyNote}</small>
                    </td>
                  ))}
                </tr>
                <tr>
                  <td>タイプ</td>
                  {services.slice(0, 4).map((service) => <td>{service.type}</td>)}
                </tr>
                <tr>
                  <td>サーバー</td>
                  {services.slice(0, 4).map((service) => <td>{service.style}</td>)}
                </tr>
                <tr>
                  <td>おすすめ</td>
                  {services.slice(0, 4).map((service) => <td>{service.fit}</td>)}
                </tr>
                <tr>
                  <td>公式確認</td>
                  {services.slice(0, 4).map((service) => (
                    <td>
                      <a class="lp1-mini-cta" href={service.link} data-affiliate={service.affiliate} data-track={`lp1_table_${service.id}`} rel="nofollow sponsored">詳しく見る</a>
                    </td>
                  ))}
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="lp1-search reveal-up" id="search">
          <h2 class="lp1-section-title">迷っている条件から選ぶ</h2>
          <div class="lp1-chip-grid">
            <a href="#oken" id="low-cost" data-scroll-to="#oken">月額・水代を抑えたい</a>
            <a href="#every" id="jousui" data-scroll-to="#every">ボトル交換なしが良い</a>
            <a href="#cosmo" data-scroll-to="#cosmo">天然水を選びたい</a>
            <a href="#frecious" data-scroll-to="#frecious">デザインも重視</a>
            <a href="#water-one" data-scroll-to="#water-one">卓上も見たい</a>
            <a href="#quick" id="solo" data-scroll-to="#quick">一人暮らし向け</a>
            <a href="#faq" data-scroll-to="#faq">解約金を確認</a>
            <a href="#ranking" data-scroll-to="#ranking">ランキングを見る</a>
          </div>
        </section>

        <section id="ranking" class="lp1-ranking-list">
          <h2 class="lp1-section-title">2026年5月 最新ランキング</h2>
          {services.map((service) => (
            <article class="lp1-card service-card" id={service.id}>
              <header class="lp1-card-head">
                <div class="lp1-card-rank"><small>第</small>{service.rank}位</div>
                <div class="lp1-card-title">
                  <h3>{service.name}</h3>
                  <p>{service.catch}</p>
                </div>
                <div class="lp1-score">評価 {service.score}</div>
              </header>
              <div class="lp1-card-body">
                <div class="lp1-card-media">
                  <a class="lp1-banner" href={service.bannerLink} data-affiliate={service.bannerAffiliate} data-track={`lp1_banner_${service.id}`} rel="nofollow sponsored" referrerpolicy="no-referrer-when-downgrade">
                    <img src={service.bannerSrc} alt={service.bannerAlt} loading="lazy" width="300" height="250" />
                  </a>
                  <div class="lp1-badge-row">
                    <span class="lp1-pill">{service.badge}</span>
                    <span class="lp1-pill">{service.type}</span>
                    <span class="lp1-pill">{service.style}</span>
                  </div>
                </div>
                <div>
                  <table class="lp1-spec">
                    <tbody>
                      <tr><th>月額目安</th><td><strong class="lp1-price">{service.monthly}</strong><br /><small>{service.monthlyNote}</small></td></tr>
                      <tr><th>サーバー料</th><td>{service.serverFee}</td></tr>
                      <tr><th>タイプ</th><td>{service.type}</td></tr>
                      <tr><th>注文方法</th><td>{service.order}</td></tr>
                      <tr><th>メンテナンス</th><td>{service.maintenance}</td></tr>
                    </tbody>
                  </table>
                  <ul class="lp1-point-list">
                    {service.points.map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="lp1-campaign">{service.campaign}</div>
                  <div class="lp1-card-actions">
                    <a class="lp1-main-cta" href={service.link} data-affiliate={service.affiliate} data-track={`lp1_card_${service.id}`} rel="nofollow sponsored">{service.cta}</a>
                    <a class="lp1-sub-cta" href="#quick" data-scroll-to="#quick" data-track={`lp1_back_table_${service.id}`}>比較表へ戻る</a>
                  </div>
                  <p class="lp1-note">※ 料金・キャンペーン・最低利用期間・解約金は変更される場合があります。申し込み前に必ず公式サイトの最新情報をご確認ください。</p>
                </div>
              </div>
            </article>
          ))}
        </section>

        <section class="lp1-faq reveal-up" id="faq">
          <h2>申し込み前によくある確認ポイント</h2>
          <div class="lp1-faq-item">
            <strong>Q. 月額料金だけで選んでいい？</strong>
            <p>月額だけでは不十分です。水代、送料、サーバーレンタル料、注文ノルマ、最低利用期間、解約金まで見て総額で判断してください。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. 水代を抑えたいならどのタイプ？</strong>
            <p>水代重視ならRO水の宅配水、使用量が多いなら浄水型の定額制が候補です。少量利用か多量利用かで最適なタイプが変わります。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. 広告で見たキャンペーンは信じていい？</strong>
            <p>キャンペーンは期間や条件が変わります。このページでは公式サイトへの確認導線を置いているので、申し込み直前に最新条件を確認してください。</p>
          </div>
          <div class="lp1-faq-item">
            <strong>Q. まずどこから見ればいい？</strong>
            <p>価格検索で来た場合は、1位のオーケンウォーターと2位のevery freciousを先に比較すると、宅配水と浄水型の違いがすぐ見えます。</p>
          </div>
        </section>

        <section class="lp1-final reveal-up">
          <h2>料金で迷うなら、まず1位の公式条件から確認</h2>
          <p>
            ウォーターサーバーは、安く見えても注文回数や解約条件で総額が変わります。
            公式条件を確認してから申し込むだけで、あとからの見落としを減らせます。
          </p>
          <a class="lp1-main-cta" href="https://px.a8.net/svt/ejp?a8mat=4B1XE4+325A0A+1LOO+5Z6WY" data-affiliate="oken" data-track="lp1_final_oken" rel="nofollow sponsored">オーケンウォーターの公式条件を見る</a>
        </section>
      </div>
    </div>
  </main>

  <footer class="lp1-disclosure">
    <p>
      掲載情報は公式サイト等の公開情報をもとに作成していますが、料金・キャンペーン・契約条件は変更される場合があります。
      申し込み前に必ず各社公式サイトで最新情報をご確認ください。
      当ページは広告・アフィリエイトリンクを含み、リンク経由で申し込みが発生した場合に報酬を受け取ることがあります。
    </p>
    <p><a href="/water-server/operator/">運営者情報</a> / <a href="/water-server/">通常版比較ページ</a></p>
  </footer>

  <script src="/water-server/app.js?v=20260513-lp1" defer></script>
</body>
</html>
