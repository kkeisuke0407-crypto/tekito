      border: 4px solid rgba(255,255,255,.95);
      border-radius: 18px;
      box-shadow: var(--lp-shadow);
      padding: 2rem;
      position: relative;
      animation: lpPop .55s ease-out both;
    }
    .lp1-edition {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      background: var(--lp-pink);
      color: #fff;
      font-weight: 900;
      border-radius: 999px;
      padding: .45rem 1.2rem;
