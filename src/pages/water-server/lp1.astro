      --lp-line: #cceff3;
      --lp-ink: #16333d;
      --lp-muted: #5e7280;
      --lp-bg: #effcff;
      --lp-shadow: 0 18px 50px rgba(5, 96, 116, .16);
    }

    body {
      margin: 0;
      font-family: "Noto Sans JP", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
