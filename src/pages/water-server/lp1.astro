        url("/water-server/images/hero-water-server-photo.png") right center / cover no-repeat;
      border-bottom: 1px solid var(--lp-line);
    }
    .lp1-hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 18px;
      background: repeating-linear-gradient(90deg, rgba(16,174,185,.45) 0 2px, transparent 2px 7px);
      opacity: .55;
    }
    .lp1-hero-inner {
      width: min(1120px, calc(100% - 28px));
      margin: 0 auto;
      min-height: 470px;
      display: grid;
      align-items: center;
      padding: 3.2rem 0 4.25rem;
    }
    .lp1-hero-card {
      width: min(560px, 100%);
