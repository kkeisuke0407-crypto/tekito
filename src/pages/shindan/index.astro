<script is:inline>
  // ステージ管理
  const stages = ['start', 'q1', 'q2', 'q3', 'q4', 'q5', 'result'];
  let answers = {};

  function showStage(name) {
    document.querySelectorAll('.stage').forEach(s => s.classList.remove('active'));
    const target = document.getElementById('stage-' + name);
    if (target) {
      target.classList.add('active');
      window.scrollTo(0, 0);
      // GAイベント送信
      if (window.gtag) {
        gtag('event', 'shindan_step', { step: name });
      }
    }
  }

  document.getElementById('btn-start').addEventListener('click', () => {
    showStage('q1');
  });

  // 質問の回答ハンドラ
  document.querySelectorAll('.q-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.q;
      const v = btn.dataset.v;
      answers[q] = v;

      // GAイベント
      if (window.gtag) {
        gtag('event', 'shindan_answer', { question: q, value: v });
      }

      // 次のステージへ
      const currentStage = btn.closest('.stage').id.replace('stage-', '');
      const idx = stages.indexOf(currentStage);
      const nextStage = stages[idx + 1];

      if (nextStage === 'result') {
        const result = calcResult(answers);
        showResult(result);
      } else {
        showStage(nextStage);
      }
    });
  });

  // 戻るボタン
  document.querySelectorAll('.q-back-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      showStage(btn.dataset.back);
    });
  });

  // 診断ロジック
  function calcResult(a) {
    // 1. 「払えない」or「取り立て既にある」→ 債務整理
    if (a.payment === 'ng' || a.trouble === 'yes') return 'law';

    // 2. 借金200万以上 + 払えない/ギリギリ → 債務整理寄り
    if (a.amount === 'high' && a.payment === 'tight' && a.count === 'many') return 'law';

    // 3. 複数社（2社以上）+ ギリギリ → おまとめローン
    if ((a.count === 'few' || a.count === 'many') && a.payment === 'tight') return 'omatome';

    // 4. 1社・余裕あり → キャッシング（一時的）
    if (a.count === 'one' && a.payment === 'ok') return 'cash';

    // 5. 1社・ギリギリ → おまとめより前にまず一時的に乗り切る or 整理
    if (a.count === 'one' && a.payment === 'tight') return 'cash';

    // 6. 残りのケース → おまとめローン（中庸）
    return 'omatome';
  }

  // 結果表示
  function showResult(type) {
    document.querySelectorAll('.result-variant').forEach(el => el.style.display = 'none');
    const el = document.getElementById('result-' + type);
    if (el) el.style.display = 'block';

    if (window.gtag) {
      gtag('event', 'shindan_result', { result: type });
    }

    showStage('result');
  }

  // 結果のCTAクリック計測
  document.querySelectorAll('[data-cta]').forEach(el => {
    el.addEventListener('click', () => {
      if (window.gtag) {
        gtag('event', 'shindan_cta_click', { cta: el.dataset.cta });
      }
    });
  });

  // やり直しボタン
  document.getElementById('btn-restart').addEventListener('click', () => {
    answers = {};
    showStage('start');
  });
</script>
