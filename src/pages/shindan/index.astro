        <span class="q-option-text">1社のみ</span>
        <span class="q-option-arrow">›</span>
      </button>
      <button class="q-option" data-q="count" data-v="few">
        <span class="q-option-num">B</span>
        <span class="q-option-text">2〜3社</span>
        <span class="q-option-arrow">›</span>
      </button>
      <button class="q-option" data-q="count" data-v="many">
