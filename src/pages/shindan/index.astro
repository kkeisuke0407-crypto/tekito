---
const title = "60秒であなたに合った解決法がわかる｜借金診断";
const description = "個人情報入力ナシ・60秒・5問だけ。あなたの状況に合った解決策（債務整理・おまとめローン・キャッシング）を診断します。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:    #FAF7F2;
      --cream2:   #F3EDE4;
      --brown:    #B88A5A;
      --brown-d:  #8C6030;
      --brown-l:  #F0E6D8;
      --green:    #3D9970;
      --green-d:  #2E7A57;
      --green-l:  #E8F5EF;
      --coral:    #D9524A;
      --coral-d:  #B33D36;
      --coral-l:  #FDE9E7;
      --text:     #2B2B2B;
      --text-mid: #4A4540;
      --text-sub: #6F6A64;
      --text-lt:  #9E9890;
      --white:    #FFFFFF;
      --border:   #E8E0D4;
      --radius:   16px;
      --radius-lg:24px;
      --shadow:   0 4px 20px rgba(100,70,30,0.08);
      --shadow-lg:0 12px 40px rgba(100,70,30,0.16);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--cream);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      min-height: 100vh;
      min-height: 100svh;
    }

    a { text-decoration: none; }

    /* ステージ切替 */
    .stage { display: none; min-height: 100vh; min-height: 100svh; }
    .stage.active { display: flex; flex-direction: column; }

    .wrap {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 20px;
      width: 100%;
    }

    /* ===== STAGE: START ===== */
    .start-stage {
      background: linear-gradient(180deg, var(--cream) 0%, var(--cream2) 100%);
      align-items: center;
      justify-content: center;
      padding: 40px 0;
      text-align: center;
    }

    .start-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 11px;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 100px;
      letter-spacing: 0.06em;
      margin-bottom: 20px;
    }

    .start-title {
      font-size: clamp(28px, 7.5vw, 38px);
      font-weight: 900;
      line-height: 1.4;
      color: var(--text);
      margin-bottom: 16px;
    }

    .start-title .accent {
      color: var(--brown-d);
      position: relative;
    }

    .start-title .accent::after {
      content: '';
      position: absolute;
      left: 0; right: 0;
      bottom: 2px;
      height: 8px;
      background: rgba(184,138,90,0.2);
      z-index: -1;
    }

    .start-sub {
      font-size: 14px;
      color: var(--text-sub);
      line-height: 1.9;
      margin-bottom: 28px;
    }

    .start-features {
      display: flex;
      gap: 0;
      margin: 0 auto 32px;
      max-width: 360px;
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .start-feat {
      flex: 1;
      padding: 14px 4px;
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .start-feat:last-child { border-right: none; }

    .start-feat-ic { font-size: 18px; margin-bottom: 4px; }
    .start-feat-tx { font-size: 11px; font-weight: 700; color: var(--text-mid); }

    .start-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--brown), var(--brown-d));
      color: var(--white);
      font-size: 17px;
      font-weight: 900;
      padding: 20px 40px;
      border: none;
      border-radius: 100px;
      box-shadow: 0 8px 24px rgba(184,138,90,0.4);
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: transform 0.18s;
      font-family: inherit;
    }

    .start-btn:active { transform: scale(0.97); }

    .start-arrow {
      animation: arrow-slide 1.4s ease-in-out infinite;
    }

    @keyframes arrow-slide {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(4px); }
    }

    .start-note {
      font-size: 11px;
      color: var(--text-lt);
      margin-top: 14px;
    }

    .start-trust {
      margin-top: 36px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: center;
    }

    .start-trust-item {
      font-size: 12px;
      color: var(--text-sub);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .start-trust-item::before {
      content: '✓';
      color: var(--green);
      font-weight: 900;
    }

    /* ===== STAGE: QUESTION ===== */
    .q-stage {
      background: var(--cream);
      padding: 24px 0 40px;
    }

    /* プログレスバー */
    .progress-wrap {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .progress-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .progress-step {
      font-size: 11px;
      font-weight: 700;
      color: var(--brown-d);
      letter-spacing: 0.06em;
    }

    .progress-pct {
      font-size: 11px;
      color: var(--text-sub);
      font-weight: 600;
    }

    .progress-bar {
      width: 100%;
      height: 6px;
      background: var(--cream2);
      border-radius: 100px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--brown), var(--brown-d));
      border-radius: 100px;
      transition: width 0.4s ease;
    }

    .q-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 24px 20px 32px;
    }

    .q-title {
      font-size: clamp(22px, 6vw, 28px);
      font-weight: 900;
      line-height: 1.5;
      color: var(--text);
      margin-bottom: 10px;
      text-align: center;
    }

    .q-sub {
      font-size: 13px;
      color: var(--text-sub);
      text-align: center;
      margin-bottom: 32px;
      line-height: 1.7;
    }

    .q-options {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 420px;
      margin: 0 auto;
      width: 100%;
    }

    .q-option {
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      text-align: left;
      cursor: pointer;
      font-family: inherit;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }

    .q-option:hover,
    .q-option:active {
      border-color: var(--brown);
      background: var(--brown-l);
      transform: translateY(-1px);
    }

    .q-option-num {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 13px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .q-option:hover .q-option-num,
    .q-option:active .q-option-num {
      background: var(--brown);
      color: var(--white);
    }

    .q-option-text {
      flex: 1;
      line-height: 1.4;
    }

    .q-option-arrow {
      color: var(--text-lt);
      font-size: 18px;
      flex-shrink: 0;
    }

    .q-option:hover .q-option-arrow,
    .q-option:active .q-option-arrow {
      color: var(--brown-d);
    }

    .q-back {
      margin-top: 28px;
      text-align: center;
    }

    .q-back-btn {
      background: none;
      border: none;
      color: var(--text-lt);
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      padding: 8px 16px;
    }

    .q-back-btn:hover { color: var(--text-sub); }

    /* ===== STAGE: RESULT ===== */
    .result-stage { padding: 32px 0 60px; }

    .result-banner {
      text-align: center;
      padding: 0 20px 24px;
    }

    .result-anim {
      display: inline-block;
      font-size: 36px;
      animation: pop 0.6s ease-out;
      margin-bottom: 8px;
    }

    @keyframes pop {
      0%   { transform: scale(0); opacity: 0; }
      60%  { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }

    .result-eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: var(--brown-d);
      letter-spacing: 0.16em;
      margin-bottom: 6px;
    }

    .result-headline {
      font-size: clamp(20px, 5.5vw, 26px);
      font-weight: 900;
      color: var(--text);
      line-height: 1.5;
      margin-bottom: 4px;
    }

    .result-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      margin: 0 20px;
      animation: slide-up 0.5s ease-out 0.2s both;
    }

    @keyframes slide-up {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .result-hero {
      padding: 32px 24px 24px;
      text-align: center;
      color: var(--white);
    }

    .result-hero--law     { background: linear-gradient(135deg, var(--brown-d) 0%, var(--brown) 100%); }
    .result-hero--omatome { background: linear-gradient(135deg, var(--green-d) 0%, var(--green) 100%); }
    .result-hero--cash    { background: linear-gradient(135deg, var(--coral-d) 0%, var(--coral) 100%); }

    .result-tag {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(8px);
      color: var(--white);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 100px;
      letter-spacing: 0.06em;
      margin-bottom: 14px;
    }

    .result-icon {
      font-size: 44px;
      margin-bottom: 8px;
    }

    .result-title {
      font-size: 22px;
      font-weight: 900;
      margin-bottom: 8px;
      line-height: 1.4;
    }

    .result-tagline {
      font-size: 13px;
      opacity: 0.92;
      line-height: 1.7;
    }

    .result-body { padding: 24px 22px 28px; }

    .result-section-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-sub);
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }

    .result-points {
      display: flex;
      flex-direction: column;
      gap: 9px;
      margin-bottom: 24px;
    }

    .result-point {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 14px;
      color: var(--text-mid);
      line-height: 1.7;
    }

    .result-point-ic {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 11px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .result-hero--omatome ~ .result-body .result-point-ic { background: var(--green-l); color: var(--green-d); }
    .result-hero--cash    ~ .result-body .result-point-ic { background: var(--coral-l); color: var(--coral-d); }

    .result-service-name {
      background: var(--cream);
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .result-service-logo {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }

    .result-service-info { flex: 1; }
    .result-service-tag-mini {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-sub);
      letter-spacing: 0.08em;
      margin-bottom: 1px;
    }
    .result-service-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
    }

    .result-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 16px;
      font-weight: 900;
      color: var(--white);
      padding: 18px 24px;
      border-radius: 100px;
      letter-spacing: 0.02em;
      transition: transform 0.18s;
      box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }

    .result-cta:active { transform: scale(0.97); }

    .result-cta--law     { background: linear-gradient(135deg, var(--brown-d), var(--brown)); }
    .result-cta--omatome { background: linear-gradient(135deg, var(--green-d), var(--green)); }
    .result-cta--cash    { background: linear-gradient(135deg, var(--coral-d), var(--coral)); }

    .result-note {
      font-size: 11px;
      color: var(--text-lt);
      text-align: center;
      margin-top: 14px;
      line-height: 1.7;
    }

    .result-other {
      margin: 32px 20px 0;
      padding-top: 28px;
      border-top: 1px solid var(--border);
    }

    .result-other-title {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-sub);
      text-align: center;
      margin-bottom: 14px;
    }

    .result-other-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .result-other-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--text-mid);
    }

    .result-other-ic {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .result-other-text { flex: 1; }
    .result-other-text strong { display: block; font-weight: 900; color: var(--text); margin-bottom: 1px; }

    .result-other-arrow { color: var(--text-lt); font-size: 16px; }

    .result-restart {
      text-align: center;
      margin-top: 32px;
    }

    .result-restart-btn {
      background: none;
      border: none;
      color: var(--text-lt);
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      padding: 8px 16px;
      text-decoration: underline;
    }

    .result-disclaimer {
      font-size: 10px;
      color: var(--text-lt);
      text-align: center;
      line-height: 1.7;
      padding: 24px 20px 0;
      max-width: 480px;
      margin: 0 auto;
    }

    /* ===== 拡張：強み・実績統計バー ===== */
    .result-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 20px 20px 0;
    }

    .result-stat {
      background: var(--white);
      border-radius: 12px;
      padding: 14px 6px;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .result-stat-num {
      font-size: 18px;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .result-stat-num--law     { color: var(--brown-d); }
    .result-stat-num--omatome { color: var(--green-d); }
    .result-stat-num--cash    { color: var(--coral-d); }

    .result-stat-label {
      font-size: 10px;
      color: var(--text-sub);
      font-weight: 600;
      line-height: 1.4;
    }

    /* ===== 拡張：強みリスト ===== */
    .result-strength {
      margin: 28px 20px 0;
    }

    .result-strength-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      background: var(--white);
      border-radius: 14px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .result-strength-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid var(--border);
    }

    .result-strength-item:last-child { border-bottom: none; }

    .result-strength-num {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      font-size: 12px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--white);
      margin-top: 1px;
    }

    .result-strength-num--law     { background: var(--brown); }
    .result-strength-num--omatome { background: var(--green); }
    .result-strength-num--cash    { background: var(--coral); }

    .result-strength-content { flex: 1; }
    .result-strength-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 4px;
      line-height: 1.45;
    }
    .result-strength-desc {
      font-size: 12.5px;
      color: var(--text-sub);
      line-height: 1.7;
    }

    /* ===== 拡張：差別化ボックス ===== */
    .result-diff-box {
      margin: 28px 20px 0;
      background: linear-gradient(135deg, var(--cream2), var(--cream));
      border: 1.5px solid var(--brown-l);
      border-radius: 14px;
      padding: 20px;
    }

    .result-diff-box--omatome { border-color: #B8E3CB; background: linear-gradient(135deg, var(--green-l), #F4FBF7); }
    .result-diff-box--cash    { border-color: #F5C7C3; background: linear-gradient(135deg, var(--coral-l), #FEF3F2); }

    .result-diff-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--brown-d);
      margin-bottom: 6px;
    }
    .result-diff-box--omatome .result-diff-eyebrow { color: var(--green-d); }
    .result-diff-box--cash    .result-diff-eyebrow { color: var(--coral-d); }

    .result-diff-title {
      font-size: 15px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 10px;
      line-height: 1.5;
    }

    .result-diff-desc {
      font-size: 13px;
      color: var(--text-mid);
      line-height: 1.85;
    }

    /* ===== 拡張：料金・条件テーブル ===== */
    .result-spec {
      margin: 28px 20px 0;
      background: var(--white);
      border-radius: 14px;
      box-shadow: var(--shadow);
      padding: 18px 20px;
    }

    .result-spec-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-sub);
      letter-spacing: 0.1em;
      margin-bottom: 12px;
    }

    .result-spec-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }

    .result-spec-row:last-child { border-bottom: none; }
    .result-spec-key { color: var(--text-sub); }
    .result-spec-val { font-weight: 900; color: var(--text); }
    .result-spec-val--law     { color: var(--brown-d); }
    .result-spec-val--omatome { color: var(--green-d); }
    .result-spec-val--cash    { color: var(--coral-d); }

    /* ===== 拡張：FAQアコーディオン ===== */
    .result-faq {
      margin: 28px 20px 0;
    }

    .result-faq-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 12px;
      text-align: center;
    }

    .result-faq-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .r-faq-item {
      background: var(--white);
      border-radius: 10px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .r-faq-q {
      width: 100%;
      background: none;
      border: none;
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
    }

    .r-faq-qi {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 11px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .result-hero--omatome ~ .result-body .r-faq-qi,
    [data-result="omatome"] .r-faq-qi { background: var(--green-l); color: var(--green-d); }

    .r-faq-qt {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.5;
      flex: 1;
      padding-top: 1px;
    }

    .r-faq-ch {
      width: 12px;
      height: 12px;
      border-right: 2px solid var(--text-lt);
      border-bottom: 2px solid var(--text-lt);
      transform: rotate(45deg);
      flex-shrink: 0;
      margin-top: 5px;
      transition: transform 0.25s;
    }

    .r-faq-item.open .r-faq-ch { transform: rotate(-135deg); margin-top: 9px; }

    .r-faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .r-faq-item.open .r-faq-a { max-height: 400px; }

    .r-faq-ai {
      padding: 0 16px 14px 48px;
      font-size: 12.5px;
      color: var(--text-mid);
      line-height: 1.85;
    }

    /* ===== 拡張：使い方ステップ ===== */
    .result-steps {
      margin: 28px 20px 0;
    }

    .result-steps-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 14px;
      text-align: center;
    }

    .step-grid {
      display: flex;
      flex-direction: column;
      gap: 8px;
      position: relative;
    }

    .step-grid::before {
      content: '';
      position: absolute;
      left: 18px;
      top: 22px;
      bottom: 22px;
      width: 2px;
      background: var(--border);
    }

    .step-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 4px 0;
    }

    .step-item-num {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      color: var(--white);
      font-size: 14px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
      box-shadow: var(--shadow);
    }

    .step-item-num--law     { background: var(--brown); }
    .step-item-num--omatome { background: var(--green); }
    .step-item-num--cash    { background: var(--coral); }

    .step-item-content {
      flex: 1;
      padding-top: 6px;
    }

    .step-item-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 3px;
    }

    .step-item-desc {
      font-size: 12px;
      color: var(--text-sub);
      line-height: 1.7;
    }

    /* ===== 拡張：最後の一押し ===== */
    .result-push {
      margin: 32px 20px 0;
      padding: 24px 22px;
      border-radius: 16px;
      text-align: center;
      color: var(--white);
    }

    .result-push--law     { background: linear-gradient(135deg, var(--brown-d), var(--brown)); }
    .result-push--omatome { background: linear-gradient(135deg, var(--green-d), var(--green)); }
    .result-push--cash    { background: linear-gradient(135deg, var(--coral-d), var(--coral)); }

    .result-push-icon {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .result-push-title {
      font-size: 16px;
      font-weight: 900;
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .result-push-desc {
      font-size: 12px;
      line-height: 1.85;
      opacity: 0.92;
      margin-bottom: 18px;
    }

    .result-push .result-cta {
      max-width: 320px;
      margin: 0 auto;
      background: var(--white);
      box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    }

    .result-push--law     .result-cta { color: var(--brown-d); }
    .result-push--omatome .result-cta { color: var(--green-d); }
    .result-push--cash    .result-cta { color: var(--coral-d); }

    .result-push-note {
      font-size: 10px;
      opacity: 0.7;
      margin-top: 10px;
    }

    /* セクション見出し（共通装飾） */
    .r-section-head {
      text-align: center;
      margin: 0 20px 14px;
    }

    .r-section-head-eb {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      color: var(--text-sub);
      padding: 4px 12px;
      background: var(--white);
      border-radius: 100px;
      box-shadow: var(--shadow);
      margin-bottom: 10px;
    }

    .r-section-head-tt {
      font-size: 17px;
      font-weight: 900;
      color: var(--text);
      line-height: 1.5;
    }
  </style>
</head>
<body>

<!-- ===== STAGE: START ===== -->
<section class="stage start-stage active" id="stage-start">
