        <span class="q-option-text">4社以上</span>
        <span class="q-option-arrow">›</span>
      </button>
    </div>
    <div class="q-back"><button class="q-back-btn" data-back="q1">← 戻る</button></div>
  </div>
</section>

<!-- ===== STAGE: Q3 毎月の返済状況 ===== -->
<section class="stage q-stage" id="stage-q3">
