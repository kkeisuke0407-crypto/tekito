<script is:inline>
  let answers = {};

  function showStage(name) {
    document.querySelectorAll('.stage').forEach(s => s.classList.remove('active'));
    const target = document.getElementById('stage-' + name);
    if (target) { target.classList.add('active'); window.scrollTo({ top: 0, behavior: 'instant' }); }
  }

  function decideResult(a) {
    if (a.payment === 'ng' || a.trouble === 'yes' || (a.amount === 'high' && a.payment === 'tight')) return 'law';
    if (a.count === 'many' || (a.count === 'few' && a.payment === 'tight')) return 'omatome';
    if (a.amount === 'low' && a.payment === 'ok' && a.count !== 'many') return 'cash';
    if (a.payment === 'tight' && a.amount !== 'low') return 'omatome';
    return 'cash';
  }

  document.getElementById('btn-start').addEventListener('click', () => {
    answers = {};
    showStage('q0');
    if (window.gtag) gtag('event', 'shindan_start');
  });

  document.querySelectorAll('.q-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.q;
      const v = btn.dataset.v;
      answers[q] = v;
      if (q === 'type') {
        if (v === 'business') {
          if (window.gtag) gtag('event', 'shindan_result', { result: 'factor' });
          showStage('result-factor');
        } else {
          showStage('q1');
        }
        return;
      }
      const stageMap = { amount: 'q2', count: 'q3', payment: 'q4', years: 'q5' };
      if (stageMap[q]) {
        showStage(stageMap[q]);
      } else {
        const result = decideResult(answers);
        if (window.gtag) gtag('event', 'shindan_result', { result });
        showStage('result-' + result);
      }
    });
  });

  document.querySelectorAll('[data-back]').forEach(btn => {
    btn.addEventListener('click', () => { showStage(btn.dataset.back); });
  });

  document.querySelectorAll('[data-cta]').forEach(el => {
    el.addEventListener('click', () => {
      if (window.gtag) gtag('event', 'shindan_cta_click', { cta: el.dataset.cta });
    });
  });

  document.querySelectorAll('[data-restart]').forEach(btn => {
    btn.addEventListener('click', () => { answers = {}; showStage('start'); });
  });

  document.querySelectorAll('[data-faq]').forEach(btn => {
    btn.addEventListener('click', () => { btn.closest('.r-faq-item').classList.toggle('open'); });
  });
</script>
