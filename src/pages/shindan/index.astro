---
const title = "60秒であなたに合った解決法がわかる｜借金診断";
const description = "個人情報入力ナシ・60秒・5問だけ。あなたの状況に合った解決策を診断します。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
  </script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18129603657"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@500;700;900&family=Inter+Tight:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #F7F5F0;
      --bg-elev:  #FFFFFF;
      --bg-soft:  #EFEAE0;
      --ink:      #14110E;
      --ink-2:    #3A352E;
      --ink-3:    #6B655B;
      --ink-4:    #9C968B;
      --line:     #E5DFD2;
      --line-2:   #D8D1C2;
      --teal:     #1F4E45;
      --teal-2:   #2C6E61;
      --teal-soft:#E6EFEA;
      --olive:    #5B6B2C;
      --olive-2:  #7A8C40;
      --olive-soft:#EDEFDF;
      --terra:    #B85838;
      --terra-2:  #D26C48;
      --terra-soft:#F6E6DD;
      --gold:     #B87A20;
      --gold-2:   #D49A35;
      --gold-soft:#FDF3DC;
      --accent:   var(--teal);
      --accent-2: var(--teal-2);
      --accent-soft: var(--teal-soft);
      --radius:   18px;
      --radius-sm:12px;
      --radius-lg:28px;
      --serif: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", serif;
      --sans:  "Inter Tight", "Noto Sans JP", system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      min-height: 100svh;
      font-feature-settings: "palt";
    }
    a { text-decoration: none; color: inherit; }
    button { font-family: inherit; }

    .app {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      position: relative;
    }
    @media (min-width: 720px) {
      body {
        background:
          radial-gradient(circle at 20% 10%, #EFEAE0 0%, transparent 40%),
          radial-gradient(circle at 80% 90%, #EFEAE0 0%, transparent 40%),
          var(--bg);
        padding: 32px 0;
      }
      .app {
        max-width: 440px;
        margin: 0 auto;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(20,17,14,0.08), 0 4px 16px rgba(20,17,14,0.04);
        min-height: calc(100svh - 64px);
      }
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 22px;
      border-bottom: 1px solid var(--line);
      background: var(--bg);
      position: sticky; top: 0; z-index: 30;
    }
    .topbar-brand {
      display: flex; align-items: center; gap: 8px;
      font-family: var(--serif);
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.02em;
    }
    .topbar-brand-mark {
      width: 22px; height: 22px;
      border-radius: 6px;
      background: var(--ink);
      color: var(--bg);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 800; font-family: var(--sans);
    }
    .topbar-meta {
      font-family: var(--sans);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--ink-3);
      text-transform: uppercase;
    }

    .stage { display: none; flex: 1; flex-direction: column; }
    .stage.active { display: flex; }
    .stage:not(.active) { display: none !important; }
    .start { padding: 32px 24px 40px; }
    .start.active { flex-direction: column; }
    .start-eyebrow {
      display: inline-flex;
      align-items: center; gap: 8px;
      font-size: 10px; font-weight: 600;
      letter-spacing: 0.2em;
      color: var(--ink-2);
      text-transform: uppercase;
      margin-bottom: 28px;
    }
    .start-eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--ink-2); }
    .start-title {
      font-family: var(--serif);
      font-weight: 700;
      font-size: clamp(34px, 9vw, 44px);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin-bottom: 22px;
    }
    .start-title em {
      font-style: normal;
      background: linear-gradient(transparent 64%, var(--accent-soft) 64%);
      padding: 0 2px;
    }
    .start-title .num { font-family: var(--sans); font-weight: 500; font-style: italic; }
    .start-lede { font-size: 14px; line-height: 2; color: var(--ink-2); margin-bottom: 32px; max-width: 380px; }
    .start-meta-row {
      display: grid; grid-template-columns: repeat(3, 1fr);
      margin-bottom: 36px;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .start-meta-cell { padding: 16px 8px; text-align: center; border-right: 1px solid var(--line); }
    .start-meta-cell:last-child { border-right: none; }
    .start-meta-num { font-family: var(--serif); font-weight: 700; font-size: 22px; color: var(--ink); line-height: 1; margin-bottom: 6px; }
    .start-meta-num small { font-family: var(--sans); font-weight: 500; font-size: 11px; margin-left: 2px; color: var(--ink-3); }
    .start-meta-label { font-size: 10px; letter-spacing: 0.12em; color: var(--ink-3); text-transform: uppercase; }
    .start-cta {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%;
      background: var(--ink); color: var(--bg);
      padding: 22px 26px; border: none; border-radius: 999px;
      font-size: 16px; font-weight: 700; cursor: pointer;
      transition: transform .25s cubic-bezier(.2,.7,.2,1), background .2s;
      margin-bottom: 14px;
    }
    .start-cta:hover { transform: translateY(-2px); background: var(--ink-2); }
    .start-cta:active { transform: scale(0.98); }
    .start-cta-arrow {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--bg); color: var(--ink);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--sans); font-weight: 600; font-size: 16px;
      transition: transform .3s;
    }
    .start-cta:hover .start-cta-arrow { transform: translateX(4px); }
    .start-cta-note { text-align: center; font-size: 11px; color: var(--ink-3); margin-bottom: 36px; }
    .start-options { margin-top: 8px; border-top: 1px solid var(--line); padding-top: 28px; }
    .start-options-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 16px; }
    .start-option-row { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--line); }
    .start-option-row:last-child { border-bottom: none; }
    .start-option-num { font-family: var(--serif); font-style: italic; font-size: 12px; color: var(--ink-3); width: 24px; flex-shrink: 0; padding-top: 2px; }
    .start-option-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 8px; flex-shrink: 0; }
    .start-option-dot.d1 { background: var(--teal); }
    .start-option-dot.d2 { background: var(--olive); }
    .start-option-dot.d3 { background: var(--terra); }
    .start-option-dot.d4 { background: var(--gold); }
    .start-option-text { flex: 1; }
    .start-option-title { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 2px; }
    .start-option-desc { font-size: 11px; color: var(--ink-3); line-height: 1.6; }
    .start-trust { margin-top: 32px; padding: 20px; background: var(--bg-soft); border-radius: var(--radius); display: flex; flex-direction: column; gap: 8px; }
    .start-trust-item { font-size: 12px; color: var(--ink-2); display: flex; align-items: center; gap: 10px; line-height: 1.6; }
    .start-trust-item::before { content: ''; width: 14px; height: 1px; background: var(--ink-2); flex-shrink: 0; }
    .q-stage { padding: 0; }
    .q-progress { padding: 24px 24px 0; display: flex; flex-direction: column; gap: 10px; }
    .q-progress-row { display: flex; justify-content: space-between; align-items: baseline; }
    .q-progress-step { font-family: var(--serif); font-weight: 700; font-size: 13px; color: var(--ink); letter-spacing: 0.02em; }
    .q-progress-step .total { color: var(--ink-4); font-weight: 500; }
    .q-progress-pct { font-family: var(--sans); font-size: 10px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; }
    .q-progress-bar { height: 2px; background: var(--line); position: relative; overflow: hidden; }
    .q-progress-fill { position: absolute; inset: 0 auto 0 0; background: var(--ink); transition: width .5s cubic-bezier(.2,.7,.2,1); }
    .q-content { flex: 1; padding: 40px 24px 28px; display: flex; flex-direction: column; animation: q-in .35s cubic-bezier(.2,.7,.2,1); }
    @keyframes q-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .q-num { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--ink-3); margin-bottom: 12px; }
    .q-title { font-family: var(--serif); font-weight: 700; font-size: clamp(24px, 6.5vw, 30px); line-height: 1.45; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 12px; }
    .q-sub { font-size: 12px; color: var(--ink-3); line-height: 1.7; margin-bottom: 32px; }
    .q-options { display: flex; flex-direction: column; gap: 10px; }
    .q-option {
      background: var(--bg-elev); border: 1px solid var(--line);
      border-radius: var(--radius); padding: 18px 20px;
      text-align: left; cursor: pointer;
      display: flex; align-items: center; gap: 16px;
      transition: all .2s; position: relative;
    }
    .q-option::after {
      content: ''; position: absolute; inset: 0;
      border-radius: var(--radius); pointer-events: none;
      box-shadow: 0 0 0 0 var(--ink); transition: box-shadow .2s;
    }
    .q-option:hover { border-color: var(--ink); transform: translateY(-1px); }
    .q-option:hover::after { box-shadow: 0 8px 24px rgba(20,17,14,0.08); }
    .q-option-key { font-family: var(--serif); font-weight: 700; font-size: 13px; color: var(--ink-3); width: 22px; flex-shrink: 0; }
    .q-option:hover .q-option-key { color: var(--ink); }
    .q-option-text { flex: 1; font-size: 15px; font-weight: 600; color: var(--ink); line-height: 1.4; }
    .q-option-arrow {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--bg); border: 1px solid var(--line);
      display: flex; align-items: center; justify-content: center;
      color: var(--ink-3); font-size: 14px;
      transition: all .2s; flex-shrink: 0;
    }
    .q-option:hover .q-option-arrow { background: var(--ink); border-color: var(--ink); color: var(--bg); transform: translateX(2px); }
    .q-back { margin-top: 28px; text-align: left; }
    .q-back-btn { background: none; border: none; color: var(--ink-3); font-size: 12px; cursor: pointer; padding: 8px 0; display: inline-flex; align-items: center; gap: 6px; }
    .q-back-btn:hover { color: var(--ink); }
    .r-stage { padding: 0 0 60px; }
    .r-stage[data-tone="law"]     { --accent: var(--teal);  --accent-2: var(--teal-2);  --accent-soft: var(--teal-soft); }
    .r-stage[data-tone="omatome"] { --accent: var(--olive); --accent-2: var(--olive-2); --accent-soft: var(--olive-soft); }
    .r-stage[data-tone="cash"]    { --accent: var(--terra); --accent-2: var(--terra-2); --accent-soft: var(--terra-soft); }
    .r-stage[data-tone="factor"]  { --accent: var(--gold);  --accent-2: var(--gold-2);  --accent-soft: var(--gold-soft); }
    .r-banner { padding: 32px 24px 28px; border-bottom: 1px solid var(--line); animation: q-in .5s ease-out; }
    .r-banner-eb { font-size: 10px; letter-spacing: 0.2em; color: var(--ink-3); text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 16px; }
    .r-banner-eb::before { content: ''; width: 24px; height: 1px; background: var(--accent); }
    .r-banner-headline { font-family: var(--serif); font-weight: 700; font-size: clamp(26px, 7vw, 32px); line-height: 1.4; color: var(--ink); margin-bottom: 4px; }
    .r-banner-headline em { font-style: normal; color: var(--accent); }
    .r-hero { margin: 28px 20px 0; background: var(--bg-elev); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--line); animation: q-in .6s ease-out .1s both; }
    .r-hero-top { padding: 32px 24px 28px; background: var(--accent); color: var(--bg-elev); position: relative; overflow: hidden; }
    .r-hero-top::before { content: ''; position: absolute; right: -60px; top: -60px; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.08); }
    .r-hero-tag { display: inline-flex; align-items: center; gap: 8px; font-size: 10px; letter-spacing: 0.2em; color: rgba(255,255,255,0.85); text-transform: uppercase; margin-bottom: 14px; position: relative; }
    .r-hero-tag::before { content: ''; width: 18px; height: 1px; background: rgba(255,255,255,0.7); }
    .r-hero-title { font-family: var(--serif); font-weight: 700; font-size: 24px; line-height: 1.45; letter-spacing: -0.005em; margin-bottom: 14px; position: relative; }
    .r-hero-tagline { font-size: 13px; line-height: 1.85; color: rgba(255,255,255,0.92); position: relative; }
    .r-hero-body { padding: 26px 24px; }
    .r-hero-body-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 14px; }
    .r-points { display: flex; flex-direction: column; }
    .r-point { display: flex; gap: 14px; padding: 12px 0; border-bottom: 1px solid var(--line); align-items: flex-start; }
    .r-point:last-child { border-bottom: none; padding-bottom: 0; }
    .r-point:first-child { padding-top: 0; }
    .r-point-num { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--accent); width: 22px; flex-shrink: 0; padding-top: 1px; }
    .r-point-text { flex: 1; font-size: 13px; color: var(--ink-2); line-height: 1.85; }
    .r-section { margin: 40px 24px 0; }
    .r-section-eb { font-size: 10px; letter-spacing: 0.22em; color: var(--accent); text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 12px; font-weight: 600; }
    .r-section-eb::before { content: ''; width: 24px; height: 1px; background: var(--accent); }
    .r-section-title { font-family: var(--serif); font-weight: 700; font-size: 20px; line-height: 1.5; color: var(--ink); margin-bottom: 20px; }
    .r-stats { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; background: var(--bg-elev); }
    .r-stat { padding: 20px 8px; text-align: center; border-right: 1px solid var(--line); }
    .r-stat:last-child { border-right: none; }
    .r-stat-num { font-family: var(--serif); font-weight: 700; font-size: 22px; color: var(--accent); line-height: 1; margin-bottom: 6px; }
    .r-stat-num small { font-family: var(--sans); font-weight: 500; font-size: 11px; color: var(--ink-3); margin-left: 1px; }
    .r-stat-label { font-size: 10px; letter-spacing: 0.1em; color: var(--ink-3); text-transform: uppercase; }
    .r-strength { background: var(--bg-elev); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .r-strength-item { display: flex; align-items: flex-start; gap: 16px; padding: 18px 20px; border-bottom: 1px solid var(--line); }
    .r-strength-item:last-child { border-bottom: none; }
    .r-strength-num { font-family: var(--serif); font-weight: 700; font-style: italic; font-size: 14px; color: var(--accent); width: 24px; flex-shrink: 0; padding-top: 2px; }
    .r-strength-content { flex: 1; }
    .r-strength-title { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 5px; line-height: 1.5; }
    .r-strength-desc { font-size: 12px; color: var(--ink-3); line-height: 1.85; }
    .r-diff { padding: 24px; background: var(--accent-soft); border-radius: var(--radius); }
    .r-diff-eb { font-size: 10px; letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase; margin-bottom: 12px; font-weight: 600; }
    .r-diff-title { font-family: var(--serif); font-weight: 700; font-size: 17px; line-height: 1.55; color: var(--ink); margin-bottom: 12px; }
    .r-diff-desc { font-size: 13px; color: var(--ink-2); line-height: 1.95; }
    .r-spec { background: var(--bg-elev); border: 1px solid var(--line); border-radius: var(--radius); padding: 18px 22px; }
    .r-spec-row { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0; border-bottom: 1px dashed var(--line); font-size: 13px; gap: 12px; }
    .r-spec-row:last-child { border-bottom: none; }
    .r-spec-row:first-child { padding-top: 4px; }
    .r-spec-key { color: var(--ink-3); font-size: 12px; letter-spacing: 0.04em; }
    .r-spec-val { font-weight: 700; color: var(--ink); font-family: var(--serif); font-size: 14px; text-align: right; }
    .r-steps { display: flex; flex-direction: column; background: var(--bg-elev); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .r-step { display: flex; gap: 18px; padding: 20px 22px; border-bottom: 1px solid var(--line); align-items: flex-start; }
    .r-step:last-child { border-bottom: none; }
    .r-step-num { font-family: var(--serif); font-weight: 700; font-size: 26px; line-height: 1; color: var(--accent); width: 36px; flex-shrink: 0; padding-top: 2px; }
    .r-step-content { flex: 1; }
    .r-step-title { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
    .r-step-desc { font-size: 12px; color: var(--ink-3); line-height: 1.85; }
    .r-faq-list { display: flex; flex-direction: column; border-top: 1px solid var(--line); }
    .r-faq-item { border-bottom: 1px solid var(--line); }
    .r-faq-q { width: 100%; background: none; border: none; padding: 18px 4px; display: flex; align-items: flex-start; gap: 14px; cursor: pointer; text-align: left; }
    .r-faq-qi { font-family: var(--serif); font-style: italic; font-weight: 700; font-size: 14px; color: var(--accent); width: 20px; flex-shrink: 0; padding-top: 1px; }
    .r-faq-qt { flex: 1; font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.55; }
    .r-faq-ch { width: 24px; height: 24px; border-radius: 50%; border: 1px solid var(--line-2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all .25s; color: var(--ink-3); margin-top: -1px; }
    .r-faq-ch::before { content: '+'; font-family: var(--sans); font-weight: 400; font-size: 16px; line-height: 1; }
    .r-faq-item.open .r-faq-ch { background: var(--ink); border-color: var(--ink); color: var(--bg); transform: rotate(45deg); }
    .r-faq-a { max-height: 0; overflow: hidden; transition: max-height .35s ease; }
    .r-faq-item.open .r-faq-a { max-height: 600px; }
    .r-faq-ai { padding: 0 4px 20px 34px; font-size: 13px; color: var(--ink-2); line-height: 1.95; }
    .r-push { margin: 48px 20px 0; padding: 36px 28px; background: var(--ink); color: var(--bg); border-radius: var(--radius-lg); text-align: left; position: relative; overflow: hidden; }
    .r-push::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 80% 20%, var(--accent) 0%, transparent 60%); opacity: 0.4; }
    .r-push-eb { position: relative; font-size: 10px; letter-spacing: 0.2em; color: rgba(255,255,255,0.6); text-transform: uppercase; margin-bottom: 16px; display: inline-flex; align-items: center; gap: 8px; }
    .r-push-eb::before { content: ''; width: 18px; height: 1px; background: rgba(255,255,255,0.4); }
    .r-push-title { position: relative; font-family: var(--serif); font-weight: 700; font-size: 22px; line-height: 1.5; margin-bottom: 14px; }
    .r-push-desc { position: relative; font-size: 13px; line-height: 1.95; color: rgba(255,255,255,0.78); margin-bottom: 28px; }
    .r-cta { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; background: var(--bg); color: var(--ink); padding: 20px 24px; border-radius: 999px; font-size: 15px; font-weight: 700; transition: transform .2s; }
    .r-cta:hover { transform: translateY(-2px); }
    .r-cta-arrow { width: 30px; height: 30px; border-radius: 50%; background: var(--ink); color: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 14px; transition: transform .3s; }
    .r-cta:hover .r-cta-arrow { transform: translateX(4px); }
    .r-push-note { position: relative; margin-top: 14px; font-size: 11px; color: rgba(255,255,255,0.55); text-align: center; }
    .r-card-cta { margin: 24px 24px 28px; display: flex; align-items: center; justify-content: space-between; gap: 12px; background: var(--accent); color: var(--bg-elev); padding: 18px 22px; border-radius: 999px; font-size: 14px; font-weight: 700; transition: transform .2s; }
    .r-card-cta:hover { transform: translateY(-2px); }
    .r-card-cta-arrow { width: 26px; height: 26px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 12px; }
    .r-other { margin: 48px 20px 0; }
    .r-other-label { font-size: 10px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 14px; display: inline-flex; align-items: center; gap: 8px; font-weight: 600; }
    .r-other-label::before { content: ''; width: 18px; height: 1px; background: var(--ink-3); }
    .r-other-list { display: flex; flex-direction: column; gap: 10px; }
    .r-other-item { background: var(--bg-elev); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 18px; display: flex; align-items: center; gap: 14px; transition: all .2s; }
    .r-other-item:hover { border-color: var(--ink); transform: translateY(-1px); }
    .r-other-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .r-other-dot.law { background: var(--teal); }
    .r-other-dot.omatome { background: var(--olive); }
    .r-other-dot.cash { background: var(--terra); }
    .r-other-dot.factor { background: var(--gold); }
    .r-other-text { flex: 1; }
    .r-other-title-tx { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 2px; font-family: var(--serif); }
    .r-other-desc-tx { font-size: 11px; color: var(--ink-3); line-height: 1.6; }
    .r-other-arrow { color: var(--ink-3); font-size: 18px; flex-shrink: 0; }
