        <span class="q-option-arrow">›</span>
      </button>
      <button class="q-option" data-q="payment" data-v="tight">
        <span class="q-option-num">B</span>
        <span class="q-option-text">ギリギリ返せている</span>
        <span class="q-option-arrow">›</span>
