---
import Base from '@/layouts/Base.astro';
import AffDisclosure from '@/components/AffDisclosure.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={post.data.title} description={post.data.title}>
  <p class="muted"><a href="/blog">&larr; All posts</a></p>
  <p class="last-updated">Published: {post.data.published}{post.data.model ? ` - drafted by ${post.data.model}` : ''}</p>
  <article>
    <Content />
  </article>
  <AffDisclosure />
</Base>
