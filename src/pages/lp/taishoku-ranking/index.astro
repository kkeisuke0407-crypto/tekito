---
const PAGE_TITLE  = "退職代行サービス比較ランキング【2025年最新】LINEで即日退職できる4選";
const PAGE_DESC   = "退職代行サービスを料金・対応速度・保証内容で比較。LINE1本で即日退職できるおすすめ4社をランキング形式で紹介。在職中の無料相談も可能。";
const CANONICAL   = "https://vpscomparehub.com/lp/taishoku-ranking/";
const OGP_IMAGE   = "https://vpscomparehub.com/og-default.svg";
const UPDATED     = "2025年5月";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "退職代行は本当に即日で退職できますか？",
      acceptedAnswer: { "@type": "Answer",
        text: "サービスによりますが、多くの退職代行は申し込み当日に会社へ連絡し、翌日以降の出社不要を実現できます。ただし有休消化や退職金の扱いは会社の規程によるため、公式サイトで事前に確認することをおすすめします。" }
    },
    {
      "@type": "Question",
      name: "退職代行を使うのは「逃げ」ですか？",
      acceptedAnswer: { "@type": "Answer",
        text: "退職は労働者の正当な権利です。引き留めや過度なプレッシャーで自分では言い出せない状況での利用は、精神的な健康を守るための現実的な選択肢の一つです。" }
    },
    {
      "@type": "Question",
      name: "退職代行を使ったことは会社にバレますか？",
      acceptedAnswer: { "@type": "Answer",
        text: "退職代行の利用自体は法律上の問題はありませんが、代行業者が会社に連絡した事実は残ります。その後の職場への影響は会社の対応次第です。" }
    },
    {
      "@type": "Question",
      name: "有給休暇は消化できますか？",
      acceptedAnswer: { "@type": "Answer",
        text: "労働組合が運営するサービス（ガーディアン等）や弁護士法人（みやび等）は交渉権限があるため、有給消化を交渉できる場合があります。一般業者では交渉できないため注意が必要です。公式で確認してください。" }
      },
    {
      "@type": "Question",
      name: "退職代行の料金はいくらですか？",
      acceptedAnswer: { "@type": "Answer",
        text: "一般的に1.5万〜5万円程度のサービスが多いです。EXITは2万円台、モームリは後払い可の業界最安水準などさまざまです。最新の料金は各公式サイトでご確認ください。" }
    },
    {
      "@type": "Question",
      name: "アルバイト・パートでも利用できますか？",
      acceptedAnswer: { "@type": "Answer",
        text: "多くのサービスはアルバイト・パート・派遣・契約社員も対象としています。各サービスの公式ページで対象範囲を確認してください。" }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <meta property="og:type"        content="article" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- フォント -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <!-- スタイル -->
