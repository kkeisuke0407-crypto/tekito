---
const PAGE_TITLE = "K18・プラチナを売る前に無料査定｜金買取査定ナビ";
const PAGE_DESC = "K18、18金ネックレス、プラチナ、金貨を売る前に確認。査定だけでも相談したい方へ、買取価格の見方、手数料、店頭・出張・宅配査定の違いを比較します。";
const CANONICAL = "https://vpscomparehub.com/gold-kaitori/";
const OGP_IMAGE = "https://vpscomparehub.com/gold-kaitori/images/hero-gold-appraisal.png";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "K18やプラチナの買取価格はどう決まりますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "主に品位、重量、当日の相場、状態、付属品、手数料、査定方法によって変わります。掲載内容は参考情報であり、実際の買取価格を保証するものではありません。"
      }
    },
    {
      "@type": "Question",
      "name": "査定だけでも利用できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "多くの買取店では査定だけの相談が可能です。売却前に、査定料、出張料、キャンセル時費用、返送料などを公式サイトで確認してください。"
      }
    },
    {
      "@type": "Question",
      "name": "壊れた指輪や片方だけのピアスも査定できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "金やプラチナとして価値が付く場合があります。刻印が見えにくい品物や古いアクセサリーも、状態だけで判断せず無料査定で確認するのがおすすめです。"
      }
    },
    {
      "@type": "Question",
      "name": "査定後に売らない選択はできますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "売却するかは査定額や条件を確認してから判断します。申込前に、キャンセル時費用や返送料、出張料などを公式サイトで確認してください。"
      }
    },
    {
      "@type": "Question",
      "name": "このページは買取店の公式サイトですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "いいえ。当サイトは買取店の公式サイトではありません。最新条件は各公式サイトでご確認ください。"
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:image" content={OGP_IMAGE} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="金買取査定ナビ" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/gold-kaitori/styles.css?v=20260511-2" />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/gold-kaitori/" class="brand" aria-label="金買取査定ナビ">
        <span class="brand-mark">Au</span>
        <span class="brand-text">金買取査定ナビ</span>
      </a>
      <nav class="nav" aria-label="ページ内ナビゲーション">
        <a href="#compare" data-scroll-to="#compare">比較</a>
        <a href="#price" data-scroll-to="#price">価格の見方</a>
        <a href="#items" data-scroll-to="#items">品目別</a>
        <a href="#check" data-scroll-to="#check">注意点</a>
        <a href="#faq" data-scroll-to="#faq">FAQ</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-bg" aria-hidden="true">
        <img src="/gold-kaitori/images/hero-gold-appraisal.png" alt="" width="1536" height="864" decoding="async" fetchpriority="high" />
      </div>
      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">売るか迷っている段階でも、まずは無料査定へ</p>
          <h1>そのK18・プラチナ、<br />しまったままは損かも。</h1>
          <p class="hero-lead">
            金やプラチナは、品位・重さ・当日の相場・手数料で査定額が変わります。
            「売るかは金額を見てから」で大丈夫。まずは手元の品物がいくらになりそうか、無料査定の条件を確認しましょう。
          </p>
          <div class="hero-actions" aria-label="主要アクション">
            <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="hero_manekiya" rel="nofollow sponsored">売る前に無料査定を相談する</a>
            <a href="#compare" class="btn btn-secondary" data-scroll-to="#compare" data-track="hero_compare">2社を比較する</a>
          </div>
          <ul class="hero-points" aria-label="確認できること">
            <li>売るかは査定後に判断</li>
            <li>手数料・キャンセル条件を確認</li>
            <li>壊れた金製品も相談</li>
            <li>店頭・出張・宅配を選べる</li>
          </ul>
        </div>
        <aside class="hero-panel" aria-label="査定前チェック">
          <span class="panel-label">この中に1つでもあれば相談候補</span>
          <h2>今すぐ査定に出しやすい品物</h2>
          <div class="quick-grid">
            <a href="#k18" data-scroll-to="#k18">K18・18金</a>
            <a href="#platinum" data-scroll-to="#platinum">プラチナ</a>
            <a href="#coin" data-scroll-to="#coin">金貨・K24</a>
            <a href="#jewelry" data-scroll-to="#jewelry">指輪・ネックレス</a>
          </div>
          <div class="mini-formula">
            <span>自分で判断しにくい理由</span>
            <strong>刻印・重量・相場・手数料で、実際の金額が変わる</strong>
          </div>
          <p>片方だけのピアス、切れたネックレス、古い指輪も、金やプラチナとして価値が付く場合があります。</p>
        </aside>
      </div>
    </section>

    <section class="reassurance-band" aria-label="査定前の安心ポイント">
      <div class="container reassurance-grid">
        <div>
          <span>01</span>
          <strong>売るかは金額を見てから</strong>
          <p>査定額・手数料・キャンセル条件を確認してから判断できます。</p>
        </div>
        <div>
          <span>02</span>
          <strong>壊れた金製品も相談候補</strong>
          <p>切れたチェーンや片方ピアスも、素材価値が残る場合があります。</p>
        </div>
        <div>
          <span>03</span>
          <strong>持ち歩きが不安なら方法を選ぶ</strong>
          <p>店頭・出張・宅配の対応条件を先に確認できます。</p>
        </div>
      </div>
    </section>

    <section class="section consult-section">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">WHY NOW</span>
          <h2>「まだ売るか分からない」人ほど、先に査定額を聞いた方が早い</h2>
          <p>金の相場を検索しても、手元の品物の実額までは分かりません。迷う時間を減らすなら、まず相談して判断材料を作るのが近道です。</p>
        </div>
        <div class="consult-grid">
          <article>
            <strong>相場だけでは分からない</strong>
            <p>K18、K24、Pt900など品位が違うと単価も変わります。刻印が薄い品物も査定で確認できます。</p>
          </article>
          <article>
            <strong>壊れていても価値が残ることがある</strong>
            <p>切れたチェーン、片方だけのピアス、古い指輪も、素材として査定対象になる場合があります。</p>
          </article>
          <article>
            <strong>手数料で手取りが変わる</strong>
            <p>査定料、出張料、キャンセル条件、返送料の有無まで見てから売るか決めると安心です。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section proof-section">
      <div class="container proof-layout">
        <div>
          <span class="section-kicker">WHY MANEKIYA</span>
          <h2>まねきやを1位に置く理由は、公式で確認できる材料が多いから</h2>
          <p>
            買取LPで大事なのは「高そう」よりも、申し込み前に判断材料が見えること。
            まねきや公式では、相場表、買取実績、買取方法、手数料に関するFAQなどを確認できます。
          </p>
          <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="proof_manekiya" rel="nofollow sponsored">まねきや公式で判断材料を見る</a>
        </div>
        <div class="proof-grid">
          <article>
            <span>01</span>
            <h3>本日の価格相場を確認しやすい</h3>
            <p>金・プラチナの1gあたり参考相場を見てから、手元の品物の査定相談に進めます。</p>
          </article>
          <article>
            <span>02</span>
            <h3>壊れた金製品の例がある</h3>
            <p>石が取れた指輪、不揃いのイヤリング、切れたネックレスなども相談候補として考えられます。</p>
          </article>
          <article>
            <span>03</span>
            <h3>店頭・出張・宅配を選べる</h3>
            <p>持ち歩きが不安、点数が多い、外出しにくい人でも、品物や状況に合う方法を確認できます。</p>
          </article>
          <article>
            <span>04</span>
            <h3>費用条件を事前確認できる</h3>
            <p>査定料、出張費、送料、キャンセル時費用などは、申込前に公式FAQで確認しておくと安心です。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section intent-strip">
      <div class="container intent-grid">
        <div>
          <span class="section-kicker">PRICE SEARCH</span>
          <h2>価格を調べている今、見るべきなのは「相場」だけではありません</h2>
        </div>
        <div class="intent-list">
          <div>
            <strong>品位</strong>
            <span>K18、K24、Pt850、Pt900など</span>
          </div>
          <div>
            <strong>重量</strong>
            <span>グラム数と石・装飾部分の扱い</span>
          </div>
          <div>
            <strong>費用</strong>
            <span>査定料、出張料、キャンセル時費用</span>
          </div>
          <div>
            <strong>方法</strong>
            <span>店頭、出張、宅配の向き不向き</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section price-section" id="price">
      <div class="container price-layout">
        <div class="price-copy">
          <span class="section-kicker">PRICE CHECK</span>
          <h2>買取価格は「単価 × 重量」だけで終わらない</h2>
          <p>
            買取店のページでは、本日の1g単価、計算例、手数料無料、査定の流れを上部で見せていることがあります。
            このページでは固定の単価を保証せず、公式サイトで最新条件を確認する前に見るべきポイントを整理します。
          </p>
          <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="price_manekiya" rel="nofollow sponsored">公式で本日の査定条件を見る</a>
        </div>
        <div class="formula-card" aria-label="買取価格の見方">
          <div class="formula-row">
            <span>1</span>
            <div>
              <strong>刻印・品位を確認</strong>
              <p>K18、K24、Pt850、Pt900など。刻印が薄い場合も査定で確認できます。</p>
            </div>
          </div>
          <div class="formula-row">
            <span>2</span>
            <div>
              <strong>重量を見る</strong>
              <p>地金部分の重さが基本。石や装飾の扱いは店舗によって異なります。</p>
            </div>
          </div>
          <div class="formula-row">
            <span>3</span>
            <div>
              <strong>費用と条件を引く</strong>
              <p>査定料、出張料、返送料、キャンセル時費用、入金方法を確認します。</p>
            </div>
          </div>
          <div class="formula-note">
            例: K18ネックレスなら「公式の当日K18単価 × 重量」が目安。実際の査定額は状態・付属品・査定日で変わります。
          </div>
        </div>
      </div>
    </section>

    <section class="section compare-section" id="compare">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">COMPARISON</span>
          <h2>無料査定できる貴金属買取店を比較</h2>
          <p>編集部が、対応品目、査定方法、申込しやすさ、公式情報の確認しやすさをもとに比較しています。</p>
        </div>

        <div class="ready-box">
          <div>
            <span class="section-kicker">READY CHECK</span>
            <h3>このどれかに当てはまるなら、比較より先に査定相談してOK</h3>
          </div>
          <ul>
            <li>金相場を見ても、自分の品物の金額が分からない</li>
            <li>壊れたアクセサリーや古い指輪を処分するか迷っている</li>
            <li>店舗に持っていくのが不安で、出張や宅配も見たい</li>
            <li>売るかは決めていないが、金額だけ先に知りたい</li>
          </ul>
          <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="ready_manekiya" rel="nofollow sponsored">当てはまるので無料査定を相談する</a>
        </div>

        <div class="rank-list">
          <article class="rank-card rank-primary">
            <div class="rank-head">
              <span class="rank-badge">1位</span>
              <div>
                <h3>まねきや <span class="pr-chip">PR</span></h3>
                <p>「売るかは査定額を見て決めたい」人が最初に相談しやすい候補</p>
              </div>
            </div>
            <div class="winner-box">
              <span>迷ったらここから</span>
              <strong>相場・実績・買取方法・費用条件を見てから相談に進める</strong>
              <p>点数が多い、持ち歩きたくない、値段だけ先に知りたい。公式で判断材料を見てから無料査定へ進みやすいのが強みです。</p>
            </div>
            <dl class="fact-grid">
              <div><dt>査定方法</dt><dd>店頭・出張・宅配</dd></div>
              <div><dt>対象</dt><dd>金、K18、プラチナ、金貨、ブランド品など</dd></div>
              <div><dt>判断材料</dt><dd>相場表、買取実績、買取方法を公式で確認</dd></div>
              <div><dt>不安対策</dt><dd>壊れた品物や点数が多い場合も相談候補</dd></div>
              <div><dt>確認したいこと</dt><dd>手数料、キャンセル条件、返送料、対応エリア</dd></div>
            </dl>
            <div class="card-action">
              <a href="#" class="btn btn-primary btn-wide" data-affiliate="manekiya" data-track="compare_manekiya" rel="nofollow sponsored">まねきやで無料査定を相談する</a>
              <p>査定額は品物の状態・重量・相場・査定日で変動します。</p>
            </div>
          </article>

          <article class="rank-card">
            <div class="rank-head">
              <span class="rank-badge rank-muted">2位</span>
              <div>
                <h3>おたからや <span class="pr-chip">PR</span></h3>
                <p>知名度や店舗網も見ながら比較したい方へ</p>
              </div>
            </div>
            <dl class="fact-grid">
              <div><dt>査定方法</dt><dd>公式サイトで確認</dd></div>
              <div><dt>対象</dt><dd>金、貴金属、ブランド品など</dd></div>
              <div><dt>使いやすさ</dt><dd>全国展開の知名度がある</dd></div>
              <div><dt>不安対策</dt><dd>比較候補として条件を確認</dd></div>
              <div><dt>確認したいこと</dt><dd>申込条件、通電条件、店舗条件</dd></div>
            </dl>
            <div class="card-action">
              <a href="#" class="btn btn-outline btn-wide" data-affiliate="otakaraya" data-track="compare_otakaraya" rel="nofollow sponsored">おたからやの条件も見る</a>
              <p>2社を比較すると、売却前に納得しやすくなります。</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section decision-section">
      <div class="container decision-layout">
        <div>
          <span class="section-kicker">DECISION</span>
          <h2>買取で迷う理由は、だいたいこの3つです</h2>
          <p>「安く買われないか」「断りづらくないか」「どの方法が楽か」。この3つが残っているなら、公式で条件を見てから相談した方が判断しやすくなります。</p>
        </div>
        <div class="decision-cards">
          <article>
            <h3>金額が不安</h3>
            <p>相場検索だけでは手取りが分かりません。品位・重量・手数料を見てもらい、売るか決めましょう。</p>
          </article>
          <article>
            <h3>断れるか不安</h3>
            <p>査定後に売らない場合の費用やキャンセル条件を、申し込み前に公式で確認しておくのが大事です。</p>
          </article>
          <article>
            <h3>持ち運びが不安</h3>
            <p>点数が多い、高額品を持ち歩きたくない場合は、出張・宅配の対応可否を先に確認しましょう。</p>
          </article>
        </div>
      </div>
      <div class="container decision-cta">
        <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="decision_manekiya" rel="nofollow sponsored">不安な条件を公式で確認して相談する</a>
      </div>
    </section>

    <section class="section flow-section">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">FLOW</span>
          <h2>査定相談は3ステップで完了</h2>
          <p>売却を急がず、まず金額と条件を確認してから判断できます。</p>
        </div>
        <div class="flow-grid">
          <article>
            <span>01</span>
            <h3>品物を確認</h3>
            <p>K18、プラチナ、金貨、切れたネックレスなど、手元にあるものをまとめて確認します。</p>
          </article>
          <article>
            <span>02</span>
            <h3>無料査定を相談</h3>
            <p>店頭・出張・宅配のうち、持ち運びや点数に合う方法を公式で確認します。</p>
          </article>
          <article>
            <span>03</span>
            <h3>金額を見て判断</h3>
            <p>提示額、手数料、キャンセル条件、入金方法に納得してから売却します。</p>
          </article>
        </div>
        <div class="flow-cta">
          <a href="#" class="btn btn-primary" data-affiliate="manekiya" data-track="flow_manekiya" rel="nofollow sponsored">まねきやで無料査定の流れを見る</a>
        </div>
      </div>
    </section>

    <section class="section item-section" id="items">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">BY ITEM</span>
          <h2>品目別に、査定前の見落としを確認</h2>
          <p>検索されやすい品目ごとに、査定で見られるポイントをまとめました。</p>
        </div>
        <div class="item-grid">
          <article class="item-card" id="k18">
            <span>K18 / 18金</span>
            <h3>K18の買取価格を知りたい方</h3>
            <p>K18は金の含有率が目安になります。ネックレスやリングは重さに加えて、石やデザインの扱いも確認しましょう。</p>
            <a href="#" data-affiliate="manekiya" data-track="item_k18" rel="nofollow sponsored">K18の無料査定を確認</a>
          </article>
          <article class="item-card" id="platinum">
            <span>Pt850 / Pt900</span>
            <h3>プラチナの相場を確認したい方</h3>
