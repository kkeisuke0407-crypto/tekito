    "step": [
      { "@type": "HowToStep", "name": "まず落ち着く", "text": "問い詰める・スマホを盗み見るなど、感情的に動く前に一度立ち止まる。" },
      { "@type": "HowToStep", "name": "自分の状況を整理する", "text": "いまどの段階か（確信がない／怪しい／ほぼ確信／証拠あり）を見極める。" },
      { "@type": "HowToStep", "name": "合法な範囲で下調べする", "text": "行動メモやレシート整理など、自分でできる安全な確認を行う。" },
      { "@type": "HowToStep", "name": "証拠が必要なら専門家へ", "text": "裁判で使える証拠は探偵に、慰謝料・離婚は弁護士に相談する。" }
