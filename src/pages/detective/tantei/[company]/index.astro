---
import { companies } from '../../../../data/detective-companies.js';

export function getStaticPaths() {
  return ['una', 'alg', 'haraichi', 'kurol'].map(company => ({ params: { company } }));
}

const { company } = Astro.params;
const c = companies[company];
if (!c) throw new Error(`Unknown company: ${company}`);

const CANONICAL = `https://vpscomparehub.com/detective/tantei/${c.slug}/`;
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-07-16";

const others = Object.values(companies).filter(x => x.slug !== c.slug);
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{c.metaTitle}</title>
  <meta name="description" content={c.metaDesc} />
  <link rel="canonical" href={CANONICAL} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={c.metaTitle} />
  <meta property="og:description" content={c.metaDesc} />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="弁護士の中の人" />
  <meta property="og:image"     content="https://vpscomparehub.com/detective/images/hero.png" />
  <meta name="twitter:card"     content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Noto+Serif+JP:wght@700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/detective/styles.css?v=20260622h" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": `${c.name}の評判・口コミは？`,
        "acceptedAnswer": { "@type": "Answer", "text": `${c.name}は「${c.tagline}」が特徴の探偵事務所です。${c.reviews.join(' ')} 掲載内容は一般的な傾向であり、実際の対応は無料相談でご確認ください。` } },
      { "@type": "Question", "name": `${c.name}はどんな人に向いていますか？`,
        "acceptedAnswer": { "@type": "Answer", "text": `${c.forWho}に向いています。逆に、${c.notForWho}は他社も比較検討するのがおすすめです。` } },
      { "@type": "Question", "name": `${c.name}の料金はいくらですか？`,
        "acceptedAnswer": { "@type": "Answer", "text": `${c.info.map(i => i[0] + 'は' + i[1]).join('、')}です。料金は調査内容・地域・難易度で変わるため、正確な金額は無料見積もりでご確認ください。` } }
    ]
  })} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "TOP", "item": "https://vpscomparehub.com/detective/" },
      { "@type": "ListItem", "position": 2, "name": "探偵社の選び方", "item": "https://vpscomparehub.com/detective/tantei/" },
      { "@type": "ListItem", "position": 3, "name": c.name, "item": CANONICAL }
    ]
  })} />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
  </script>
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","wt0koam10v");
  </script>
</head>
<body class="lp-page lp-page-v2">

<header class="dt-header">
  <div class="dt-header-inner">
    <a href="/detective/" class="dt-logo">
      <div class="dt-logo-icon"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;border-radius:8px;display:block;" /></div>
      <div class="dt-logo-wrap"><span>弁護士の中の人</span><span class="dt-logo-sub">中の人ナビ</span></div>
    </a>
    <a href={INSTAGRAM_URL} class="dt-header-insta" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/></svg>
      <span>@lawyer.nakanohito</span>
    </a>
  </div>
</header>

<nav class="col-header-nav">
  <div class="col-header-nav-inner">
    <a href="/detective/navi/">状況ナビ</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/start/">最初に</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/flow/">診断</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cost/">費用相場</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/tantei/">探偵社比較</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cases/">体験談</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/column/">コラム</a>
  </div>
</nav>

<div class="lp-hero">
  <div class="lp-hero-meta">
    <span class="updated-meta">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      最終更新 <strong>{UPDATED}</strong>
    </span>
  </div>
  <span class="hero-v2-badge" style="display:inline-block;margin-bottom:.5rem;">{c.rank}｜{c.rankLabel}</span>
  <h1>{c.name}の<br/>評判・料金レビュー</h1>
  <p class="lp-hero-sub">{c.catch}。法律事務所の元事務員が、<strong>良い点も気になる点も正直に</strong>レビューします。</p>
</div>

<div class="lp-body">

  <nav class="lp-breadcrumb" aria-label="パンくず">
    <a href="/detective/">TOP</a>
    <span class="sep">›</span>
    <a href="/detective/tantei/">探偵社の選び方</a>
    <span class="sep">›</span>
    <strong>{c.name}</strong>
  </nav>

  <div class="lp-card">
    <h2>{c.name}の基本情報</h2>
    <table class="cd-info-table">
      <tbody>
        {c.info.map(row => (
          <tr><th>{row[0]}</th><td>{row[1]}</td></tr>
        ))}
      </tbody>
    </table>
    <div class="cd-evals">
      {c.evals.map(ev => (
        <div class="cd-eval-row">
          <span class="cd-eval-label">{ev[0]}</span>
          <div class="cd-eval-track"><div class="cd-eval-fill" style={`width:${ev[1]}%`}></div></div>
        </div>
      ))}
    </div>
    <a href={c.ctaUrl} class="lp-cta-block-btn" style="display:block;text-align:center;margin-top:1.25rem;" data-affiliate={c.affiliate} data-track={`cd_${c.slug}_top`} rel="nofollow sponsored noopener">{c.name}の公式サイトを見る →</a>
    <p style="text-align:center;font-size:.78rem;color:var(--muted);margin-top:.5rem;">無料・匿名OK・秘密厳守</p>
  </div>

  <div class="lp-card">
    <h2>強み（良い点）</h2>
    <ul class="cd-list cd-list-good">
      {c.strengths.map(s => (<li>{s}</li>))}
    </ul>
    <h2 style="margin-top:1.5rem;">気になる点（正直に）</h2>
    <ul class="cd-list cd-list-bad">
      {c.weaknesses.map(w => (<li>{w}</li>))}
    </ul>
  </div>

  <div class="lp-card">
    <h2>こんな人に向いています</h2>
    <div class="lp-step">
      <div class="lp-step-num">◎</div>
      <div class="lp-step-body"><strong>向いている人</strong><span>{c.forWho}</span></div>
    </div>
    <div class="lp-step">
      <div class="lp-step-num">△</div>
      <div class="lp-step-body"><strong>他社も検討したい人</strong><span>{c.notForWho}</span></div>
    </div>
  </div>

  <div class="lp-card">
    <h2>評判・口コミの傾向</h2>
    <p>ネット上の口コミや、事務所で見聞きした範囲での一般的な傾向を整理しました（個別の体験は人によって異なります）。</p>
    <ul class="cd-list">
      {c.reviews.map(r => (<li>{r}</li>))}
    </ul>
  </div>

  <div class="lp-card">
    <h2>中の人の正直レビュー</h2>
    <div class="cd-comment">
      <p>{c.comment}</p>
    </div>
    <div class="lp-warn">
      <div class="lp-warn-title">依頼前に必ず</div>
      <p>料金は調査内容・地域・難易度で変わります。<strong>必ず無料相談・無料見積もりで、自分のケースの費用感を確認してから</strong>契約してください。1社だけでなく複数社を比較するのが失敗しないコツです。</p>
    </div>
  </div>

  <div class="lp-cta-block">
    <h3>{c.name}に無料で相談してみる</h3>
    <p>{c.catch}。まずは無料相談で、あなたのケースだといくらくらいかかりそうか、見積もりを取ってみるのが確実です。匿名・秘密厳守で相談できます。</p>
    <a href={c.ctaUrl} class="lp-cta-block-btn" data-affiliate={c.affiliate} data-track={`cd_${c.slug}_cta`} rel="nofollow sponsored noopener">{c.name}の公式サイトを見る →</a>
    <p class="lp-cta-block-note">無料・匿名OK・秘密厳守</p>
  </div>

  <div class="lp-related">
    <h3>他の探偵社と比べる</h3>
    <div class="col-grid">
      <a href="/detective/tantei/" class="col-card">
        <span class="col-card-badge comparison">比較</span>
        <h3>探偵社4社の横並び比較</h3>
        <p>料金・特徴・エリアを一覧で比較。</p>
      </a>
      {others.slice(0, 2).map(o => (
        <a href={`/detective/tantei/${o.slug}/`} class="col-card">
          <span class="col-card-badge comparison">{o.rank}</span>
          <h3>{o.name}の評判・料金</h3>
          <p>{o.catch}</p>
        </a>
      ))}
    </div>
  </div>

</div>

<footer class="dt-footer">
  <div class="dt-footer-inner">
    <div class="dt-footer-logo">
      <div class="dt-footer-logo-icon" style="padding:0;overflow:hidden;"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;" /></div>
      <span>弁護士の中の人</span>
    </div>
    <p class="dt-footer-text">
      Instagram「弁護士の中の人（@lawyer.nakanohito）」の公式サイト。<br/>
      法律事務所の元事務員が、浮気・不倫で悩む方へ正直な情報をお届けしています。<br/>
      <span style="font-size:.75rem;color:rgba(255,255,255,.35)">当サイトは一部にアフィリエイトリンクを含みます。掲載の料金・評判は目安であり、内容を保証するものではありません。</span>
    </p>
    <div class="dt-footer-links">
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener">Instagram</a>
      <a href="/detective/tantei/">探偵社の選び方</a>
      <a href="/detective/cost/">費用相場</a>
      <a href="/detective/shouko/">証拠判定</a>
      <a href="/detective/lawyer/">弁護士相談</a>
      <a href="/detective/column/">コラム</a>
      <a href="/detective/about/">中の人について</a>
      <a href="/detective/privacy/">プライバシーポリシー</a>
      <a href="/detective/operator/">運営者情報</a>
    </div>
    <p class="dt-footer-copy">© 2026 弁護士の中の人</p>
  </div>
</footer>

<div class="sticky-cta-bar" id="sticky-cta">
  <span class="sticky-label">まずは無料相談から</span>
  <a href={c.ctaUrl} class="sticky-btn" data-affiliate={c.affiliate} data-track={`sticky_cd_${c.slug}`} rel="nofollow sponsored noopener">{c.name}を見る →</a>
  <button class="sticky-close" id="sticky-close" aria-label="閉じる">✕</button>
</div>

<script src="/detective/app.js" is:inline defer></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var sticky = document.getElementById('sticky-cta');
    if (!sticky) return;
    var dismissed = false;
    document.getElementById('sticky-close').addEventListener('click', function() {
      dismissed = true; sticky.classList.remove('visible');
    });
    window.addEventListener('scroll', function() {
      if (dismissed) return;
      sticky.classList.toggle('visible', window.scrollY > window.innerHeight * 0.6);
    }, { passive: true });
  });
</script>

</body>
</html>
