<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('ns-gen');
    if (!btn) return;

    function buildLetter() {
      var target = document.getElementById('ns-target').value;
      var amountRaw = (document.getElementById('ns-amount').value || '').replace(/[^0-9]/g, '');
      var deadline = document.getElementById('ns-deadline').value;
      var relation = document.getElementById('ns-relation').value;

      var toLabel = target === 'spouse' ? '貴殿（貴女）' : '貴殿（貴女）';
      var title = '通知書';

      var lines = [];
      lines.push('　　　　　　　　　' + title);
      lines.push('');

      // 事実の記載（中立・事実ベース、脅迫表現なし）
      if (target === 'partner') {
        if (relation === 'continued') {
          lines.push('　私は、私の配偶者と貴殿（貴女）が、継続的に不貞行為（肉体関係）を行っていた事実を確認いたしました。');
        } else if (relation === 'once') {
          lines.push('　私は、私の配偶者と貴殿（貴女）が、不貞行為（肉体関係）に及んだ事実を確認いたしました。');
        } else {
          lines.push('　私は、私の配偶者と貴殿（貴女）との間に、不貞行為があったと考えられる事実を確認しております。');
        }
        lines.push('　貴殿（貴女）の行為により、私は夫婦関係を害され、多大な精神的苦痛を受けました。');
      } else {
        if (relation === 'continued') {
          lines.push('　私は、貴殿（貴女）が第三者と継続的に不貞行為（肉体関係）を行っていた事実を確認いたしました。');
        } else if (relation === 'once') {
          lines.push('　私は、貴殿（貴女）が第三者と不貞行為（肉体関係）に及んだ事実を確認いたしました。');
        } else {
          lines.push('　私は、貴殿（貴女）に不貞行為があったと考えられる事実を確認しております。');
        }
        lines.push('　貴殿（貴女）の行為により、私は多大な精神的苦痛を受けました。');
      }
      lines.push('');

      // 請求
      if (amountRaw) {
        var man = parseInt(amountRaw, 10);
        lines.push('　つきましては、上記不貞行為による慰謝料として、金' + man.toLocaleString('ja-JP') + '万円を請求いたします。');
      } else {
        lines.push('　つきましては、上記不貞行為による慰謝料の支払いを請求いたします。金額については別途協議を求めます。');
      }
      if (deadline) {
        lines.push('　本書面到達後' + deadline + '以内に、下記口座へお支払いいただきますようお願い申し上げます。');
      }
      lines.push('');
      lines.push('　なお、本件について誠意ある対応が得られない場合は、法的手続きを検討せざるを得ませんので、あらかじめ申し添えます。');
      lines.push('');
      lines.push('　　　　　　　　　　　　　　　　　　令和　年　月　日');
      lines.push('');
      lines.push('　　　　　　　　　　　住所：');
      lines.push('　　　　　　　　　　　氏名：　　　　　　　　　　　印');
      lines.push('');
      lines.push('（振込先口座）');
      lines.push('　銀行名・支店名：');
      lines.push('　口座番号：');
      lines.push('　口座名義：');

      return lines.join('\n');
    }

    btn.addEventListener('click', function () {
      var text = buildLetter();
      document.getElementById('ns-output').textContent = text;
      var result = document.getElementById('ns-result');
      result.classList.add('visible');
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (typeof gtag === 'function') gtag('event', 'naiyoshomei_generated', {});
      if (window.dataLayer) window.dataLayer.push({ event: 'naiyoshomei_generated' });
    });

    document.getElementById('ns-copy').addEventListener('click', function () {
      var text = document.getElementById('ns-output').textContent;
      var self = this;
      function done() {
        var old = self.textContent;
        self.textContent = 'コピーしました ✓';
        setTimeout(function () { self.textContent = old; }, 1800);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () {
          fallbackCopy(text); done();
        });
      } else {
        fallbackCopy(text); done();
      }
    });

    function fallbackCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
    }
  });
</script>

</body>
</html>
