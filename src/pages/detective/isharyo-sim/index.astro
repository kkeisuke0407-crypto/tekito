<div class="sticky-cta-bar" id="sticky-cta">
  <span class="sticky-label">実際の金額は弁護士に</span>
  <a href="/detective/lawyer/" class="sticky-btn" data-track="sticky_sim_lawyer">弁護士相談ガイドを見る →</a>
  <button class="sticky-close" id="sticky-close" aria-label="閉じる">✕</button>
</div>

<script src="/detective/app.js" is:inline defer></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('sim-calc');
    if (!btn) return;
    var BASE = { divorce: 200, separate: 150, claim: 90, undecided: 130 };
    var YEAR = { y1: 0.7, y2: 1.0, y3: 1.2, y4: 1.4 };
    var DEG  = { once: 0.75, mid: 1.1, habit: 1.35 };
    var EVID = { strong: 1.1, some: 1.0, none: 0.85 };

    btn.addEventListener('click', function () {
      var dir = document.getElementById('sim-dir').value;
      var yr  = document.getElementById('sim-years').value;
      var kid = document.getElementById('sim-kids').value;
      var deg = document.getElementById('sim-deg').value;
      var ev  = document.getElementById('sim-evidence').value;

      if (!dir || !yr || !kid || !deg || !ev) {
        alert('すべての質問にお答えください。');
        return;
      }

      var raw = BASE[dir] * YEAR[yr] * (kid === 'yes' ? 1.15 : 1.0) * DEG[deg] * EVID[ev];
      var low  = Math.max(30, Math.round((raw * 0.7) / 10) * 10);
      var high = Math.min(400, Math.round((raw * 1.15) / 10) * 10);
      if (high <= low) high = low + 30;

      var amount = document.getElementById('sim-amount');
      amount.innerHTML = 'およそ <span></span>' + low + '〜' + high + '<span></span>万円';

      var note = document.getElementById('sim-note');
      var msgs = [];
      if (ev === 'none') {
        msgs.push('現時点では<strong>証拠がない</strong>ため、このままでは請求が難しい可能性があります。まずは証拠を固めることが最優先です。');
      } else if (ev === 'some') {
        msgs.push('一部の証拠はありますが、<strong>不貞を立証できる決定的な証拠</strong>があると交渉を有利に進めやすくなります。');
      } else {
        msgs.push('決定的な証拠をお持ちなら、慰謝料請求を進める土台は整っています。次は弁護士への相談が現実的な一歩です。');
      }
      msgs.push('※これは過去の判例傾向にもとづく<strong>目安</strong>です。実際の金額は個別事情で変わります。');
      note.innerHTML = msgs.join('<br/>');

      var result = document.getElementById('sim-result');
      result.classList.add('visible');
      result.scrollIntoView({ behavior: 'smooth', block: 'center' });

      if (typeof gtag === 'function') {
        gtag('event', 'sim_calc_done', { direction: dir, evidence: ev });
      }
      if (window.dataLayer) {
        window.dataLayer.push({ event: 'sim_calc_done', direction: dir, evidence: ev });
      }
    });
  });
</script>

</body>
</html>
