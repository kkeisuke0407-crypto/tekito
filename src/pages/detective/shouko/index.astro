---
const PAGE_TITLE = "浮気の証拠、使える？使えない？タイプ別判定ガイド｜中の人ナビ";
const PAGE_DESC  = "LINE・写真・動画・GPS履歴・レシート・録音・SNS——浮気の証拠として「裁判で使えるか」「集め方は合法か」をタイプ別に判定。法律事務所の元事務員が、証拠の強さと注意点を正直に整理しました。";
const CANONICAL  = "https://vpscomparehub.com/detective/shouko/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-06-15";

const evidences = [
  {
    name: "ラブホテルの出入り写真・動画",
    badge: "good", badgeLabel: "証拠力 高",
    power: 95, legal: 70,
    desc: "二人がラブホテルに一緒に出入りする様子は、不貞行為を強く推認させる代表的な証拠。日時・場所が特定でき、複数回あればさらに強力です。",
    tip: "公道など誰でも撮影できる場所からの撮影は合法。ただし敷地内への無断侵入や、気づかれて警戒されるリスクがあるため、<strong>撮影は探偵に任せるのが確実</strong>です。"
  },
  {
    name: "探偵の調査報告書",
    badge: "good", badgeLabel: "証拠力 高",
    power: 98, legal: 95,
    desc: "日時・場所・行動・写真が時系列で整理された報告書は、裁判で最も通用しやすい証拠。弁護士も「これがあると進めやすい」と評価します。",
    tip: "探偵業の届出をした業者が作成したものが前提。<strong>裁判を見据えるなら最初から探偵に依頼</strong>するのが、結果的に最短ルートになります。"
  },
  {
    name: "性的な内容のLINE・メール",
    badge: "mid", badgeLabel: "証拠力 中〜高",
    power: 75, legal: 50,
    desc: "肉体関係をうかがわせるやり取りは有力な証拠になりえます。ただし「会いたい」程度では不貞の立証には弱く、内容次第で評価が分かれます。",
    tip: "<strong>勝手にスマホを見て取得すると、不正アクセス等で違法・証拠として弱くなる</strong>恐れがあります。画面を見られる状況での撮影など、入手経路に注意。"
  },
  {
    name: "クレジット明細・レシート",
    badge: "mid", badgeLabel: "証拠力 中",
    power: 50, legal: 85,
    desc: "ホテル・贈り物・二人分の飲食など、不貞を間接的に裏づける材料。単体では弱いですが、他の証拠と組み合わせると効果的です。",
    tip: "家計として共有している明細なら入手は問題になりにくい。<strong>「間接事実」を積み重ねる補強材料</strong>として保管しておきましょう。"
  },
  {
    name: "GPSの位置情報履歴",
    badge: "mid", badgeLabel: "証拠力 中（補助）",
    power: 45, legal: 55,
    desc: "「いつ・どこにいたか」を示せますが、位置情報だけでは「誰と何をしていたか」までは証明できず、単体では不貞の証拠になりにくい。",
    tip: "設置できるのは<strong>自分名義／共有名義の車のみ</strong>。下調べで行動を絞り込み、決定的な場面の撮影は探偵に、が王道です。<a href=\"/detective/gps/\">GPS活用ガイド</a>へ。"
  },
  {
    name: "会話の録音",
    badge: "mid", badgeLabel: "証拠力 中",
    power: 55, legal: 60,
    desc: "本人が不貞を認める発言の録音は有力。自分が当事者として参加した会話の録音は、相手の同意がなくても証拠として認められる傾向です。",
    tip: "<strong>第三者間の会話を盗聴するのは違法</strong>で証拠にもなりません。自分が会話に加わっている録音にとどめてください。"
  },
  {
    name: "SNS・写真共有アプリの投稿",
    badge: "bad", badgeLabel: "証拠力 低〜中",
    power: 35, legal: 60,
    desc: "ペアの投稿や位置情報がヒントになることはありますが、公開情報は加工・削除されやすく、それ単体で不貞を立証するのは困難です。",
    tip: "スクショで<strong>日時がわかる形で保存</strong>しておくと補助材料に。ただし鍵アカウントへの不正ログインは違法なので絶対に避けてください。"
  },
  {
    name: "勝手に見たスマホのスクショ",
    badge: "bad", badgeLabel: "要注意",
    power: 40, legal: 15,
    desc: "内容自体は決定的でも、<strong>入手経路が問題視されると証拠価値が大きく下がり</strong>、逆にプライバシー侵害で自分が責められることもあります。",
    tip: "事務所でも「これで突撃して立場が悪化した」例が最多。<strong>見つけても問い詰めず</strong>、正規の方法で証拠を固め直すのが鉄則です。"
  }
];
