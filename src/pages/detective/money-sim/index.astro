<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('ms-calc');
    if (!btn) return;

    // 児童扶養手当：子供人数と所得区分から年額目安（2026年度）
    // 全部支給48,050円/月・第2子以降11,350円/月、一部支給・停止を所得で概算
    function childAllowance(kids, income) {
      if (kids === 0) return 0;
      var firstMonthly, addMonthly;
      if (income === 'low')      { firstMonthly = 48050; addMonthly = 11350; } // 全部支給
      else if (income === 'mid') { firstMonthly = 27000; addMonthly = 7000; }  // 一部支給の中間概算
      else                       { firstMonthly = 0;     addMonthly = 0; }      // 支給停止
      var extra = Math.max(0, kids - 1);
      return (firstMonthly + addMonthly * extra) * 12;
    }

    // 養育費：算定表を大まかに反映した月額目安 × 22歳までの残年数 × 子供人数係数
    function childSupport(kids, age, ex) {
      if (kids === 0) return 0;
      var perChild = { e300: 30000, e500: 50000, e700: 70000, e900: 90000 }[ex] || 0;
      // 子供が増えると1人あたりは逓減
      var kidFactor = { 1: 1, 2: 1.7, 3: 2.2 }[kids] || 1;
      var monthly = perChild * kidFactor;
      var years = Math.max(0, 22 - parseInt(age, 10)); // 末子が22歳になるまでの概算
      return monthly * 12 * years;
    }

    // 年金分割：婚姻期間から老後の受給増の超概算（幅で提示）
    function pensionSplit(marriage) {
      return { m5: '数万〜十数万円', m15: '十数万〜30万円', m25: '30万〜60万円', m30: '50万円以上' }[marriage] || '—';
    }

    function yen(n) { return n.toLocaleString('ja-JP'); }

    btn.addEventListener('click', function () {
      var kids  = document.getElementById('ms-kids').value;
      var age   = document.getElementById('ms-age').value;
      var income = document.getElementById('ms-income').value;
      var ex    = document.getElementById('ms-ex').value;
      var marriage = document.getElementById('ms-marriage').value;

      if (kids === '' || age === '' || income === '' || ex === '' || marriage === '') {
        alert('すべての質問にお答えください。');
        return;
      }
      var kidsN = parseInt(kids, 10);

      var allowanceYear = childAllowance(kidsN, income);
      var supportTotal  = childSupport(kidsN, age, ex);
      var pension = pensionSplit(marriage);

      // 合計の目安（児童扶養手当は「年額」、養育費は「総額」）
      var breakdown = document.getElementById('ms-breakdown');
      var rows = [];
      rows.push('<div class="ms-row"><span>児童扶養手当</span><strong>' + (allowanceYear > 0 ? '年 約' + yen(allowanceYear) + '円' : '対象外・支給停止') + '</strong></div>');
      rows.push('<div class="ms-row"><span>養育費（22歳までの総額目安）</span><strong>' + (supportTotal > 0 ? '約' + yen(supportTotal) + '円' : '子供なし') + '</strong></div>');
      rows.push('<div class="ms-row"><span>年金分割（老後の受給増・目安）</span><strong>年 ' + pension + '</strong></div>');
      breakdown.innerHTML = rows.join('');

      var amount = document.getElementById('ms-amount');
      if (supportTotal > 0) {
        amount.innerHTML = '養育費だけで<br/>約 ' + yen(supportTotal) + ' 円';
      } else if (allowanceYear > 0) {
        amount.innerHTML = '児童扶養手当<br/>年 約' + yen(allowanceYear) + ' 円';
      } else {
        amount.innerHTML = '年金分割が中心';
      }

      var note = document.getElementById('ms-note');
      var msgs = [];
      if (income === 'high') {
        msgs.push('あなたの年収では<strong>児童扶養手当は支給停止の可能性</strong>があります。所得制限は毎年変わるため、自治体窓口で必ず確認を。');
      } else if (income === 'mid') {
        msgs.push('児童扶養手当は<strong>一部支給</strong>の可能性が高いです。実額は前年所得で細かく決まります。');
      }
      if (supportTotal > 0) {
        msgs.push('養育費は<strong>「取り決めても払われない」</strong>のが最大の壁。公正証書や合意書で金額を明確にし、2026年改正の差し押さえ制度に備えましょう。');
      }
      msgs.push('※これは2026年時点の制度にもとづく<strong>概算</strong>です。実額は所得・自治体・個別事情で変わります。自治体・年金事務所・弁護士にご確認ください。');
      note.innerHTML = msgs.join('<br/>');

      var result = document.getElementById('ms-result');
      result.classList.add('visible');
      result.scrollIntoView({ behavior: 'smooth', block: 'center' });

      if (typeof gtag === 'function') gtag('event', 'moneysim_calc_done', { kids: kids, income: income });
      if (window.dataLayer) window.dataLayer.push({ event: 'moneysim_calc_done', kids: kids, income: income });
    });
  });
</script>

</body>
</html>
