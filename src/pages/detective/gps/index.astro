    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "GPSを使って配偶者の行動パターンを把握する手順",
    "description": "自分名義または共有名義の車にGPSを設置し、行動パターンを記録して次のステップを判断する手順。",
    "step": [
      { "@type": "HowToStep", "name": "車の名義を確認する", "text": "車検証で名義人を確認し、自分名義または共有名義であることを確かめる。" },
      { "@type": "HowToStep", "name": "GPS機器を選ぶ", "text": "通信費・更新頻度・バッテリー持続時間・取り付け方法を比較して選定する。" },
      { "@type": "HowToStep", "name": "設置して行動パターンを記録", "text": "1〜2週間、行動パターン（どこに・いつ・どれくらい滞在）を記録する。" },
      { "@type": "HowToStep", "name": "次のステップを判断", "text": "記録から探偵に依頼するか、判断する。" }
    ]
  })} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
