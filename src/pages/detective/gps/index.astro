const CANONICAL  = "https://lawyer-nakanohito.com/detective/gps/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const AFFILIATE_URL = "https://h.accesstrade.net/sp/cc?rk=0100r19500orzx";
---
