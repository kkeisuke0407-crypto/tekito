  <style>
    .md-list { display:grid; grid-template-columns:1fr; gap:.85rem; margin:1rem 0 0; }
    .md-card { border:1.5px solid rgba(0,0,0,.09); border-radius:14px; padding:1rem 1.05rem; background:#fff; }
    .md-card-name { font-size:1.02rem; font-weight:900; line-height:1.5; color:var(--navy,#1a2b4a); margin:0 0 .35rem; }
    .md-tel { display:inline-flex; align-items:center; gap:.4rem; background:#c8362a; color:#fff; font-weight:900; font-size:1.05rem; letter-spacing:.02em; padding:.5rem .85rem; border-radius:10px; text-decoration:none; margin:.15rem 0 .5rem; }
    .md-tel svg { width:1em; height:1em; }
    .md-telnote { display:block; font-size:.76rem; color:rgba(0,0,0,.55); margin:.1rem 0 .55rem; }
    .md-body { font-size:.87rem; line-height:1.85; margin:0; color:var(--text,#333); }
    .md-note { font-size:.78rem; line-height:1.8; color:rgba(0,0,0,.55); margin:.6rem 0 0; padding:.55rem .7rem; background:rgba(0,0,0,.035); border-radius:8px; }
    .md-cta { display:inline-block; margin-top:.7rem; font-size:.85rem; font-weight:800; color:var(--navy,#1a2b4a); text-decoration:underline; }
  </style>
</head>
