---
const PAGE_TITLE = "浮気・不倫の無料相談窓口まとめ｜弁護士に頼む前に使える公的サービス｜中の人ナビ";
const PAGE_DESC  = "「弁護士に頼むお金がない」「まず誰かに話したい」——そんなときに無料で使える相談窓口を、法律（法テラス・自治体・弁護士会）と気持ち・DV・緊急（よりそいホットライン・DV相談＋など）に分けて、法律事務所の元事務員が整理しました。匿名で使える窓口も多数。";
const CANONICAL  = "https://vpscomparehub.com/detective/soudan/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-06-22";

const telHref = (t) => (/[＃#]/.test(t) ? 'tel:%23' : 'tel:') + t.replace(/[^0-9]/g, '');

const houritsu = [
  {
    name: "法テラス（日本司法支援センター）",
    tel: "0570-078374",
    telnote: "サポートダイヤル／平日9:00〜21:00・土9:00〜17:00",
    body: "国が設立した法的トラブルの総合案内所。収入・資産が一定基準以下なら、同じ問題で3回まで無料の法律相談が受けられ、弁護士費用の立替（分割で返済）も利用できます。まず電話で「使えるか」を確認できます。",
    note: "無料相談・費用立替には資力要件あり（目安：地方在住3人家族で夫婦の月収合算27万円台以下など）。離婚など配偶者と対立する事件では配偶者の収入は合算しません。最新の基準は公式で確認を。",
  },
  {
    name: "自治体の無料法律相談",
    tel: null,
    telnote: "お住まいの市区役所・町村役場へ",
    body: "多くの市区町村が、住民向けに弁護士による無料法律相談（1回30分程度・予約制）を定期開催しています。費用は無料で、資力要件がないことが多いのが利点。「◯◯市 無料法律相談」で検索するか、市役所の市民相談窓口へ。",
    note: "1人1回・時間制限あり、予約が埋まりやすい点に注意。まず全体像をつかむのに向いています。",
  },
  {
    name: "弁護士会の法律相談センター",
    tel: null,
    telnote: "各都道府県の弁護士会",
    body: "各地の弁護士会が運営する相談窓口。離婚・不倫問題に対応する相談枠があり、初回は無料〜有料（30分5,000円程度）。有料でも「不倫慰謝料に強い弁護士」に直接つながりやすいのが強みです。",
    note: "料金は地域・相談内容で異なります。予約時に無料枠の有無を確認してください。",
  },
  {
    name: "初回無料の法律事務所",
    tel: null,
    telnote: "民間の法律事務所",
    body: "不倫慰謝料・離婚を扱う事務所の多くが「初回相談無料」を掲げています。いきなり依頼しなくてOK。見積もりと方針を聞くだけでも、次の一手がはっきりします。複数に相談して比べるのも自由です。",
    note: "無料なのは「相談」まで。依頼時の費用体系（着手金・報酬）は必ず事前確認を。",
    ctaHref: "/detective/lawyer/",
    ctaLabel: "弁護士相談ガイドを見る →",
  },
];

const kokoro = [
  {
    name: "よりそいホットライン",
    tel: "0120-279-338",
    telnote: "24時間365日・通話無料・匿名OK",
    body: "「誰かに話したい」「この先どうしたらいいか分からない」——どんな内容でも受け止めてくれる総合相談。DV・性暴力・つらい気持ちなど専門のつなぎ先もあります。",
  },
  {
    name: "DV相談＋（プラス）",
    tel: "0120-279-889",
    telnote: "24時間・電話／メール／チャット・通話無料",
    body: "配偶者からの暴力・モラハラの相談専用。24時間つながり、必要に応じて避難や支援機関へつないでくれます。身の危険があるときの心強い窓口。",
  },
  {
    name: "DV相談ナビ",
    tel: "＃8008",
    telnote: "最寄りの相談機関へ自動転送",
    body: "「はれれば（＃8008）」で覚えられる番号。かけると、お住まいの地域の配偶者暴力相談支援センターなど最寄りの窓口につながります。",
  },
  {
    name: "女性の人権ホットライン",
    tel: "0570-070-810",
    telnote: "法務省・平日8:30〜17:15",
    body: "女性をめぐる人権問題（配偶者からの暴力、ストーカー、セクハラ等）の相談。法務局の職員・人権擁護委員が対応します。",
  },
  {
    name: "警察相談専用電話",
    tel: "＃9110",
    telnote: "緊急でない相談用（緊急は110番）",
    body: "つきまとい・脅し・不安があるが事件かどうか迷う——そんなときの相談窓口。今まさに危険が迫っているときは、迷わず110番へ。",
  },
];
