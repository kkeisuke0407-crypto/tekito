            <div class="eval-bar-row">
              <span class="eval-bar-label">費用の安さ</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:95%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">実績・信頼</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:72%"></div></div>
            </div>
            <div class="eval-bar-row">
              <span class="eval-bar-label">対応の柔軟性</span>
              <div class="eval-bar-track"><div class="eval-bar-fill" style="width:78%"></div></div>
