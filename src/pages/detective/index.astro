---
import { columns } from '../../data/detective-columns.js';
const pickSlugs = ['jitsumu-bure-pattern','ishatyou-toreta-torenakatta','nani-kara-hajimeru','bengoshi-shouko-ato','tashikameru-kowai','tantei-souba'];
const recentColumns = pickSlugs.map(s => columns.find(c => c.slug === s)).filter(Boolean);

const PAGE_TITLE = "中の人ナビ｜浮気・不倫で悩んだときの全選択肢ガイド";
const PAGE_DESC  = "法律事務所の元事務員が、浮気・不倫で悩む方に「探偵・GPS・弁護士・相談」の全選択肢を正直に解説。費用相場・法律の境界線・実体験集まで、判断材料をまとめました。";
const CANONICAL  = "https://vpscomparehub.com/detective/";
const OGP_IMAGE  = "https://vpscomparehub.com/detective/images/hero.png";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-05-25";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="弁護士の中の人" />
  <meta name="twitter:card"       content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/detective/styles.css?v=20260615g" />
  <link rel="manifest" href="/detective/manifest.json" />
  <meta name="theme-color" content="#1e3a5f" />
  <link rel="apple-touch-icon" href="/detective/images/logo-icon.png" />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
  </script>

  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wt0koam10v");
  </script>

  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://vpscomparehub.com/detective/#website",
        "url": "https://vpscomparehub.com/detective/",
        "name": "中の人ナビ",
        "description": "法律事務所の元事務員が浮気・不倫で悩む方へ探偵・GPS・弁護士・相談の全選択肢を解説",
        "publisher": {
          "@type": "Person",
          "name": "弁護士の中の人",
          "url": "https://vpscomparehub.com/detective/about/"
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://vpscomparehub.com/detective/glossary/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "Organization",
        "@id": "https://vpscomparehub.com/detective/#org",
        "name": "中の人ナビ",
        "url": "https://vpscomparehub.com/detective/",
        "logo": "https://vpscomparehub.com/detective/images/logo-icon.png",
        "sameAs": ["https://www.instagram.com/lawyer.nakanohito/"]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "中の人ナビとはどんなサイトですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "中の人ナビは、Instagram「@lawyer.nakanohito（弁護士の中の人）」の公式サイトです。法律事務所で約10年勤務した元事務員が、浮気・不倫で悩む方へ「探偵・GPS・弁護士・電話占い・公認心理師のカウンセリング」の全選択肢を整理し、費用相場・法律の境界線・慰謝料の目安・立場別ガイドなどを正直に解説しています。" } },
          { "@type": "Question", "name": "そもそも「中の人」って誰ですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "弁護士事務所で約10年事務員として働いてきた者です。何百件もの離婚・浮気・慰謝料に関する案件を間近で見てきました。私自身は弁護士ではないため、法的な見解は述べず、事務員として見聞きしてきた経験を中心にお伝えしています。" } },
          { "@type": "Question", "name": "探偵以外の選択肢（GPSなど）はないのですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "あります。状況によっては、自分でGPSを使う、まず気持ちを整理する、弁護士に相談する、といった選択肢が適切なケースもあります。5問診断と費用相場ページで状況に合うものを選べます。" } },
          { "@type": "Question", "name": "自分でGPSを使うのは違法ではないですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "自分名義または夫婦共有名義の車であれば、設置が違法になりにくいとされています。一方で、相手だけの名義の車・社用車・他人の所有物への設置は、ストーカー規制法の対象になる可能性があります。" } },
          { "@type": "Question", "name": "弁護士に相談するのと、探偵に依頼するのは、どちらが先ですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "慰謝料や離婚を視野に入れている場合、「証拠を集めてから弁護士に相談」が一般的な順番です。弁護士は法的手続きを進める専門家であり、証拠収集の調査は行いません。" } },
          { "@type": "Question", "name": "弁護士はどこで探せばいいですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "交渉が調停・訴訟に発展すると何度も動くことになるため、自宅から通いやすい『地域の不倫慰謝料に強い弁護士』を選ぶのが鉄則です。ベンナビ不倫慰謝料なら、地域・取扱分野・無料相談有無で絞り込み検索ができます。" } },
          { "@type": "Question", "name": "浮気調査の費用相場はいくらですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "一般的に20〜80万円。時間制（1時間2万円前後）、パック制（30〜60万円）、成功報酬制（着手金＋成功時報酬）の3タイプがあります。詳しくは費用相場ページ。" } },
          { "@type": "Question", "name": "家族や職場にバレませんか？",
            "acceptedAnswer": { "@type": "Answer", "text": "探偵業法により、探偵事務所には守秘義務があります。匿名相談も可能で、連絡方法（電話・LINE・メール）も指定できます。信頼できる業者であれば情報が漏れることはありません。" } },
          { "@type": "Question", "name": "不倫の慰謝料の相場はいくらですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "一般的な相場は50〜300万円程度です。婚姻期間が長いほど、未成年の子供がいる場合、不貞が長期・常習的な場合、不貞が原因で離婚・別居に至った場合は金額が上振れする傾向があります。実際の金額は個別事情で大きく変わるため、目安シミュレーターおよび弁護士相談で確認してください。" } },
          { "@type": "Question", "name": "裁判で使える浮気の証拠は何ですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "もっとも証拠力が高いのは「ラブホテルへの出入り写真・動画」「宿泊を伴う交際を示す写真」「探偵事務所の調査報告書」です。LINE・メールのスクショや位置情報の記録、レシートなどは単体では弱く、上記の決定的証拠と組み合わせることで証拠力が高まります。スマホを勝手に見て得たスクショは不正アクセス禁止法に触れる可能性があり、証拠としても評価が下がります。" } }
        ]
      }
    ]
  })}</script>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
