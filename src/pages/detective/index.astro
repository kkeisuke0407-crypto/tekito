---
import { columns } from '../../data/detective-columns.js';
const pickSlugs = ['jitsumu-bure-pattern','ishatyou-toreta-torenakatta','nani-kara-hajimeru','bengoshi-shouko-ato','tashikameru-kowai','tantei-souba'];
const recentColumns = pickSlugs.map(s => columns.find(c => c.slug === s)).filter(Boolean);

const PAGE_TITLE = "中の人ナビ｜浮気・不倫で悩んだときの全選択肢ガイド";
const PAGE_DESC  = "法律事務所の元事務員が、浮気・不倫で悩む方に「探偵・GPS・弁護士・相談」の全選択肢を正直に解説。費用相場・法律の境界線・実体験集まで、判断材料をまとめました。";
const CANONICAL  = "https://lawyer-nakanohito.com/";
const OGP_IMAGE  = "https://lawyer-nakanohito.com/og-default.jpg";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-05-25";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="弁護士の中の人" />
  <meta name="twitter:card"       content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/detective/styles.css?v=20260525s" />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
  </script>

  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wt0koam10v");
  </script>

  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://lawyer-nakanohito.com/#website",
        "url": "https://lawyer-nakanohito.com/",
        "name": "中の人ナビ",
        "description": "法律事務所の元事務員が浮気・不倫で悩む方へ探偵・GPS・弁護士・相談の全選択肢を解説",
        "publisher": {
          "@type": "Person",
          "name": "弁護士の中の人",
          "url": "https://lawyer-nakanohito.com/detective/about/"
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://lawyer-nakanohito.com/detective/glossary/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "Organization",
        "@id": "https://lawyer-nakanohito.com/#org",
        "name": "中の人ナビ",
        "url": "https://lawyer-nakanohito.com/",
        "logo": "https://lawyer-nakanohito.com/detective/images/logo-icon.png",
        "sameAs": ["https://www.instagram.com/lawyer.nakanohito/"]
      },
      {
        "@type": "ItemList",
        "name": "個人的に信頼できる探偵 3社",
        "itemListOrder": "https://schema.org/ItemListOrderAscending",
        "numberOfItems": 3,
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "うな探偵社", "url": "https://h.accesstrade.net/sp/cc?rk=0100q30i00orzx" },
          { "@type": "ListItem", "position": 2, "name": "原一探偵事務所", "url": "https://h.accesstrade.net/sp/cc?rk=0100ken700orzx" },
          { "@type": "ListItem", "position": 3, "name": "総合探偵社クロル", "url": "https://h.accesstrade.net/sp/cc?rk=0100paqn00orzx" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "そもそも「中の人」って誰ですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "弁護士事務所で約10年事務員として働いてきた者です。何百件もの離婚・浮気・慰謝料に関する案件を間近で見てきました。私自身は弁護士ではないため、法的な見解は述べず、事務員として見聞きしてきた経験を中心にお伝えしています。" } },
          { "@type": "Question", "name": "探偵以外の選択肢（GPSなど）はないのですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "あります。状況によっては、自分でGPSを使う、まず気持ちを整理する、弁護士に相談する、といった選択肢が適切なケースもあります。5問診断と費用相場ページで状況に合うものを選べます。" } },
          { "@type": "Question", "name": "自分でGPSを使うのは違法ではないですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "自分名義または夫婦共有名義の車であれば、設置が違法になりにくいとされています。一方で、相手だけの名義の車・社用車・他人の所有物への設置は、ストーカー規制法の対象になる可能性があります。" } },
          { "@type": "Question", "name": "弁護士に相談するのと、探偵に依頼するのは、どちらが先ですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "慰謝料や離婚を視野に入れている場合、「証拠を集めてから弁護士に相談」が一般的な順番です。弁護士は法的手続きを進める専門家であり、証拠収集の調査は行いません。" } },
          { "@type": "Question", "name": "弁護士はどこで探せばいいですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "交渉が調停・訴訟に発展すると何度も動くことになるため、自宅から通いやすい『地域の不倫慰謝料に強い弁護士』を選ぶのが鉄則です。ベンナビ不倫慰謝料なら、地域・取扱分野・無料相談有無で絞り込み検索ができます。" } },
          { "@type": "Question", "name": "浮気調査の費用相場はいくらですか？",
            "acceptedAnswer": { "@type": "Answer", "text": "一般的に20〜80万円。時間制（1時間2万円前後）、パック制（30〜60万円）、成功報酬制（着手金＋成功時報酬）の3タイプがあります。詳しくは費用相場ページ。" } },
          { "@type": "Question", "name": "家族や職場にバレませんか？",
            "acceptedAnswer": { "@type": "Answer", "text": "探偵業法により、探偵事務所には守秘義務があります。匿名相談も可能で、連絡方法（電話・LINE・メール）も指定できます。信頼できる業者であれば情報が漏れることはありません。" } }
        ]
      }
    ]
  })}</script>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<header class="dt-header">
  <div class="dt-header-inner">
    <a href="/detective/" class="dt-logo">
      <div class="dt-logo-icon">
        <img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;border-radius:8px;display:block;" />
      </div>
      <div class="dt-logo-wrap">
        <span>弁護士の中の人</span>
        <span class="dt-logo-sub">中の人ナビ</span>
      </div>
    </a>
    <a href={INSTAGRAM_URL} class="dt-header-insta" target="_blank" rel="noopener" data-track="header_instagram">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/></svg>
      <span>@lawyer.nakanohito</span>
    </a>
  </div>
</header>
<nav class="col-header-nav">
  <div class="col-header-nav-inner">
    <a href="/detective/flow/">診断</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cost/">費用相場</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/law/">法律の境界線</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cases/">体験談</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/column/">コラム</a>
  </div>
</nav>

<!-- ══ HERO v2 ════════════════════════════════════════════════ -->
<section class="hero-v2">
  <div class="hero-v2-inner">
    <div class="hero-v2-copy">
      <span class="hero-v2-badge">法律事務所の元事務員が教える、浮気・不倫の全選択肢</span>
      <h1>「なんか最近、<br/>様子が<em>おかしい</em>。」<br/>その直感は、たいてい正しい。</h1>
      <p class="hero-v2-lead">探偵・GPS・弁護士・電話相談——あなたに合うのはどれ？ 何百件もの相談を見てきた経験から、選び方・費用感・法律の境界線まで、正直にお伝えします。</p>

      <div class="hero-v2-quick-actions">
        <a href="/detective/flow/" class="hero-v2-quick" data-track="hero_diag">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span>5問で診断する：自分に必要なのはどれ？</span>
          <span class="hero-v2-quick-arrow">→</span>
        </a>
        <a href="#ranking" class="hero-v2-quick" data-scroll-to="#ranking" data-track="hero_ranking">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>信頼できる探偵社3社を比較する</span>
          <span class="hero-v2-quick-arrow">→</span>
        </a>
        <a href="#bennavi-section" class="hero-v2-quick" data-scroll-to="#bennavi-section" data-track="hero_lawyer">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>
          <span>近くの不倫慰謝料に強い弁護士を探す</span>
          <span class="hero-v2-quick-arrow">→</span>
        </a>
      </div>

      <div class="hero-v2-trust">
        <div class="hero-v2-trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          匿名OK
        </div>
        <div class="hero-v2-trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          相談無料
        </div>
        <div class="hero-v2-trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          裁判対応
        </div>
        <div class="hero-v2-trust-item">
          <span class="updated-meta" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.18);color:rgba(255,255,255,.75);">
            最終更新 <strong style="color:var(--gold-lt);">{UPDATED}</strong>
          </span>
        </div>
      </div>
    </div>

    <div class="hero-v2-visual">
      <div class="hero-v2-visual-frame">
        <img src="/detective/images/hero.png" alt="弁護士の中の人" />
      </div>
    </div>
  </div>
</section>

<!-- ══ TL;DR / 結論ブロック ═══════════════════════════════════ -->
<div class="conclusion-block">
  <div class="conclusion-card">
    <div class="conclusion-card-title">浮気を疑ったら、まず何をすべき？</div>
    <p style="font-size:.88rem;line-height:1.85;color:var(--text);margin:0;">状況によって最初の一手は違います。事務所での経験から、典型的な3つのパターンをまとめました。</p>
    <div class="conclusion-list">
      <div class="conclusion-item">
        <span class="conclusion-item-num">1</span>
        <div class="conclusion-item-body"><strong>あたりが付いている人</strong>：探偵に証拠収集を依頼 → 弁護士で慰謝料請求。<a href="#ranking">3社比較を見る</a></div>
      </div>
      <div class="conclusion-item">
        <span class="conclusion-item-num">2</span>
        <div class="conclusion-item-body"><strong>確証がない／費用を抑えたい人</strong>：GPSで行動パターンを把握してから判断。<a href="#self-check">GPSの使い方</a>／<a href="/detective/law/">法律の境界線</a></div>
      </div>
      <div class="conclusion-item">
        <span class="conclusion-item-num">3</span>
        <div class="conclusion-item-body"><strong>すでに証拠を持っている人</strong>：自宅近くの不倫慰謝料に強い弁護士に相談。<a href="#bennavi-section">ベンナビ不倫慰謝料で探す</a></div>
      </div>
    </div>
  </div>
</div>

<!-- ══ 4選択肢ハブ ════════════════════════════════════════════ -->
<section class="home-section">
  <div class="home-section-inner">
    <div class="mag-section-head">
      <span class="mag-num">01</span>
      <h2><span class="mag-sub">Your options</span>あなたが選べる4つの選択肢</h2>
    </div>
    <div class="options-hub-grid">
      <a href="#ranking" class="options-hub-card" data-scroll-to="#ranking" data-track="hub_detective">
        <div class="options-hub-icon options-hub-icon--detective options-hub-icon--img"><img src="/detective/images/detective.png" alt="探偵" /></div>
        <div class="options-hub-body">
          <strong>探偵に依頼する</strong>
          <span>証拠を確実に押さえたい・慰謝料を請求したい</span>
        </div>
        <svg class="options-hub-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      <a href="/detective/gps/" class="options-hub-card" data-track="hub_gps">
        <div class="options-hub-icon options-hub-icon--gps">📍</div>
        <div class="options-hub-body">
          <strong>GPSで行動を確認</strong>
          <span>費用を抑えて、まず行動パターンを把握したい</span>
        </div>
        <svg class="options-hub-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      <a href="/detective/lawyer/" class="options-hub-card" data-track="hub_lawyer">
        <div class="options-hub-icon options-hub-icon--lawyer options-hub-icon--img"><img src="/detective/images/lawyer.png" alt="弁護士" /></div>
        <div class="options-hub-body">
          <strong>弁護士に相談</strong>
          <span>離婚・慰謝料を法的に進めたい（証拠を持ってから）</span>
        </div>
        <svg class="options-hub-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      <a href="/detective/uranai/" class="options-hub-card" data-track="hub_uranai">
        <div class="options-hub-icon options-hub-icon--uranai">🌙</div>
        <div class="options-hub-body">
          <strong>まず話を聞いてもらう</strong>
          <span>気持ちが整理できない・誰にも言えない</span>
        </div>
        <svg class="options-hub-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <p style="text-align:center;margin-top:1.5rem;"><a href="/detective/flow/" style="color:var(--navy);font-weight:700;text-decoration:underline;" data-track="hub_flow">迷っている方は5問診断へ →</a></p>
  </div>
</section>

<!-- ══ RANKING ═══════════════════════════════════════════════ -->
<section class="dt-section ranking-section home-section--alt" id="ranking">
  <div class="dt-container">
    <div class="ranking-header">
      <span class="kicker kicker-white">PERSONALLY SELECTED</span>
      <h2><span class="heading-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></span> 個人的に信頼できる探偵 3社</h2>
      <p class="ranking-header-sub">5つの基準をすべてクリアした業者のみ。実際に調査内容・報告書・料金体系を確認して厳選しました。</p>
    </div>

    <div class="ranking-cards">

      <!-- No.1 うな探偵社 -->
      <div class="ranking-card rank-1 fade-up">
        <span class="card-pr-badge">PR</span>
        <div class="rank-badge">
          <div class="rank-num">1</div>
          <div>
            <div style="font-size:.72rem;font-weight:800;color:#92400e">No.1</div>
            <div class="rank-label">コスパ重視</div>
          </div>
        </div>
        <div class="ranking-card-body">
          <div class="ranking-name">うな探偵社</div>
          <div class="ranking-badges">
            <span class="ranking-badge-tag good">不成立0円プランあり</span>
            <span class="ranking-badge-tag">成功報酬プランあり</span>
            <span class="ranking-badge-tag">分割払いOK</span>
            <span class="ranking-badge-tag good">裁判対応報告書</span>
          </div>
          <div class="eval-bars">
            <div class="eval-bar-row"><span class="eval-bar-label">費用の安さ</span><div class="eval-bar-track"><div class="eval-bar-fill" style="width:95%"></div></div></div>
            <div class="eval-bar-row"><span class="eval-bar-label">実績・信頼</span><div class="eval-bar-track"><div class="eval-bar-fill" style="width:72%"></div></div></div>
            <div class="eval-bar-row"><span class="eval-bar-label">対応の柔軟性</span><div class="eval-bar-track"><div class="eval-bar-fill" style="width:78%"></div></div></div>
          </div>
          <div class="ranking-features">
            <div class="ranking-feature">成功報酬プランで費用リスクゼロ</div>
            <div class="ranking-feature">クレカ・PayPay・分割払い対応</div>
            <div class="ranking-feature">関東3拠点・全国ネットワーク対応</div>
          </div>
          <div class="ranking-price-row"><div class="ranking-price-label">時間制</div><div class="ranking-price">7,000円/時・1名（税込）</div></div>
          <div class="ranking-price-row" style="margin-top:.4rem"><div class="ranking-price-label">成功報酬プラン</div><div class="ranking-price">証拠なし→0円</div></div>
          <div class="ranking-comment">
            <div class="ranking-comment-label">個人的な推薦コメント</div>
            <p>広告費を抑えて料金を安く維持しているタイプの事務所。業界平均（1万〜1.2万円/時）の約半額で成功報酬プランもある。代表が全国調査業協同組合の理事を務めており、公安委員会届出も確認済み。<em>「成功報酬プランは証拠が取れなかった場合の費用リスクを大幅に抑えられます」</em></p>
