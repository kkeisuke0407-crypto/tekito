<!-- ══ 4選択肢ハブ ════════════════════════════════════════════ -->
<section class="home-section" id="options">
  <div class="home-section-inner">
    <div class="mag-section-head">
      <span class="mag-num">01</span>
      <h2><span class="mag-sub">Your options</span>あなたが選べる4つの選択肢</h2>
    </div>
    <div class="options-hub-grid">
      <a href="/detective/tantei/" class="options-hub-card" data-track="hub_detective">
        <div class="options-hub-icon options-hub-icon--detective options-hub-icon--img"><img src="/detective/images/detective.png" alt="探偵" /></div>
