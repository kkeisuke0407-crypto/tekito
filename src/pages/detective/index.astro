---
const PAGE_TITLE = "探偵費用を比較｜浮気の証拠ナビ｜探偵比較・無料相談サイト";
const PAGE_DESC  = "探偵事務所の費用・実績・調査報告書の質を無料で比較。浮気調査・素行調査・証拠収集のご依頼前に、複数の探偵事務所の料金体系・追加費用・対応エリアを確認しましょう。";
const CANONICAL  = "https://vpscomparehub.com/detective/";
const OGP_IMAGE  = "https://vpscomparehub.com/og-default.svg";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "探偵費用はどのくらいかかりますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "調査内容・日数・調査員の人数・難易度によって大きく異なります。1日の調査で10〜15万円前後、数日間で30〜50万円前後が目安ですが、依頼前に必ず複数社で見積もりを取ることをおすすめします。" }
    },
    {
      "@type": "Question",
      "name": "匿名で相談できますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "はい、多くの探偵事務所では匿名・ニックネームでの相談が可能です。個人情報の入力は依頼確定後になるケースが多いため、まずは気軽にご相談ください。" }
    },
    {
      "@type": "Question",
      "name": "相談したら必ず契約しないといけませんか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "いいえ、相談・見積もりだけで終わっても問題ありません。複数社の見積もりを比べてから決断することをおすすめします。" }
    },
    {
      "@type": "Question",
      "name": "証拠は裁判で使えますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "調査報告書の品質・形式によって裁判での利用可否が変わります。依頼前に「裁判利用を想定した報告書を作成できるか」を確認することが重要です。" }
    },
    {
      "@type": "Question",
      "name": "このページは広告ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "このページには広告・アフィリエイトリンクを含みます。掲載順は報酬額だけでなく、料金の透明性・実績・調査報告書の質・対応エリアをもとに構成しています。" }
    }
  ]
};
