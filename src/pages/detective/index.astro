---
const PAGE_TITLE = "探偵費用を比較｜浮気の証拠ナビ｜探偵比較・無料相談サイト";
const PAGE_DESC  = "探偵事務所の費用・実績・調査報告書の質を無料で比較。浮気調査・素行調査・証拠収集のご依頼前に、複数の探偵事務所の料金体系・追加費用・対応エリアを確認しましょう。";
const CANONICAL  = "https://vpscomparehub.com/detective/";
const OGP_IMAGE  = "https://vpscomparehub.com/og-default.svg";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "探偵費用はどのくらいかかりますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "調査内容・日数・調査員の人数・難易度によって大きく異なります。1日の調査で10〜15万円前後、数日間で30〜50万円前後が目安ですが、依頼前に必ず複数社で見積もりを取ることをおすすめします。" }
    },
    {
      "@type": "Question",
      "name": "匿名で相談できますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "はい、多くの探偵事務所では匿名・ニックネームでの相談が可能です。個人情報の入力は依頼確定後になるケースが多いため、まずは気軽にご相談ください。" }
    },
    {
      "@type": "Question",
      "name": "相談したら必ず契約しないといけませんか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "いいえ、相談・見積もりだけで終わっても問題ありません。複数社の見積もりを比べてから決断することをおすすめします。" }
    },
    {
      "@type": "Question",
      "name": "証拠は裁判で使えますか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "調査報告書の品質・形式によって裁判での利用可否が変わります。依頼前に「裁判利用を想定した報告書を作成できるか」を確認することが重要です。" }
    },
    {
      "@type": "Question",
      "name": "このページは広告ですか？",
      "acceptedAnswer": { "@type": "Answer",
        "text": "このページには広告・アフィリエイトリンクを含みます。掲載順は報酬額だけでなく、料金の透明性・実績・調査報告書の質・対応エリアをもとに構成しています。" }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />

  <!-- OGP -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:image"       content={OGP_IMAGE} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="浮気の証拠ナビ" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <!-- Page CSS -->
  <link rel="stylesheet" href="/detective/styles.css" />

  <!-- Google Ads / GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
  </script>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<header class="dt-header">
  <div class="dt-header-inner">
    <a href="/detective/" class="dt-logo">
      <div class="dt-logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </div>
      <div class="dt-logo-wrap">
        <span>浮気の証拠ナビ</span>
        <span class="dt-logo-sub">探偵比較・無料相談サイト</span>
      </div>
    </a>
    <nav class="dt-nav">
      <a href="#ranking"  data-scroll-to="#ranking">ランキング</a>
      <a href="#cost"     data-scroll-to="#cost">費用目安</a>
      <a href="#flow"     data-scroll-to="#flow">ご利用の流れ</a>
      <a href="#faq"      data-scroll-to="#faq">FAQ</a>
    </nav>
  </div>
</header>

<!-- ══ HERO ════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="dt-container hero-inner">
    <div class="hero-copy">
      <div class="hero-badge">探偵事務所を比較して失敗しない探偵選びをサポート</div>
      <h1>浮気の証拠、<br/>自分で集める前に<br/>探偵費用を<em>比較</em>してください</h1>
      <p class="hero-sub-copy">
        探偵費用の相場は<strong>30〜90万円</strong>と幅があります。<br/>
        同じ調査でも依頼先で数十万円の差が出るため、比較が重要です。
      </p>
      <div class="hero-badges">
        <div class="hero-badge-item">
          <span class="badge-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          <span>匿名OK</span>
        </div>
        <div class="hero-badge-item">
          <span class="badge-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
          <span>相談無料</span>
        </div>
        <div class="hero-badge-item">
          <span class="badge-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
          <span>全国対応</span>
        </div>
        <div class="hero-badge-item">
          <span class="badge-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg></span>
          <span>見積もり比較</span>
        </div>
      </div>
      <a href="#" class="hero-cta" data-affiliate="matching" data-track="hero_matching" rel="nofollow sponsored">
        <span class="cta-free-badge">無料</span>
        今すぐ探偵を比較する
        <span class="hero-cta-arrow">›</span>
      </a>
    </div>
    <div class="hero-media">
      <div class="hero-media-card">
        <img
          src="/detective/images/hero.png"
          alt="探偵事務所に相談する女性のイメージ"
          class="hero-img"
          width="600"
          height="700"
          decoding="async"
        />
      </div>
    </div>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f5f6f8"/>
    </svg>
  </div>
</section>

<!-- ══ PR DISCLOSURE ═══════════════════════════════════════════ -->
<p class="pr-bar">PR｜当ページはアフィリエイトリンクを含みます</p>

<!-- ══ WARNING SECTION ══════════════════════════════════════════ -->
<section class="dt-section warning-section">
  <div class="dt-container">
    <div class="warning-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 探偵選びで失敗すると</div>
    <div class="warning-inner">
      <div class="warning-left">
        <h2>証拠も<em>お金も</em><br/>失います</h2>
        <p class="warning-lead">浮気調査は、安ければいいわけではありません。</p>
      </div>
      <div class="risk-grid">
        <div class="risk-card">
          <div class="risk-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>
          <strong>証拠として弱い<br/>写真しか撮れない</strong>
        </div>
        <div class="risk-card">
          <div class="risk-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <strong>追加料金で<br/>高額になる</strong>
        </div>
        <div class="risk-card">
          <div class="risk-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <strong>調査日を外して<br/>費用だけかかる</strong>
        </div>
        <div class="risk-card">
          <div class="risk-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
          <strong>報告書が<br/>裁判で使いにくい</strong>
        </div>
        <div class="risk-card">
          <div class="risk-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
          <strong>料金体系が<br/>不明確</strong>
        </div>
      </div>
    </div>
    <p class="warning-footer">だから、1社だけで決めるのは危険です。</p>
  </div>
</section>

<!-- ══ 5 POINTS ══════════════════════════════════════════════════ -->
<div class="divider"></div>
<section class="dt-section section-white">
  <div class="dt-container">
    <div class="section-head">
      <span class="kicker">CHECK POINTS</span>
      <h2>探偵を選ぶ前に見るべき<br/><strong style="color:var(--red)">5つのポイント</strong></h2>
    </div>
    <div class="points-grid">
      <div class="point-card">
        <div class="point-num">01</div>
        <div class="point-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
        <h3>料金体系</h3>
        <p>時間制・パック制・成功報酬制を確認</p>
      </div>
      <div class="point-card">
        <div class="point-num">02</div>
        <div class="point-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></div>
        <h3>追加費用</h3>
        <p>車両費・深夜料金・延長料金の有無</p>
      </div>
      <div class="point-card">
        <div class="point-num">03</div>
        <div class="point-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <h3>調査報告書</h3>
        <p>親告や慰謝料請求で使える内容か</p>
      </div>
      <div class="point-card">
        <div class="point-num">04</div>
        <div class="point-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div>
        <h3>実績</h3>
        <p>不倫・浮気調査の経験が多いか</p>
      </div>
      <div class="point-card">
        <div class="point-num">05</div>
        <div class="point-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        <h3>対応エリア</h3>
        <p>対象者の行動範囲に対応できるか</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ QUIZ / MATCHING ══════════════════════════════════════════ -->
<section class="quiz-section" id="matching">
  <div class="dt-container">
    <div class="section-head" style="margin-bottom:1.5rem">
      <span class="kicker kicker-white">FREE MATCHING</span>
      <h2>あなたに合う探偵を<strong style="color:var(--gold-lt)">無料</strong>で比較できます</h2>
    </div>
    <div class="quiz-grid">
      <div class="quiz-card">
        <span class="quiz-q-label">Q1 調査したい内容は？</span>
        <div class="quiz-options">
          <label class="quiz-option"><input type="radio" name="q1" /> 配偶者の浮気</label>
          <label class="quiz-option"><input type="radio" name="q1" /> 婚約者の浮気</label>
          <label class="quiz-option"><input type="radio" name="q1" /> 不倫相手の特定</label>
          <label class="quiz-option"><input type="radio" name="q1" /> 証拠収集</label>
        </div>
      </div>
      <div class="quiz-card">
        <span class="quiz-q-label">Q2 証拠はありますか？</span>
        <div class="quiz-options">
          <label class="quiz-option"><input type="radio" name="q2" /> LINEだけある</label>
          <label class="quiz-option"><input type="radio" name="q2" /> 写真がある</label>
          <label class="quiz-option"><input type="radio" name="q2" /> 怪しいだけ</label>
          <label class="quiz-option"><input type="radio" name="q2" /> すでに自白している</label>
        </div>
      </div>
      <div class="quiz-card">
        <span class="quiz-q-label">Q3 予算感は？</span>
        <div class="quiz-options">
          <label class="quiz-option"><input type="radio" name="q3" /> 10万円以内</label>
          <label class="quiz-option"><input type="radio" name="q3" /> 30万円以内</label>
          <label class="quiz-option"><input type="radio" name="q3" /> 50万円以内</label>
          <label class="quiz-option"><input type="radio" name="q3" /> まだ決めていない</label>
        </div>
      </div>
      <div class="quiz-cta-card">
        <span class="quiz-cta-free">完全無料</span>
        <h3>無料で<br/>比較してみる</h3>
        <p class="quiz-cta-sub">最適な探偵事務所をご案内します</p>
        <a href="#" class="quiz-cta-btn" data-affiliate="matching" data-track="quiz_matching" rel="nofollow sponsored">
          無料で比較する ›
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══ COST + WHO ════════════════════════════════════════════════ -->
<div class="divider"></div>
<section class="dt-section section-white" id="cost">
  <div class="dt-container">
    <div class="cost-who-grid">
      <div>
        <div class="section-head" style="text-align:left;margin-bottom:1rem">
          <span class="kicker">COST GUIDE</span>
          <h2>探偵費用の目安</h2>
        </div>
        <div class="cost-card">
          <div class="cost-card-head">調査日数別・費用の参考範囲</div>
          <table class="cost-table">
            <tbody>
              <tr>
                <td>1日だけの調査</td>
                <td class="cost-range">10〜15万円前後</td>
              </tr>
              <tr>
                <td>数日間の調査</td>
                <td class="cost-range">30〜50万円前後</td>
              </tr>
              <tr>
                <td>長期・難航する調査</td>
                <td class="cost-range">100万円以上に<br/>なることも</td>
              </tr>
            </tbody>
          </table>
          <p class="cost-note">総額相場の目安は30〜90万円（平均約40万円）。依頼先や調査内容で大きく変わります。</p>
        </div>
        <div class="plan-type-card">
          <div class="cost-card-head">料金プランの種類</div>
          <div class="plan-type-grid">
            <div class="plan-type-item">
              <div class="plan-type-name">時間制</div>
              <div class="plan-type-price">1h 7,000〜15,000円</div>
              <p>調査時間に応じて課金。短期・確認調査向き。</p>
            </div>
            <div class="plan-type-item">
              <div class="plan-type-name">パック制</div>
              <div class="plan-type-price">20h〜 35万円前後〜</div>
              <p>まとめて時間を購入。長期調査でお得になる場合あり。</p>
            </div>
            <div class="plan-type-item plan-type-item--highlight">
              <div class="plan-type-name">成功報酬制</div>
              <div class="plan-type-price">証拠取得時のみ課金</div>
              <p>証拠が取れなかった場合は費用ゼロ。リスクを抑えたい方向き。</p>
            </div>
          </div>
        </div>
      </div>
      <div>
        <div class="section-head" style="text-align:left;margin-bottom:1rem">
          <span class="kicker">WHO SHOULD CONSULT</span>
          <h2>こんな方は、探偵に<br/>相談する価値があります</h2>
        </div>
        <div class="who-card">
          <div class="who-card-head">探偵相談に向いている状況</div>
          <div class="who-list">
            <div class="who-item">
              <div class="who-check">✓</div>
              <span>会う曜日や時間帯がだいたい分かる</span>
            </div>
            <div class="who-item">
              <div class="who-check">✓</div>
              <span>相手の勤務先や行動範囲が分かる</span>
            </div>
            <div class="who-item">
              <div class="who-check">✓</div>
              <span>LINEやレシートなど怪しい証拠がある</span>
            </div>
            <div class="who-item">
              <div class="who-check">✓</div>
              <span>慰謝料請求や離婚を考えている</span>
            </div>
            <div class="who-item">
              <div class="who-check">✓</div>
              <span>自分で尾行して失敗したくない</span>
            </div>
