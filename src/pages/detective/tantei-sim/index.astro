  <span class="sticky-label">予算がわかったら</span>
  <a href="/detective/tantei/" class="sticky-btn" data-track="sticky_tanteisim_tantei">探偵社を比較する →</a>
  <button class="sticky-close" id="sticky-close" aria-label="閉じる">✕</button>
</div>

<script src="/detective/app.js" is:inline defer></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('ts-calc');
    if (!btn) return;

    function yen(n) { return n.toLocaleString('ja-JP'); }

    btn.addEventListener('click', function () {
      var plan  = document.getElementById('ts-plan').value;
      var staff = document.getElementById('ts-staff').value;
      var hours = document.getElementById('ts-hours').value;
      var days  = document.getElementById('ts-days').value;
      var area  = document.getElementById('ts-area').value;

      if (!plan || !staff || !hours || !days || !area) {
        alert('すべての質問にお答えください。');
        return;
      }
      var staffN = parseInt(staff, 10);
      var hoursN = parseInt(hours, 10);
      var daysN  = parseInt(days, 10);

      var unit = 8000; // 1名1時間の目安
      var base = unit * staffN * hoursN * daysN;

      var planFactor = 1, planLabel = '';
      if (plan === 'time')    { planFactor = 1.0; planLabel = '時間制'; }
      if (plan === 'pack')    { planFactor = daysN >= 2 ? 0.85 : 1.05; planLabel = 'パック制'; }
      if (plan === 'success') { planFactor = 1.15; planLabel = '成功報酬制（着手金＋報酬の合計目安）'; }

      var areaAdd = area === 'far' ? 50000 : 0;

      var raw = base * planFactor + areaAdd;
      var low  = Math.max(50000, Math.round((raw * 0.85) / 10000) * 10000);
      var high = Math.round((raw * 1.2) / 10000) * 10000;
      if (high <= low) high = low + 100000;

      var amount = document.getElementById('ts-amount');
      amount.innerHTML = 'およそ ' + yen(low) + '〜' + yen(high) + ' 円';

      var breakdown = document.getElementById('ts-breakdown');
      var rows = [];
      rows.push('<div class="ms-row"><span>料金プラン</span><strong>' + planLabel + '</strong></div>');
      rows.push('<div class="ms-row"><span>調査規模</span><strong>' + staffN + '名 × ' + hoursN + '時間 × ' + daysN + '日</strong></div>');
      rows.push('<div class="ms-row"><span>エリア</span><strong>' + (area === 'far' ? '遠方（出張費込み）' : '近隣') + '</strong></div>');
      breakdown.innerHTML = rows.join('');

      var note = document.getElementById('ts-note');
      var msgs = [];
      if (plan === 'pack' && daysN >= 2) {
        msgs.push('複数日の調査は<strong>パック制が割安</strong>になりやすいです。総額が決まっているので予算も読みやすい。');
      } else if (plan === 'time') {
        msgs.push('時間制は<strong>短時間で証拠が取れれば割安</strong>。行動パターンを絞れているほど有利です。');
      } else if (plan === 'success') {
        msgs.push('成功報酬制は<strong>証拠が取れなければ0円のプラン</strong>もあり、リスクを抑えたい方向け。着手金の有無は要確認。');
      }
      msgs.push('※これは一般的な料金体系にもとづく<strong>概算</strong>です。実額は難易度・地域・事務所で変わります。必ず無料見積もりで確認してください。');
      note.innerHTML = msgs.join('<br/>');

      var result = document.getElementById('ts-result');
      result.classList.add('visible');
      result.scrollIntoView({ behavior: 'smooth', block: 'center' });

      if (typeof gtag === 'function') gtag('event', 'tanteisim_calc_done', { plan: plan, days: days });
      if (window.dataLayer) window.dataLayer.push({ event: 'tanteisim_calc_done', plan: plan, days: days });
    });
  });
</script>

</body>
</html>
