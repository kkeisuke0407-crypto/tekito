---
import { situations } from '../../../data/detective-situations.js';

export function getStaticPaths() {
  return Object.keys(situations).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const sit = situations[slug];
if (!sit) throw new Error(`Unknown situation: ${slug}`);

const CANONICAL = `https://vpscomparehub.com/detective/situation/${slug}/`;
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-06-15";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{sit.title}</title>
  <meta name="description" content={sit.desc} />
  <link rel="canonical" href={CANONICAL} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={sit.title} />
  <meta property="og:description" content={sit.desc} />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="弁護士の中の人" />
  <meta property="og:image"     content="https://vpscomparehub.com/detective/images/hero.png" />
  <meta name="twitter:card"     content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Noto+Serif+JP:wght@700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/detective/styles.css?v=20260615g" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "TOP", "item": "https://vpscomparehub.com/detective/" },
      { "@type": "ListItem", "position": 2, "name": sit.label, "item": CANONICAL }
    ]
  })} />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
  </script>
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","wt0koam10v");
  </script>
</head>
<body class="lp-page lp-page-v2">

<header class="dt-header">
  <div class="dt-header-inner">
    <a href="/detective/" class="dt-logo">
      <div class="dt-logo-icon"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;border-radius:8px;display:block;" /></div>
      <div class="dt-logo-wrap"><span>弁護士の中の人</span><span class="dt-logo-sub">中の人ナビ</span></div>
    </a>
    <a href={INSTAGRAM_URL} class="dt-header-insta" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/></svg>
      <span>@lawyer.nakanohito</span>
    </a>
  </div>
</header>

<nav class="col-header-nav">
  <div class="col-header-nav-inner">
    <a href="/detective/start/">最初に</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/flow/">診断</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cost/">費用相場</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/law/">法律の境界線</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cases/">体験談</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/column/">コラム</a>
  </div>
</nav>

<div class="lp-hero">
  <div class="lp-hero-meta">
    <span class="updated-meta">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      最終更新 <strong>{UPDATED}</strong>
    </span>
  </div>
  <span class="hero-v2-badge" style="display:inline-block;margin-bottom:.5rem;">{sit.badge}</span>
  <h1 set:html={sit.h1}></h1>
  <p class="lp-hero-sub">{sit.sub}</p>
</div>

<div class="lp-body">
  <nav class="lp-breadcrumb" aria-label="パンくず">
    <a href="/detective/">TOP</a>
    <span class="sep">›</span>
    <strong>{sit.label}</strong>
  </nav>

  <div class="tldr-card">
    <div class="tldr-title">このページの内容</div>
    <p class="tldr-body" set:html={sit.intro}></p>
  </div>

  <div class="lp-card">
    <h2>このタイプで起きやすい失敗パターン</h2>
    <p>事務所での実感として、<strong>「やるべきこと」より先に「やってはいけないこと」を知る</strong>方が、結果的に被害が小さく済みます。{sit.label}でとくに注意したい4つを整理しました。</p>
    {sit.pitfalls.map((p, i) => (
      <div class="lp-step">
        <div class="lp-step-num">×</div>
        <div class="lp-step-body">
          <strong>{p.strong}</strong>
          <span>{p.note}</span>
        </div>
      </div>
    ))}
    <div class="lp-warn">
      <div class="lp-warn-title">このタイプ特有のコツ</div>
      <p set:html={sit.tip}></p>
    </div>
  </div>

  <div class="lp-card">
    <h2>次にやるべきこと（3パターン）</h2>
    <p>{sit.label}を疑っているとき、次にやるべきことは「状況の整理」「証拠の準備」「専門家への相談」の3つに分かれます。当てはまるところから読んでみてください。</p>
    <div class="conclusion-card" style="margin-top:1rem;">
      <div class="conclusion-list">
        <div class="conclusion-item"><span class="conclusion-item-num">A</span><div class="conclusion-item-body"><strong>まだ確信がない・気持ちが整理できない</strong><br/><a href="/detective/start/">「最初にやること」ガイド</a>／<a href="/detective/flow/">5問診断</a>で順序を整理／<a href="/detective/uranai/">電話占い・カウンセリングで話を聞いてもらう</a></div></div>
        <div class="conclusion-item"><span class="conclusion-item-num">B</span><div class="conclusion-item-body"><strong>証拠を集めたい・自分でできる範囲を知りたい</strong><br/><a href="/detective/shouko/">使える証拠の判定</a>／<a href="/detective/gps/">GPS活用ガイド</a>／<a href="/detective/law/">合法・違法の境界</a></div></div>
        <div class="conclusion-item"><span class="conclusion-item-num">C</span><div class="conclusion-item-body"><strong>確実な証拠を取りたい・慰謝料も視野</strong><br/><a href="/detective/tantei/">探偵社の選び方</a>／<a href="/detective/isharyo-sim/">慰謝料の目安シミュレーター</a>／<a href="/detective/lawyer/">弁護士相談ガイド</a></div></div>
      </div>
    </div>
  </div>

  <div class="lp-cta-block">
    <h3>あなたに必要な選択肢を整理する</h3>
    <p>5問の質問に答えるだけで、いまのあなたに合った進め方が分かります。匿名・無料・1分。</p>
    <a href={sit.cta_main} class="lp-cta-block-btn" data-track={`situation_${slug}_main`}>{sit.cta_main_label} →</a>
    <p class="lp-cta-block-note">{sit.cta_sub_label}</p>
  </div>

  <div class="lp-related">
    <h3>他の立場の方向けガイド</h3>
    <div class="col-grid">
      {Object.entries(situations).filter(([s]) => s !== slug).slice(0, 3).map(([s, item]) => (
        <a href={`/detective/situation/${s}/`} class="col-card">
          <span class="col-card-badge comparison">{item.badge}</span>
          <h3>{item.label}を疑ったときに</h3>
          <p>{item.sub.substring(0, 60)}…</p>
        </a>
      ))}
      <a href="/detective/start/" class="col-card">
        <span class="col-card-badge experience">ガイド</span>
        <h3>最初にやること完全ガイド</h3>
        <p>立場を問わず、共通の進め方を整理。</p>
      </a>
    </div>
  </div>

</div>

<footer class="dt-footer">
  <div class="dt-footer-inner">
    <div class="dt-footer-logo">
      <div class="dt-footer-logo-icon" style="padding:0;overflow:hidden;"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;" /></div>
      <span>弁護士の中の人</span>
    </div>
    <p class="dt-footer-text">
      Instagram「弁護士の中の人（@lawyer.nakanohito）」の公式サイト。<br/>
      法律事務所の元事務員が、浮気・不倫で悩む方へ正直な情報をお届けしています。<br/>
      <span style="font-size:.75rem;color:rgba(255,255,255,.35)">当サイトは一部にアフィリエイトリンクを含みます。</span>
    </p>
    <div class="dt-footer-links">
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener">Instagram</a>
      <a href="/detective/start/">最初にやること</a>
      <a href="/detective/flow/">5問診断</a>
      <a href="/detective/cost/">費用相場</a>
      <a href="/detective/law/">法律の境界線</a>
      <a href="/detective/cases/">体験談</a>
      <a href="/detective/glossary/">用語集</a>
      <a href="/detective/column/">コラム</a>
      <a href="/detective/about/">中の人について</a>
      <a href="/detective/privacy/">プライバシーポリシー</a>
      <a href="/detective/operator/">運営者情報</a>
    </div>
    <p class="dt-footer-copy">© 2026 弁護士の中の人</p>
  </div>
</footer>

<div class="sticky-cta-bar" id="sticky-cta">
  <span class="sticky-label">まずは状況を整理</span>
  <a href="/detective/start/" class="sticky-btn" data-track={`sticky_situation_${slug}`}>「最初にやること」を読む →</a>
  <button class="sticky-close" id="sticky-close" aria-label="閉じる">✕</button>
</div>

<script src="/detective/app.js" is:inline defer></script>

</body>
</html>
