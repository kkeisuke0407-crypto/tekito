const PAGE_DESC  = "離婚が成立したあとにやる手続きを、お金（年金分割・養育費・ひとり親の手当）／名義・生活（姓・戸籍・保険・住まい）／子どもとの関係（面会交流）に分けて、法律事務所の元事務員が整理。申請しないともらえないお金や、期限のある手続きを見逃さないためのチェックリストです。";
const CANONICAL  = "https://vpscomparehub.com/detective/rikon-go/";
