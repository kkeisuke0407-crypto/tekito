---
const title = "運営者情報｜中の人ナビ（弁護士の中の人）";
const description = "「中の人ナビ」（弁護士の中の人）の運営者情報。サイト概要、運営目的、お問い合わせ先、掲載基準・広告表記をまとめています。";
const SITE_URL = "https://vpscomparehub.com/detective/";
const CANONICAL = "https://vpscomparehub.com/detective/operator/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={CANONICAL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="弁護士の中の人" />
  <meta property="og:image" content="https://vpscomparehub.com/detective/images/hero.png" />
  <meta name="twitter:card" content="summary_large_image" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "運営者情報｜中の人ナビ",
    "url": CANONICAL,
    "description": description,
    "publisher": {
      "@type": "Organization",
      "name": "中の人ナビ",
      "url": SITE_URL,
      "logo": "https://vpscomparehub.com/detective/images/logo-icon.png",
      "sameAs": [INSTAGRAM_URL]
    }
  })} />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "TOP", "item": SITE_URL },
      { "@type": "ListItem", "position": 2, "name": "運営者情報", "item": CANONICAL }
    ]
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Noto Sans JP", -apple-system, BlinkMacSystemFont, sans-serif;
      background: #f5f6f8; color: #1a1e2a;
      font-size: 15px; line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }
    .wrap { max-width: 680px; margin: 0 auto; min-height: 100vh; }

    /* Header */
    .topbar {
      background: #0d1b2e;
      padding: 14px 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .topbar-icon {
      width: 26px; height: 26px; border-radius: 7px;
      background: linear-gradient(135deg, #c9922a, #e07b30);
      display: flex; align-items: center; justify-content: center;
      color: #fff; flex-shrink: 0;
    }
    .topbar-icon svg { width: 14px; height: 14px; display: block; }
    .topbar-name { font-weight: 900; font-size: 14px; color: #fff; }
    .topbar-back {
      margin-left: auto; font-size: 12px;
      color: rgba(255,255,255,.55); text-decoration: none;
    }
    .topbar-back:hover { color: #fff; text-decoration: underline; }

    /* Content */
    .content { padding: 2rem 1.5rem 3rem; }
    .page-title {
      font-size: 1.4rem; font-weight: 900;
      letter-spacing: -.02em;
      margin-bottom: 2rem;
      padding-bottom: .75rem;
      border-bottom: 2px solid #0d1b2e;
    }

    .section { margin-bottom: 2rem; }
    .section-title {
      font-size: .78rem; font-weight: 800;
      letter-spacing: .1em;
      color: #64748b;
      margin-bottom: .75rem;
      text-transform: uppercase;
    }
    .info-table { width: 100%; border-collapse: collapse; }
    .info-table tr { border-bottom: 1px solid #e2e8f0; }
    .info-table th {
      width: 140px; padding: .75rem 0;
      font-size: .82rem; font-weight: 700;
      color: #64748b; text-align: left;
      vertical-align: top;
    }
    .info-table td {
      padding: .75rem 0 .75rem 1rem;
      font-size: .88rem; color: #1a1e2a;
    }

    /* Nav links */
    .nav-list { display: flex; flex-direction: column; gap: .5rem; }
    .nav-link {
      display: inline-flex; align-items: center; gap: .35rem;
      font-size: .88rem; font-weight: 600;
      color: #1d4ed8; text-decoration: none;
    }
    .nav-link:hover { text-decoration: underline; }

    /* Footer */
    .page-footer {
      background: #0d1b2e; color: rgba(255,255,255,.5);
      text-align: center; padding: 1.5rem;
      font-size: .75rem;
    }
    .page-footer a { color: rgba(255,255,255,.5); }
    .page-footer a:hover { color: #fff; }
  </style>

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
  </script>
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","wt0koam10v");
  </script>
</head>
<body>
<div class="wrap">

  <div class="topbar">
    <div class="topbar-icon" style="padding:0;overflow:hidden;">
      <img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;display:block;" />
    </div>
    <span class="topbar-name">弁護士の中の人</span>
    <a href="/detective/" class="topbar-back">← トップへ戻る</a>
  </div>

  <div class="content">
    <h1 class="page-title">運営者情報</h1>

    <div class="section">
      <p class="section-title">基本情報</p>
      <table class="info-table">
        <tbody>
          <tr>
            <th>サイト名</th>
            <td>中の人ナビ（弁護士の中の人）</td>
          </tr>
          <tr>
            <th>URL</th>
            <td><a href={SITE_URL} style="color:#1d4ed8;text-decoration:none;">{SITE_URL}</a></td>
          </tr>
          <tr>
            <th>運営者</th>
            <td>「弁護士の中の人」（法律事務所で約10年勤務した元事務員）</td>
          </tr>
          <tr>
            <th>運営開始</th>
            <td>2025年</td>
          </tr>
          <tr>
            <th>運営目的</th>
            <td>浮気・不倫で悩む方への正直な情報提供（探偵・GPS・弁護士・電話占い・公認心理師カウンセリングの全選択肢を整理）</td>
          </tr>
          <tr>
            <th>Instagram</th>
            <td><a href={INSTAGRAM_URL} target="_blank" rel="noopener" style="color:#1d4ed8;text-decoration:none;">@lawyer.nakanohito</a></td>
          </tr>
          <tr>
            <th>お問い合わせ</th>
            <td>Instagram DM（<a href={INSTAGRAM_URL} target="_blank" rel="noopener" style="color:#1d4ed8;text-decoration:none;">@lawyer.nakanohito</a>）にてお受けしています。<br/><span style="font-size:.8rem;color:#64748b;">※ 個別の法律相談には対応できません。弁護士へご相談ください。</span></td>
          </tr>
          <tr>
            <th>最終更新</th>
            <td>2026年6月</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="section">
      <p class="section-title">掲載基準・広告表記</p>
      <p style="font-size:.88rem;line-height:1.8;color:#475569">
        当サイトに掲載している探偵事務所は、アフィリエイトプログラムに参加しており、リンク経由で申し込みが発生した場合に報酬を受け取ることがあります。<br/>
        掲載順・紹介内容は報酬額だけでなく、料金の透明性・実績・調査報告書の品質・対応エリアの広さをもとに構成しています。<br/>
        料金は調査内容・地域・難易度によって異なります。記載の金額は参考目安であり、申し込み前に必ず各社に直接お見積もりをご確認ください。
      </p>
    </div>

    <div class="section">
      <p class="section-title">関連ページ</p>
      <div class="nav-list">
        <a href="/detective/about/" class="nav-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="4"/><path d="M5.5 21a6.5 6.5 0 0 1 13 0"/></svg>
          中の人について（運営者プロフィール）
        </a>
        <a href="/detective/privacy/" class="nav-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          プライバシーポリシー
        </a>
        <a href="/detective/" class="nav-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          トップページへ戻る
        </a>
      </div>
    </div>
  </div>

  <div class="page-footer">
    <p>© 2026 弁護士の中の人</p>
  </div>

</div>
</body>
</html>
