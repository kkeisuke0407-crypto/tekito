---
const PAGE_TITLE = "浮気・不倫 発覚から解決までの全体ロードマップ｜中の人ナビ";
const PAGE_DESC  = "浮気を疑ってから解決するまでの全体像を1枚に。気持ちの整理→証拠→専門家→慰謝料・離婚まで、各ステップでやるべきことと使えるツール・ガイドを、法律事務所の元事務員がまとめました。";
const CANONICAL  = "https://vpscomparehub.com/detective/roadmap/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-06-22";

const steps = [
  {
    phase: "STEP 1",
    title: "気持ちを整理する",
    lead: "疑いを持った直後は、誰でも冷静でいられません。まず自分の心を守ることから。焦って問い詰めるのは厳禁です。",
    links: [
      { href: "/detective/check/", label: "浮気チェック診断（20の兆候）" },
      { href: "/detective/mental-care/", label: "心を壊さないためのセルフケア" },
      { href: "/detective/uranai/", label: "話せる相談先（電話占い・カウンセリング）" },
      { href: "/detective/start/", label: "最初にやること完全ガイド" },
    ]
  },
  {
    phase: "STEP 2",
    title: "方向性を決める",
    lead: "「確かめたい」「離婚したい」「やり直したい」——ゴールによって進む道が変わります。まず自分がどうしたいかを整理。",
    links: [
      { href: "/detective/flow/", label: "5問診断で進め方を見つける" },
      { href: "/detective/situation/husband/", label: "立場別ガイド（夫・妻・恋人・単身赴任・産後・熟年）" },
      { href: "/detective/shufuku/", label: "やり直したい方へ（修復ガイド）" },
    ]
  },
  {
    phase: "STEP 3",
    title: "証拠を確保する",
    lead: "慰謝料・離婚を視野に入れるなら、証拠が土台になります。相手に消される前に、合法な範囲で保全を。",
    links: [
      { href: "/detective/shouko-hozen/", label: "証拠保全チェックリスト（今日やること）" },
      { href: "/detective/shouko/", label: "証拠タイプ別の判定ガイド" },
      { href: "/detective/law/", label: "合法・違法の境界線" },
      { href: "/detective/gps/", label: "GPS活用ガイド" },
    ]
  },
  {
    phase: "STEP 4",
    title: "プロに依頼する",
    lead: "決定的な証拠は自力では難しい領域。信頼できる探偵に、費用感をつかんでから相談を。",
    links: [
      { href: "/detective/tantei-sim/", label: "調査費用シミュレーター" },
      { href: "/detective/tantei/", label: "信頼できる探偵社の選び方（4社比較）" },
      { href: "/detective/cost/", label: "浮気調査の費用相場" },
      { href: "/detective/checklist/", label: "依頼前の準備チェックリスト" },
    ]
  },
  {
    phase: "STEP 5",
    title: "慰謝料・離婚を進める",
    lead: "証拠が固まったら、いよいよ請求・離婚の段階。弁護士の力が効いてきます。請求された側の対応もここに。",
    links: [
      { href: "/detective/isharyo-sim/", label: "慰謝料の目安シミュレーター" },
      { href: "/detective/naiyo-shomei/", label: "内容証明ジェネレーター" },
      { href: "/detective/rikon-nagare/", label: "離婚の進め方 完全ガイド" },
      { href: "/detective/lawyer/", label: "弁護士相談ガイド" },
      { href: "/detective/seikyu-sareta/", label: "慰謝料を請求された側の対応" },
    ]
  },
  {
    phase: "STEP 6",
    title: "その後の生活を立て直す",
    lead: "離婚後は、申請しないともらえないお金があります。制度を知って、新しい生活の足場を固めましょう。",
    links: [
      { href: "/detective/money-sim/", label: "離婚後にもらえるお金シミュレーター" },
      { href: "/detective/cases/", label: "体験談（実例から学ぶ）" },
      { href: "/detective/mental-care/", label: "心のセルフケア" },
    ]
  },
];
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC} />
  <link rel="canonical" href={CANONICAL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={PAGE_TITLE} />
  <meta property="og:description" content={PAGE_DESC} />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="弁護士の中の人" />
  <meta property="og:image"     content="https://vpscomparehub.com/detective/images/hero.png" />
  <meta name="twitter:card"     content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&family=Noto+Serif+JP:wght@700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/detective/styles.css?v=20260622g" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "TOP", "item": "https://vpscomparehub.com/detective/" },
      { "@type": "ListItem", "position": 2, "name": "解決までのロードマップ", "item": CANONICAL }
    ]
  })} />

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
  </script>
  <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","wt0koam10v");
  </script>
</head>
<body class="lp-page lp-page-v2">

<header class="dt-header">
  <div class="dt-header-inner">
    <a href="/detective/" class="dt-logo">
      <div class="dt-logo-icon"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;border-radius:8px;display:block;" /></div>
      <div class="dt-logo-wrap"><span>弁護士の中の人</span><span class="dt-logo-sub">中の人ナビ</span></div>
    </a>
    <a href={INSTAGRAM_URL} class="dt-header-insta" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/></svg>
      <span>@lawyer.nakanohito</span>
    </a>
  </div>
</header>

<nav class="col-header-nav">
  <div class="col-header-nav-inner">
    <a href="/detective/start/">最初に</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/flow/">診断</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cost/">費用相場</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/law/">法律の境界線</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/cases/">体験談</a>
    <span class="col-nav-sep">|</span>
    <a href="/detective/faq/">Q&A</a>
  </div>
</nav>

<div class="lp-hero">
  <div class="lp-hero-meta">
    <span class="updated-meta">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      最終更新 <strong>{UPDATED}</strong>
    </span>
  </div>
  <h1>発覚から解決までの<br/>全体ロードマップ</h1>
  <p class="lp-hero-sub">浮気を疑ってから解決するまでの流れを、6ステップで整理しました。<strong>あなたが今いる場所</strong>から、必要なガイド・ツールにたどり着けます。迷ったら、ここに戻ってきてください。</p>
</div>

<div class="lp-body">

  <nav class="lp-breadcrumb" aria-label="パンくず">
    <a href="/detective/">TOP</a>
    <span class="sep">›</span>
    <strong>解決までのロードマップ</strong>
  </nav>

  <div class="tldr-card">
    <div class="tldr-title">全体の流れ</div>
    <p class="tldr-body"><strong>① 気持ちを整理 → ② 方向性を決める → ③ 証拠を確保 → ④ プロに依頼 → ⑤ 慰謝料・離婚 → ⑥ 生活を立て直す</strong>。すべてを一気にやる必要はありません。今のあなたの段階から、一歩ずつ進めば大丈夫です。</p>
  </div>

  {steps.map(step => (
    <div class="lp-card rm-step">
      <div class="rm-phase">{step.phase}</div>
      <h2>{step.title}</h2>
      <p>{step.lead}</p>
      <div class="rm-links">
        {step.links.map(l => (
          <a href={l.href} class="rm-link" data-track="roadmap_link">
            <span>{l.label}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        ))}
      </div>
    </div>
  ))}

  <div class="lp-cta-block">
    <h3>どこから始めればいいか分からない方へ</h3>
    <p>ステップが多くて迷ったら、5問の診断で「いまのあなたに合った一手」を提案します。匿名・無料・1分です。</p>
    <a href="/detective/flow/" class="lp-cta-block-btn" data-track="roadmap_to_flow">5問診断で進め方を見つける →</a>
    <p class="lp-cta-block-note">気持ちの整理から証拠・慰謝料まで、状況別に案内します</p>
  </div>

</div>

<footer class="dt-footer">
  <div class="dt-footer-inner">
    <div class="dt-footer-logo">
      <div class="dt-footer-logo-icon" style="padding:0;overflow:hidden;"><img src="/detective/images/logo-icon.png" alt="弁護士の中の人" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;" /></div>
      <span>弁護士の中の人</span>
    </div>
    <p class="dt-footer-text">
      Instagram「弁護士の中の人（@lawyer.nakanohito）」の公式サイト。<br/>
      法律事務所の元事務員が、浮気・不倫で悩む方へ正直な情報をお届けしています。<br/>
      <span style="font-size:.75rem;color:rgba(255,255,255,.35)">当サイトは一部にアフィリエイトリンクを含みます。</span>
    </p>
    <div class="dt-footer-links">
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener">Instagram</a>
      <a href="/detective/start/">最初にやること</a>
      <a href="/detective/flow/">5問診断</a>
      <a href="/detective/tantei/">探偵社の選び方</a>
      <a href="/detective/lawyer/">弁護士相談</a>
      <a href="/detective/faq/">よくある質問</a>
      <a href="/detective/column/">コラム</a>
      <a href="/detective/about/">中の人について</a>
      <a href="/detective/privacy/">プライバシーポリシー</a>
      <a href="/detective/operator/">運営者情報</a>
    </div>
    <p class="dt-footer-copy">© 2026 弁護士の中の人</p>
  </div>
</footer>

<div class="sticky-cta-bar" id="sticky-cta">
  <span class="sticky-label">迷ったら5問診断</span>
  <a href="/detective/flow/" class="sticky-btn" data-track="sticky_roadmap_flow">進め方を見つける →</a>
  <button class="sticky-close" id="sticky-close" aria-label="閉じる">✕</button>
</div>

<script src="/detective/app.js" is:inline defer></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var sticky = document.getElementById('sticky-cta');
    if (!sticky) return;
    var dismissed = false;
    document.getElementById('sticky-close').addEventListener('click', function() {
      dismissed = true; sticky.classList.remove('visible');
    });
    window.addEventListener('scroll', function() {
      if (dismissed) return;
      sticky.classList.toggle('visible', window.scrollY > window.innerHeight * 0.6);
    }, { passive: true });
  });
</script>

</body>
</html>
