---
const PAGE_TITLE = "弁護士事務所の元事務員が明かす、浮気・不倫の本音10｜誰も教えてくれない話｜中の人ナビ";
const PAGE_DESC  = "慰謝料の相場、探偵の選び方、弁護士との付き合い方——ネットには「きれいごと」があふれています。法律事務所で約10年、何百件もの案件を間近で見てきた元事務員が、表では言われない“本音”を10個だけ、正直に打ち明けます。";
const CANONICAL  = "https://vpscomparehub.com/detective/honne/";
const INSTAGRAM_URL = "https://www.instagram.com/lawyer.nakanohito/";
const UPDATED = "2026-06-22";

const groups = [
  {
    label: "お金・慰謝料の本音",
    items: [
      {
        title: "「相場◯◯万円」は、ほとんど当てになりません",
        body: "どのサイトも「不倫慰謝料の相場は50〜300万円」と書きます。でも事務所で見てきた現実は、同じような不倫でも、100万で終わる人もいれば300万取れる人もいた。差を生むのは相場ではなく、<strong>証拠の強さ・相手の資力・交渉のうまさ</strong>の3つ。相場を鵜呑みにして「これくらいか」と諦めるのが、いちばんもったいないです。",
        take: "まず自分のケースの目安を出し、相場ではなく“交渉材料”で考える。",
        cta: { href: "/detective/isharyo-sim/", label: "慰謝料の目安を試算する →", track: "honne_isharyosim" },
      },
      {
        title: "「一括で満額」取れる人は、実は少数派",
        body: "請求書に書く金額と、実際に振り込まれる金額は別物です。相手が「そんな大金ない」と言えば、現実は分割・減額の攻防になります。だからこそ、<strong>最初の請求額の設定と、それを支える証拠</strong>が効いてくる。弱気な請求額を出すと、そこからさらに値切られます。",
        take: "最初の請求は、証拠に見合う“強気の適正額”から入るのが定石。",
        cta: { href: "/detective/naiyo-shomei/", label: "内容証明の作り方を見る →", track: "honne_naiyo" },
      },
    ],
  },
  {
    label: "証拠・探偵の本音",
    items: [
      {
        title: "自分で撮った証拠、9割は「使えない」で終わります",
        body: "「決定的な写真が撮れた！」と持ってくる方、多いです。でも入手方法が違法だったり、決定力が足りなかったりで、裁判では使えないことがほとんど。しかも一度自分で動いて相手に警戒されると、<strong>その後プロが入っても証拠が取れなくなる</strong>。これが事務所でいちばん多かった“後悔”でした。",
        take: "下調べは自分で、決定的な瞬間はプロに。順番を逆にしない。",
        cta: { href: "/detective/tantei/", label: "失敗しない探偵の選び方 →", track: "honne_tantei" },
      },
      {
        title: "探偵に足元を見られるのは「焦っている人」",
        body: "同じ調査でも、請求額に大きな差が出ます。高くなりがちなのは、相場を知らず、日程も絞れず、「とにかく早く」と焦っている人。逆に、<strong>怪しい曜日・時間帯を自分で絞ってから依頼する人</strong>は、調査時間が短く済んで費用も抑えられます。探偵は“動く時間”で料金が決まるからです。",
        take: "依頼前に行動パターンの“あたり”をつける。それだけで数十万変わることも。",
        cta: { href: "/detective/tantei-sim/", label: "調査費用の目安を試算する →", track: "honne_tanteisim" },
      },
      {
        title: "良い探偵かどうかは「報告書」を見ればわかる",
        body: "事務所には色々な探偵事務所の報告書が届きました。裁判で通用するのは、日時・場所・状況が客観的に、写真つきで整理されたもの。逆に“使えない”報告書もありました。見分け方はシンプルで、<strong>契約前に報告書のサンプルを見せてもらえるか</strong>。渋る業者は避けたほうが無難です。",
        take: "契約前に「報告書のサンプルを見せて」と必ず聞く。",
        cta: { href: "/detective/checklist/", label: "依頼前チェックリスト →", track: "honne_checklist" },
      },
    ],
  },
  {
    label: "弁護士・手続きの本音",
    items: [
      {
        title: "弁護士が“本気を出す”依頼者には、共通点があります",
        body: "同じ弁護士でも、依頼者によって動きの本気度が変わる——そう感じることがありました。スイッチが入りやすいのは、<strong>証拠と「どうしたいか」が整理されている人</strong>。逆に全部丸投げだと、弁護士も方針を立てにくく、時間もかかります。弁護士は“素材”があるほど力を出せるんです。",
        take: "相談前に「証拠」と「希望のゴール」をメモにまとめておく。",
        cta: { href: "/detective/start/", label: "最初にやること完全ガイド →", track: "honne_start" },
      },
      {
        title: "無料相談を“使い倒す人”と“消化する人”の差",
        body: "初回無料相談は30分〜1時間。ここで差が出ます。活かす人は、<strong>聞きたいことを紙に書いて持ってくる</strong>。時間内に全部聞いて、方針まで持ち帰る。なんとなく話して終わる人は、また振り出しです。無料の枠は、準備した人ほど得をするようにできています。",
        take: "質問リストを紙に。優先度の高い順に並べて持参する。",
        cta: { href: "/detective/soudan/", label: "無料相談できる窓口まとめ →", track: "honne_soudan" },
      },
      {
        title: "調停で損をするのは「感情的に責める人」",
        body: "調停は“勝ち負けを競う場”ではなく、間に入る調停委員が話をまとめる場です。ここで相手を感情的に責め立てる人は、実は不利になりがち。調停委員が信頼するのは、<strong>冷静に事実と証拠を並べられる人</strong>。「かわいそうな人」より「筋が通っている人」に味方が集まります。",
        take: "言いたいことは、感情ではなく“事実の時系列”で整理して伝える。",
        cta: { href: "/detective/rikon-nagare/", label: "離婚の進め方 完全ガイド →", track: "honne_rikonnagare" },
      },
    ],
  },
  {
    label: "気持ち・その後の本音",
    items: [
      {
        title: "「早く動いた人」と「1年迷った人」、いちばん差が出るのは“心”",
        body: "結果を分けるのはお金や証拠だけではありません。いちばん大きく変わるのは、<strong>心の回復の早さ</strong>です。証拠は時間とともに消え、気持ちは宙ぶらりんの期間が長いほど削られていく。動くと決めた人は、たとえ結果が同じでも、前を向くのが早かった。迷う時間そのものが、いちばんのコストなんです。",
        take: "「今すぐ決断」ではなく「今、順番だけ知る」。それだけで前に進める。",
        cta: { href: "/detective/mental-care/", label: "心のセルフケア →", track: "honne_mentalcare" },
      },
      {
        title: "やり直せた夫婦が、水面下でやっていたこと",
        body: "修復して続いた夫婦もたくさん見てきました。共通していたのは、責め続けることではなく——<strong>「二度目はない」という線引きと、これからの条件をきちんと決めた</strong>こと。曖昧なまま「許す」だけだと、また同じことが起きがちでした。感情の整理と、現実的なルール決め。その両輪でした。",
        take: "許すか別れるかの前に、「線引き」と「条件」を言葉にしてみる。",
        cta: { href: "/detective/shufuku/", label: "夫婦関係の修復ガイド →", track: "honne_shufuku" },
      },
    ],
  },
];
let n = 0;
