    .honne-intro { font-size:.95rem; line-height:1.95; margin:0 0 .5rem; }
    .honne-group-label {
      display:inline-block; font-size:.8rem; font-weight:900; letter-spacing:.04em;
      color:#c8362a; background:rgba(200,54,42,.08); border:1px solid rgba(200,54,42,.2);
      padding:.3rem .7rem; border-radius:999px; margin:2rem 0 .3rem;
    }
    .honne-card {
      position:relative; background:#fff; border:1px solid rgba(0,0,0,.08);
      border-left:4px solid #c8362a; border-radius:12px;
      padding:1.15rem 1.15rem 1.1rem; margin:1rem 0;
      box-shadow:0 2px 12px rgba(0,0,0,.05);
    }
    .honne-num {
      display:inline-block; font-family:"Noto Serif JP",serif; font-size:.82rem; font-weight:700;
      color:#c8362a; letter-spacing:.06em; margin-bottom:.35rem;
    }
    .honne-card h3 { font-size:1.08rem; line-height:1.55; font-weight:900; color:var(--navy,#1a2b4a); margin:0 0 .6rem; }
    .honne-card p { font-size:.9rem; line-height:1.95; margin:0; color:var(--text,#333); }
    .honne-take {
      display:flex; gap:.5rem; align-items:flex-start;
      margin-top:.85rem; padding:.7rem .85rem; background:#fbf7ee;
