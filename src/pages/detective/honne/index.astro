    }
    .honne-cta:hover { border-bottom-color:#c8362a; }
    .honne-close { background:linear-gradient(135deg,#1a2b4a,#0d1b2e); color:#fff; border-radius:14px; padding:1.4rem 1.25rem; margin:2rem 0 0; }
