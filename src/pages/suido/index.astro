<!-- ══ 問い合わせフォーム ══════════════════════════════════════ -->
<section class="sd-section form-section" id="contact">
  <div class="sd-container">
    <div class="section-head">
      <span class="kicker">CONTACT</span>
      <h2>無料相談・見積もり依頼</h2>
      <p>施設情報をお知らせください。地元の登録業者をご紹介します</p>
    </div>
    <div class="form-wrap">
      <h3>受水槽清掃の無料相談</h3>
      <p class="form-sub">営業時間内（平日9:00〜18:00）にご連絡します。土日祝は翌営業日の対応となります。</p>

      <!-- action は Netlify Forms / Google Apps Script の URL に差し替え -->
      <form id="contact-form" action="/api/contact" method="POST" novalidate>
        <input type="hidden" name="form-name" value="suido-contact" />
        <div class="form-group">
          <label for="company">会社名・施設名 <span class="required">必須</span></label>
          <input type="text" id="company" name="company" placeholder="例：〇〇マンション管理組合" required />
        </div>
        <div class="form-group">
          <label for="name">担当者名 <span class="required">必須</span></label>
          <input type="text" id="name" name="name" placeholder="例：山田 太郎" required />
        </div>
        <div class="form-group">
          <label for="tel">電話番号 <span class="required">必須</span></label>
          <input type="tel" id="tel" name="tel" placeholder="例：03-0000-0000" required />
        </div>
        <div class="form-group">
          <label for="prefecture">都道府県 <span class="required">必須</span></label>
          <select id="prefecture" name="prefecture" required>
            <option value="">選択してください</option>
            <option>北海道</option><option>青森県</option><option>岩手県</option><option>宮城県</option>
            <option>秋田県</option><option>山形県</option><option>福島県</option><option>茨城県</option>
            <option>栃木県</option><option>群馬県</option><option>埼玉県</option><option>千葉県</option>
            <option>東京都</option><option>神奈川県</option><option>新潟県</option><option>富山県</option>
            <option>石川県</option><option>福井県</option><option>山梨県</option><option>長野県</option>
            <option>岐阜県</option><option>静岡県</option><option>愛知県</option><option>三重県</option>
            <option>滋賀県</option><option>京都府</option><option>大阪府</option><option>兵庫県</option>
            <option>奈良県</option><option>和歌山県</option><option>鳥取県</option><option>島根県</option>
            <option>岡山県</option><option>広島県</option><option>山口県</option><option>徳島県</option>
            <option>香川県</option><option>愛媛県</option><option>高知県</option><option>福岡県</option>
            <option>佐賀県</option><option>長崎県</option><option>熊本県</option><option>大分県</option>
            <option>宮崎県</option><option>鹿児島県</option><option>沖縄県</option>
          </select>
        </div>
        <div class="form-group">
          <label for="facility_type">施設の種類</label>
          <select id="facility_type" name="facility_type">
            <option value="">選択してください</option>
            <option>マンション・集合住宅</option>
            <option>オフィスビル</option>
            <option>商業施設・テナントビル</option>
            <option>工場・倉庫</option>
            <option>病院・診療所</option>
            <option>介護・福祉施設</option>
            <option>学校・教育施設</option>
            <option>ホテル・宿泊施設</option>
            <option>その他</option>
          </select>
        </div>
        <div class="form-group">
          <label for="tank_size">受水槽の有効容量（わかる範囲で）</label>
          <select id="tank_size" name="tank_size">
            <option value="">わからない / 未確認</option>
            <option>10m³以下</option>
            <option>10〜20m³</option>
            <option>20〜50m³</option>
            <option>50〜100m³</option>
            <option>100m³超</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">その他・ご要望</label>
          <textarea id="message" name="message" placeholder="最後の清掃からの経過年数、希望日程、複数棟まとめての依頼など、自由にご記入ください"></textarea>
        </div>
        <button type="submit" class="form-submit" data-track="form_submit">
          無料で相談する →
        </button>
        <p class="form-note">個人情報は業者紹介のみに使用し、第三者への販売・提供は行いません。</p>
      </form>
    </div>
  </div>
</section>

