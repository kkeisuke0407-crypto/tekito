---
const title = "債務整理おすすめ6選｜借金スッキリnavi";
const description = "返済が苦しい・複数社から借入・督促が止まらない。債務整理に対応する事務所6社を公式情報ベースで9項目比較。相談料・費用・対応範囲を確認できます。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18129603657"></script>
  <script is:inline>
    function toggleFaq(id) {
      var item = document.getElementById(id);
      item.classList.toggle('open');
    }
    var _hlCol = null;
    function hlCol(col) {
      _hlCol = (_hlCol === col) ? null : col;
      document.querySelectorAll('.ct-head-firm').forEach(function(el) {
        el.classList.toggle('hl', String(el.dataset.col) === String(_hlCol));
      });
      document.querySelectorAll('.ct-row-val').forEach(function(el) {
        el.classList.toggle('hl', String(el.dataset.col) === String(_hlCol));
      });
    }
  </script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
    function gtagSendEvent(url) {
      try {
        if (typeof gtag === 'function') {
          gtag('event', 'money_cta', {
            'event_label': url,
            'transport_type': 'beacon',
          });
        }
      } catch (e) {}
      return true;
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@700;900&family=M+PLUS+Rounded+1c:wght@700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #FF6B35; --primary-dark: #E04E18; --primary-soft: #FFE3D1;
      --cream: #FFF8F0; --warm-white: #FFFDF9;
      --ink: #2A1F1A; --ink-soft: #7A5A45;
      --green: #2FB67E; --green-dark: #1F8F5F;
      --yellow: #FFC247; --border: #F0E2D2; --pink: #FFE3EE;
      --zen: "Zen Maru Gothic", sans-serif;
      --round: "M PLUS Rounded 1c", sans-serif;
      --sans: "Noto Sans JP", sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: #F5EDE0; color: var(--ink); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    button { font-family: inherit; cursor: pointer; }
    .page-wrap { max-width: 440px; margin: 0 auto; background: var(--warm-white); min-height: 100vh; position: relative; }
    @media (min-width: 600px) {
      body { padding: 24px 0; background: radial-gradient(circle at 20% 10%, #FFE2C0 0%, transparent 45%), radial-gradient(circle at 80% 90%, #FFD9C4 0%, transparent 45%), #F5EDE0; }
      .page-wrap { border-radius: 28px; overflow: hidden; box-shadow: 0 24px 60px rgba(196,110,60,0.18); }
    }
    /* ── PC layout ── */
    @media (min-width: 860px) {
      body { padding: 32px 24px; }
      .page-wrap { max-width: 900px; border-radius: 24px; }

      /* Hero 2-col */
      .hero { padding: 40px 40px 44px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; }
      .hero-blob { width: 220px; height: 220px; top: -50px; right: -40px; }
      .hero h1 { font-size: 42px; margin: 16px 0 10px; }
      .hero-lead { font-size: 15px; margin-bottom: 22px; }
      .hero-cta { font-size: 17px; padding: 16px; }
      .hero-badge { font-size: 12px; }
      .hero-note { font-size: 12px; }
      .hero-stats { grid-template-columns: repeat(3,1fr); margin-top: 0; }
      .hero-stat-n { font-size: 24px; }
      .hero-stat-l { font-size: 11px; }
      .hero-right { display: flex; flex-direction: column; gap: 16px; z-index: 1; position: relative; }

      /* Sections */
      .worry { padding: 32px 28px 16px; }
      .worry-title { font-size: 20px; }
      .worry-list { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .worry-item { font-size: 14px; }
      .worry-footer { font-size: 14px; margin-top: 18px; }

      /* Case study */
      .case-study-mobile { display: none; }
      .case-study { margin: 20px 28px 0; padding: 20px 24px; display: flex; align-items: center; gap: 32px; }
      .case-study-note { margin-top: 0; flex: 1; font-size: 12px; }
      .case-study-body { gap: 16px; }
      .case-study-num { font-size: 28px; }
      .case-study-num.before { font-size: 22px; }

      /* Checklist */
      .checklist-wrap { margin: 20px 28px 0; }
      .checklist-title { font-size: 20px; margin-bottom: 16px; }
      .checklist-items { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .checklist-item { font-size: 14px; }
      .checklist-footer { font-size: 14px; }
      .checklist-cta { font-size: 16px; padding: 16px; max-width: 400px; margin-left: auto; margin-right: auto; }

      /* Sec heads */
      .sec-head { padding: 32px 28px 12px; }
      .sec-head h2 { font-size: 26px; }
      .sec-head p { font-size: 13px; }

      /* Ranking 3-col */
      .ranking-list { padding: 16px 28px 12px; display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
      .firm-card { padding: 20px 18px 18px; }
      .firm-emblem { width: 52px; height: 52px; font-size: 26px; }
      .firm-name { font-size: 14px; }
      .firm-cta { font-size: 13px; padding: 13px 8px; }

      /* Compare */
      .compare-wrap { padding: 8px 28px 4px; }
      .compare-table { min-width: 760px; }
      .ct-row-key { font-size: 12px; padding: 11px 12px; }
      .ct-row-val { font-size: 12px; }
      .ct-head-firm { padding: 10px 6px; }
      .ct-firm-name { font-size: 11px; }

      /* How-to */
      .howto-wrap { padding: 8px 28px 8px; }
      .howto-steps { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px 24px; }
      .howto-step::after { display: none; }
      .howto-body { padding-bottom: 0; }
      .howto-num { width: 34px; height: 34px; font-size: 17px; }
      .howto-body strong { font-size: 14px; }
      .howto-body p { font-size: 13px; }

      /* Criteria 2-col */
      .criteria-wrap { padding: 8px 28px 8px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .criteria-body strong { font-size: 14px; }
      .criteria-body p { font-size: 12px; }
      .extra-offers { margin: 12px 28px 4px; padding: 18px 20px; }
      .extra-offers h3 { font-size: 22px; }
      .extra-offers p { font-size: 13px; }
      .offer-grid { grid-template-columns: 1fr; gap: 12px; }

      /* FAQ */
      .faq-list { padding: 8px 28px 24px; }
      .faq-q-text { font-size: 14px; }
      .faq-a-text { font-size: 13px; }

      /* Final CTA */
      .final-cta { margin: 8px 28px 20px; padding: 28px 28px; }
      .final-cta h3 { font-size: 26px; }
      .final-cta p { font-size: 13px; }
      .final-cta-shindan-main { font-size: 20px; }

      /* Footer */
      .site-footer { padding: 24px 28px 36px; }
      .footer-text { font-size: 11px; }
    }

    /* AppBar */
    .appbar {
      position: sticky; top: 0; z-index: 30;
      background: rgba(255,253,249,0.92); backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 8px 14px; display: flex; align-items: center; gap: 10px;
    }
    .appbar-logo {
      width: 30px; height: 30px; border-radius: 9px;
      background: linear-gradient(135deg, var(--primary), #FF9447);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-family: var(--zen); font-weight: 900; font-size: 17px;
      box-shadow: 0 3px 8px rgba(255,107,53,0.35); flex-shrink: 0;
    }
    .appbar-name { font-family: var(--zen); font-weight: 900; font-size: 15px; color: var(--ink); letter-spacing: -0.01em; line-height: 1.05; }
    .appbar-sub { font-size: 9px; color: var(--ink-soft); letter-spacing: 0.06em; }
    .appbar-spacer { flex: 1; }

    /* Hero */
    .hero {
      position: relative; overflow: hidden;
      padding: 20px 18px 28px;
      background: radial-gradient(160% 80% at 100% 0%, #FFCBA4 0%, transparent 55%),
                  radial-gradient(120% 70% at 0% 100%, #FFD9C4 0%, transparent 60%),
                  linear-gradient(180deg, #FFF6EC 0%, #FFEDDB 100%);
    }
    .hero-blob {
      position: absolute; top: -30px; right: -30px; width: 140px; height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,180,71,0.45), transparent 70%);
      filter: blur(8px); pointer-events: none;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #fff; border-radius: 999px; padding: 5px 12px 5px 8px;
      font-size: 11px; font-weight: 700; color: var(--primary-dark);
      box-shadow: 0 4px 10px rgba(255,107,53,0.18); position: relative; z-index: 1;
    }
    .hero-badge-dot {
      width: 18px; height: 18px; border-radius: 50%; background: var(--primary);
      color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 11px;
    }
    .hero h1 {
      margin: 12px 0 6px;
      font-family: var(--zen); font-weight: 900; font-size: 30px; line-height: 1.2;
      letter-spacing: -0.02em; color: var(--ink); position: relative; z-index: 1;
    }
    .hero-h1-mark { background: linear-gradient(180deg, transparent 60%, #FFD480 60%); padding: 0 4px; }
    .hero-lead { margin: 6px 0 18px; font-size: 13px; color: var(--ink-soft); line-height: 1.7; position: relative; z-index: 1; }
    .hero-left { position: relative; z-index: 1; }
    .hero-right { display: none; }
    .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 16px; }
    .hero-stat { background: #fff; border-radius: 14px; padding: 10px 6px; text-align: center; box-shadow: 0 4px 12px rgba(196,110,60,0.08); }
    .hero-stat-n { font-family: var(--zen); font-weight: 900; font-size: 20px; color: var(--primary); line-height: 1; }
    .hero-stat-l { font-size: 10px; color: var(--ink-soft); margin-top: 4px; }
    .hero-cta {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; border: none;
      background: linear-gradient(180deg, #FF8A4D, var(--primary));
      color: #fff; font-family: var(--round); font-weight: 800; font-size: 16px;
      padding: 14px; border-radius: 16px;
      box-shadow: 0 8px 18px rgba(255,107,53,0.4), inset 0 1px 0 rgba(255,255,255,0.3);
      position: relative; z-index: 1; cursor: pointer;
    }
    .hero-note { margin-top: 10px; font-size: 11px; color: var(--ink-soft); text-align: center; position: relative; z-index: 1; }

    /* Assurance */
    .assurance { padding: 16px 16px 4px; background: var(--warm-white); }
    .assurance-grid { display: grid; gap: 8px; }
    .assurance-card {
      display: flex; align-items: flex-start; gap: 10px;
      background: #fff; border: 1px solid var(--border); border-radius: 14px;
      padding: 12px; box-shadow: 0 5px 14px rgba(196,110,60,0.06);
    }
    .assurance-icon {
      width: 30px; height: 30px; border-radius: 10px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      background: var(--primary-soft); color: var(--primary-dark); font-weight: 900;
    }
    .assurance-body strong { display: block; font-size: 13px; font-weight: 800; color: var(--ink); margin-bottom: 3px; }
    .assurance-body p { margin: 0; font-size: 11px; line-height: 1.65; color: var(--ink-soft); }

    /* Worry Strip */
    .worry { padding: 22px 16px 8px; background: var(--warm-white); }
    .worry-title { text-align: center; margin-bottom: 14px; font-family: var(--zen); font-weight: 800; font-size: 18px; color: var(--ink); }
    .worry-list { display: flex; flex-direction: column; gap: 8px; }
    .worry-item {
      display: flex; align-items: center; gap: 10px;
      background: var(--cream); border-radius: 12px; padding: 10px 14px;
      border: 1px solid var(--border); font-size: 13px; color: var(--ink); font-weight: 500;
    }
    .worry-icon {
      width: 22px; height: 22px; border-radius: 50%; background: #FFE3D1; color: var(--primary-dark);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 800; flex-shrink: 0;
    }
    .worry-footer { text-align: center; margin-top: 14px; font-size: 13px; font-weight: 700; color: var(--primary-dark); }

    /* Section Header */
    .sec-head { padding: 24px 18px 8px; text-align: center; }
    .sec-kicker {
      display: inline-block; font-family: var(--round); font-size: 11px; font-weight: 800;
      letter-spacing: 0.18em; color: var(--primary); background: var(--primary-soft);
      padding: 4px 12px; border-radius: 999px;
    }
    .sec-head h2 { margin: 10px 0 4px; font-family: var(--zen); font-weight: 900; font-size: 22px; color: var(--ink); line-height: 1.3; letter-spacing: -0.01em; }
    .sec-head p { margin: 0; font-size: 12px; color: var(--ink-soft); }
    /* Firm Card */
    .ranking-list { padding: 14px 16px 8px; display: flex; flex-direction: column; gap: 18px; }
    .firm-card {
      position: relative; background: #fff; border-radius: 20px; padding: 18px 16px 16px;
      border: 1px solid var(--border); box-shadow: 0 6px 16px rgba(196,110,60,0.08);
      transition: all 0.25s cubic-bezier(.2,.8,.2,1);
    }
    .firm-card:hover { box-shadow: 0 14px 30px rgba(196,110,60,0.18); transform: translateY(-3px); }
    .pick-badge {
      position: absolute; top: -10px; left: 14px;
      color: #fff; font-family: var(--zen); font-weight: 900;
      font-size: 11px; padding: 4px 10px; border-radius: 999px; letter-spacing: 0.04em;
    }
    .firm-head { display: flex; gap: 12px; align-items: flex-start; }
    .firm-emblem {
      width: 56px; height: 56px; border-radius: 16px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-family: var(--zen); font-weight: 900; font-size: 28px;
      inset: 0 1px 0 rgba(255,255,255,0.25);
    }
    .firm-type { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; margin-bottom: 4px; }
    .firm-name { font-family: var(--zen); font-weight: 800; font-size: 15px; line-height: 1.3; color: var(--ink); letter-spacing: -0.01em; }

    .star { font-size: 12px; }
    .firm-tagline {
      margin-top: 12px; padding: 8px 12px; border-radius: 10px;
      font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 6px;
    }
    .firm-specs { margin-top: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .firm-spec { background: #FBF5EE; border-radius: 10px; padding: 8px 10px; }
    .firm-spec-label { font-size: 9px; color: var(--ink-soft); font-weight: 600; margin-bottom: 2px; }
    .firm-spec-val { font-family: var(--round); font-weight: 800; font-size: 13px; line-height: 1.2; }
    .firm-badges { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
    .firm-badge {
      font-size: 10px; font-weight: 700; color: var(--ink-soft); background: #F5EBDC;
      padding: 3px 8px; border-radius: 999px; border: 1px solid var(--border);
    }
    .firm-pros { margin-top: 12px; display: flex; flex-direction: column; gap: 5px; }
    .firm-pro { display: flex; gap: 6px; align-items: flex-start; font-size: 12px; color: var(--ink); line-height: 1.5; }
    .firm-cta {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      margin-top: 14px; text-decoration: none;
      background: linear-gradient(180deg, #FF8A4D, var(--primary));
      color: #fff; font-family: var(--round); font-weight: 800; font-size: 14px;
      padding: 14px 8px; border-radius: 14px;
      box-shadow: 0 6px 16px rgba(255,107,53,0.45);
      transition: transform 0.2s;
    }
    .firm-cta:hover { transform: translateY(-2px); }
    .firm-cta.is-disabled { background: #EEF3F9; color: #5F6D7A; box-shadow: none; cursor: default; }
    .firm-cta.is-disabled:hover { transform: none; }
    .firm-cta-note { margin-top: 6px; text-align: center; font-size: 10px; color: var(--ink-soft); }
    .firm-pick { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--border); font-size: 11px; color: var(--ink-soft); display: flex; align-items: center; gap: 6px; }
    .firm-pick strong { font-weight: 700; color: var(--primary-dark); }
    .firm-caution {
      margin-top: 8px; padding: 8px 10px; border-radius: 10px;
      background: #FFF8EE; border: 1px dashed #FFD2AA;
      font-size: 11px; color: var(--ink-soft); line-height: 1.6;
    }
    .firm-caution strong { color: var(--primary-dark); }
    .firm-banner { margin-top: 10px; border-radius: 12px; overflow: visible; }
    .firm-banner a {
      position: relative; display: flex; align-items: center; justify-content: space-between; gap: 8px;
      min-height: auto; padding: 8px 10px; border: 1px solid var(--border); border-radius: 12px;
      background: #FFF8EE; color: var(--ink); line-height: 1.4; box-shadow: none;
      overflow: hidden;
    }
    .firm-banner a::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.55) 46%, transparent 62%);
      pointer-events: none; display: none;
    }
    .firm-banner-kicker { display: none; }
    .firm-banner-title { position: relative; z-index: 1; font-family: var(--zen); font-size: 12px; font-weight: 900; color: var(--ink); }
    .firm-banner-copy { display: none; }
    .firm-banner-action { position: relative; z-index: 1; margin-top: 0; justify-self: auto; padding: 4px 8px; border-radius: 999px; background: #fff; border: 1px solid #FFD2AA; color: var(--primary-dark); font-size: 10px; font-weight: 800; white-space: nowrap; flex-shrink: 0; }
    .firm-banner-placeholder {
      margin-top: 12px; min-height: 90px; display: grid; gap: 3px;
      padding: 13px 14px; border: 1px solid #D8E9FF; border-radius: 14px;
      background: linear-gradient(135deg, #F6FAFF 0%, #E9F4FF 58%, #DCEBFF 100%);
      color: var(--ink); line-height: 1.45;
    }
    .firm-banner-placeholder .firm-banner-kicker { color: #2F63B7; }
    .firm-banner-placeholder .firm-banner-action { color: #2F63B7; }
    .extra-offers { margin: 10px 16px 6px; background: #F6FAFF; border: 1px solid #D8E9FF; border-radius: 16px; padding: 14px 12px; }
    .extra-offers h3 { font-family: var(--zen); font-size: 17px; margin-bottom: 6px; color: #2F63B7; }
    .extra-offers p { font-size: 12px; color: var(--ink-soft); line-height: 1.6; margin-bottom: 10px; }
    .offer-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    .offer-item { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 10px; }
    .offer-title { font-size: 13px; font-weight: 700; margin-bottom: 8px; }
    .offer-btn { display: flex; justify-content: center; align-items: center; background: linear-gradient(180deg, #FF8A4D, var(--primary)); color: #fff; border-radius: 10px; padding: 10px; font-size: 13px; font-weight: 700; margin-top: 8px; text-decoration: none; }
    .offer-btn.is-disabled { background: #EEF3F9; color: #5F6D7A; box-shadow: none; cursor: default; }
    .offer-note { margin-top: 8px; font-size: 10px; color: #8D7A67; text-align: center; }

    /* Compare Table */
    .compare-helper {
      margin: 0 16px 8px; padding: 9px 12px;
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
      background: #FFF8EE; border: 1px solid var(--border); border-radius: 12px;
      font-size: 11px; color: var(--ink-soft);
    }
    .compare-hint { color: var(--primary-dark); font-weight: 800; }
    .compare-arrow { color: var(--primary-dark); font-weight: 900; letter-spacing: 0.08em; white-space: nowrap; }
    .compare-wrap { padding: 8px 12px 4px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .compare-table { min-width: 700px; background: #fff; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 6px 16px rgba(196,110,60,0.06); }
    .ct-head { display: grid; grid-template-columns: 88px repeat(6, 1fr); background: linear-gradient(180deg, var(--primary-soft), #FFF1E2); border-bottom: 1px solid var(--border); }
    .ct-head-label { padding: 10px 8px; font-size: 10px; color: var(--ink-soft); font-weight: 700; border-right: 1px solid var(--border); }
    .ct-head-firm { padding: 8px 4px; text-align: center; cursor: pointer; border-right: 1px solid var(--border); transition: background 0.2s; }
    .ct-head-firm:last-child { border-right: none; }
    .ct-head-firm.hl { background: #fff; }
    .ct-head-emblem { display: flex; justify-content: center; margin-bottom: 4px; }
    .ct-emblem-sm { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 14px; }
    .ct-firm-name { font-family: var(--zen); font-weight: 800; font-size: 10px; color: var(--ink); line-height: 1.2; }
    .ct-row { display: grid; grid-template-columns: 88px repeat(6, 1fr); border-bottom: 1px solid var(--border); }
    .ct-row:last-child { border-bottom: none; }
