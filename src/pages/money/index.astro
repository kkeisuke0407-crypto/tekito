---
const title = "借金のこと、ひとりで抱えなくて大丈夫。";
const description = "返済がつらい、利息ばかりで減らない、誰にも相談できない。そんな方のための無料相談・キャッシング比較サイト。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:    #FAF7F2;
      --cream2:   #F3EDE4;
      --brown:    #B88A5A;
      --brown-d:  #8C6030;
      --brown-l:  #F0E6D8;
      --green:    #3D9970;
      --green-d:  #2E7A57;
      --green-l:  #E8F5EF;
      --text:     #2B2B2B;
      --text-mid: #4A4540;
      --text-sub: #6F6A64;
      --text-lt:  #9E9890;
      --white:    #FFFFFF;
      --border:   #E8E0D4;
      --radius:   14px;
      --radius-lg:22px;
      --shadow:   0 4px 20px rgba(100,70,30,0.08);
      --shadow-lg:0 8px 40px rgba(100,70,30,0.13);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--cream);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      padding-bottom: 80px;
    }

    a { text-decoration: none; }
    img { display: block; max-width: 100%; }

    .wrap {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .sec  { padding: 56px 0; }
    .sec-sm { padding: 40px 0; }

    /* アニメーション */
    .rev {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .rev.on { opacity: 1; transform: translateY(0); }

    .rev-l {
      opacity: 0;
      transform: translateX(-18px);
      transition: opacity 0.45s ease, transform 0.45s ease;
    }
    .rev-l.on { opacity: 1; transform: translateX(0); }

    .rev-s {
      opacity: 0;
      transform: scale(0.94);
      transition: opacity 0.45s ease, transform 0.45s ease;
    }
    .rev-s.on { opacity: 1; transform: scale(1); }

    /* 共通ラベル */
    .eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--brown);
      margin-bottom: 8px;
    }

    .sec-title {
      font-size: clamp(22px, 5.5vw, 28px);
      font-weight: 900;
      line-height: 1.5;
      color: var(--text);
      margin-bottom: 8px;
    }

    .sec-lead {
      font-size: 14px;
      color: var(--text-sub);
      line-height: 1.9;
      margin-bottom: 28px;
    }

    /* ========== HERO ========== */
    .hero {
      background: var(--cream);
      position: relative;
      overflow: hidden;
      min-height: 640px;
      display: flex;
      flex-direction: column;
    }

    /* 右側の画像：絶対配置で右にはみ出す */
    .hero-img {
      position: absolute;
      right: 0;
      top: 0;
      width: 56%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    /* 画像左端をクリームにフェードアウト */
    .hero-img-fade {
      position: absolute;
      top: 0; bottom: 0;
      right: 50%;
      width: 100px;
      background: linear-gradient(to right, var(--cream) 0%, transparent 100%);
      z-index: 1;
      pointer-events: none;
    }

    /* テキストエリア */
    .hero-content {
      position: relative;
      z-index: 2;
      padding: 44px 20px 28px;
      width: 100%;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: var(--brown-d);
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 14px;
      opacity: 0.85;
    }

    .hero-title {
      font-size: clamp(28px, 8.5vw, 44px);
      font-weight: 900;
      line-height: 1.35;
      color: var(--text);
      margin-bottom: 16px;
      max-width: 52%;
    }

    .hero-sub {
      font-size: 12px;
      color: var(--text-sub);
      line-height: 1.85;
      margin-bottom: 24px;
      max-width: 52%;
    }

    /* 信頼バッジ 3列 */
    .hero-badges {
      display: flex;
      gap: 0;
      margin-bottom: 16px;
    }

    .hero-badge-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      background: var(--white);
      padding: 10px 2px;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-mid);
      text-align: center;
      border-right: 1px solid var(--border);
    }

    .hero-badge-item:first-child { border-radius: var(--radius) 0 0 var(--radius); }
    .hero-badge-item:last-child  { border-radius: 0 var(--radius) var(--radius) 0; border-right: none; }

    .hero-badge-icon { font-size: 16px; }
    .hero-badge-sub  { font-size: 9px; color: var(--text-lt); font-weight: 500; }

    /* CTAボタン 2列 */
    .hero-btns {
      display: flex;
      gap: 8px;
      margin-bottom: 0;
    }

    .hero-btn-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .hero-btn-label {
      font-size: 9px;
      font-weight: 700;
      color: var(--text-lt);
      text-align: center;
      letter-spacing: 0.02em;
    }

    .btn-law {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      background: var(--brown);
      color: var(--white);
      font-size: 12px;
      font-weight: 900;
      padding: 14px 6px;
      border-radius: var(--radius);
      box-shadow: 0 4px 16px rgba(184,138,90,0.38);
      transition: transform 0.18s;
      letter-spacing: 0.01em;
      text-align: center;
      line-height: 1.3;
    }

    .btn-law:active { transform: scale(0.97); }

    .btn-cash {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      background: #D9524A;
      color: var(--white);
      font-size: 12px;
      font-weight: 900;
      padding: 14px 6px;
      border-radius: var(--radius);
      box-shadow: 0 4px 16px rgba(217,82,74,0.32);
      transition: transform 0.18s;
      letter-spacing: 0.01em;
      text-align: center;
      line-height: 1.3;
    }

    .btn-cash:active { transform: scale(0.97); }

    /* 下部：女の子コメントバー */
    .hero-bottom {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 14px 16px;
      margin-top: auto;
    }

    .hero-bottom-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
      background: var(--cream2);
      border: 2px solid var(--brown-l);
    }

    .hero-bottom-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }

    .hero-bottom-comment {
      flex: 1;
      font-size: 11px;
      color: var(--text-mid);
      line-height: 1.7;
    }

    .hero-bottom-comment strong {
      color: var(--brown-d);
      font-size: 10px;
      display: block;
      margin-bottom: 1px;
    }

    .hero-bottom-list {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .hero-bottom-check {
      font-size: 10px;
      color: var(--text-sub);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .hero-bottom-check::before {
      content: '✓';
      color: var(--brown);
      font-weight: 900;
      font-size: 10px;
    }

    /* ========== EMPATHY ========== */
    .empathy-bg { background: var(--cream2); }

    .empathy-cards {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .empathy-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 15px;
      font-weight: 600;
      color: var(--text-mid);
      box-shadow: var(--shadow);
      border-left: 3px solid var(--brown-l);
    }

    .empathy-card .em { font-size: 22px; flex-shrink: 0; }

    /* ========== DECIDE ========== */
    .decide-bg { background: var(--white); }

    .decide-row {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .decide-card {
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--white);
    }

    .decide-head {
      padding: 18px 20px 14px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .decide-icon {
      width: 46px;
      height: 46px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }

    .decide-icon--law  { background: var(--brown-l); }
    .decide-icon--cash { background: var(--green-l); }

    .decide-name { font-size: 16px; font-weight: 900; color: var(--text); margin-bottom: 2px; }
    .decide-sub  { font-size: 12px; color: var(--text-sub); }

    .decide-checks {
      padding: 0 20px 14px;
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .decide-check {
      font-size: 13.5px;
      color: var(--text-mid);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.6;
    }

    .decide-check::before {
      content: '✓';
      font-weight: 900;
      color: var(--brown);
      flex-shrink: 0;
    }

    .decide-card--cash .decide-check::before { color: var(--green); }

    .decide-cta {
      display: block;
      margin: 2px 20px 20px;
      padding: 13px;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 900;
      text-align: center;
      color: var(--white);
      letter-spacing: 0.02em;
    }

    .decide-cta--law  { background: var(--brown);    box-shadow: 0 4px 14px rgba(184,138,90,0.3); }
    .decide-cta--cash { background: var(--green);    box-shadow: 0 4px 14px rgba(61,153,112,0.25); }

    .or-divider {
      text-align: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-lt);
      position: relative;
      padding: 2px 0;
    }

    .or-divider::before,
    .or-divider::after {
      content: '';
      position: absolute;
      top: 50%;
      width: calc(50% - 20px);
      height: 1px;
      background: var(--border);
    }

    .or-divider::before { left: 0; }
    .or-divider::after  { right: 0; }

    /* ========== GIRL COMMENT ========== */
    .girl-bg { background: var(--cream2); }

    .girl-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .girl-avatar {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid var(--white);
      box-shadow: var(--shadow-lg);
      margin-bottom: 16px;
      background: var(--cream2);
    }

    .girl-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .girl-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-sub);
      margin-bottom: 12px;
    }

    .girl-bubble {
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px 22px;
      box-shadow: var(--shadow);
      position: relative;
      text-align: left;
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-mid);
      max-width: 380px;
    }

    .girl-bubble::before {
      content: '';
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      border-width: 0 10px 10px;
      border-style: solid;
      border-color: transparent transparent var(--white);
    }

    /* ========== LAW ========== */
    .law-bg { background: var(--white); }

    .service-head {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 22px;
    }

    .service-badge {
      width: 54px;
      height: 54px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      flex-shrink: 0;
      background: var(--brown-l);
    }

    .service-badge--cash { background: var(--green-l); }

    .service-name  { font-size: 17px; font-weight: 900; margin-bottom: 2px; }
    .service-tag   { font-size: 12px; color: var(--text-sub); }

    .stat-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 24px;
    }

    .stat-box {
      background: var(--cream);
      border-radius: var(--radius);
      padding: 14px 8px;
      text-align: center;
    }

    .stat-num   { font-size: 19px; font-weight: 900; color: var(--brown-d); line-height: 1.1; margin-bottom: 4px; }
    .stat-label { font-size: 10px; color: var(--text-sub); font-weight: 600; }

    .debt-cards {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px;
    }

    .debt-card {
      background: var(--cream);
      border-radius: var(--radius);
      padding: 16px 18px;
      border-left: 3px solid var(--brown);
    }

    .debt-card--cash { border-left-color: var(--green); }

    .debt-title {
      font-size: 14px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .debt-badge {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 100px;
      background: var(--brown-l);
      color: var(--brown-d);
    }

    .debt-badge--cash { background: var(--green-l); color: var(--green-d); }

    .debt-desc { font-size: 13px; color: var(--text-sub); line-height: 1.75; }

    .feat-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 22px;
    }

    .feat-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--text-mid);
      line-height: 1.65;
    }

    .feat-dot {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 11px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .feat-dot--cash { background: var(--green-l); color: var(--green-d); }

    .fee-box {
      background: var(--cream2);
      border-radius: var(--radius);
      padding: 18px;
      margin-bottom: 22px;
      border: 1px solid var(--border);
    }

    .fee-title  { font-size: 12px; font-weight: 700; color: var(--brown-d); letter-spacing: 0.08em; margin-bottom: 10px; }
    .fee-title--cash { color: var(--green-d); }

    .fee-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      padding: 7px 0;
      border-bottom: 1px solid var(--border);
    }

    .fee-row:last-child { border-bottom: none; }
    .fee-key { color: var(--text-sub); }
    .fee-val { font-weight: 900; color: var(--brown-d); }
    .fee-val--cash { color: var(--green-d); }

    .for-who {
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      margin-bottom: 22px;
    }

    .for-who-title { font-size: 13px; font-weight: 700; color: var(--text-sub); margin-bottom: 10px; }

    .for-who-item {
      font-size: 13.5px;
      color: var(--text-mid);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.65;
      margin-bottom: 6px;
    }

    .for-who-item::before {
      content: '→';
      color: var(--brown);
      font-weight: 900;
      flex-shrink: 0;
    }

    .for-who-item--cash::before { color: var(--green); }

    .btn-sec-law {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--brown);
      color: var(--white);
      font-size: 16px;
      font-weight: 900;
      padding: 17px 24px;
      border-radius: 100px;
      box-shadow: 0 6px 22px rgba(184,138,90,0.35);
      transition: transform 0.18s;
    }

    .btn-sec-law:active { transform: scale(0.97); }

    .btn-sec-cash {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--green);
      color: var(--white);
      font-size: 16px;
      font-weight: 900;
      padding: 17px 24px;
      border-radius: 100px;
      box-shadow: 0 6px 22px rgba(61,153,112,0.3);
      transition: transform 0.18s;
    }

    .btn-sec-cash:active { transform: scale(0.97); }

    /* ========== CASH ========== */
    .cash-bg { background: var(--cream2); }

    .highlight {
      background: var(--green-l);
      border: 1.5px solid #9FD3B8;
      border-radius: var(--radius);
      padding: 20px;
      text-align: center;
      margin-bottom: 22px;
    }

    .highlight-label { font-size: 12px; font-weight: 700; color: var(--green-d); margin-bottom: 6px; }
    .highlight-main  { font-size: clamp(26px, 7vw, 34px); font-weight: 900; color: var(--green-d); line-height: 1.2; }
    .highlight-sub   { font-size: 12px; color: var(--green-d); margin-top: 6px; opacity: 0.8; }

    .spec-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 22px;
    }

    .spec-item {
      background: var(--white);
      border-radius: var(--radius);
      padding: 14px;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .spec-val { font-size: 17px; font-weight: 900; color: var(--green-d); line-height: 1.2; margin-bottom: 4px; }
    .spec-key { font-size: 11px; color: var(--text-sub); font-weight: 600; }

    /* ========== COMPARE ========== */
    .compare-bg { background: var(--white); }

    .compare-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      background: var(--white);
      margin-bottom: 12px;
    }

    .compare-table thead { background: var(--brown); }
    .compare-table th {
      padding: 13px 10px;
      font-size: 12px;
      font-weight: 900;
      color: var(--white);
      text-align: center;
    }

    .compare-table th:first-child {
      text-align: left;
      background: rgba(0,0,0,0.15);
      width: 36%;
    }

    .compare-table td {
      padding: 12px 10px;
      font-size: 13px;
      text-align: center;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    .compare-table td:first-child {
      text-align: left;
      font-weight: 700;
      color: var(--text-sub);
      background: var(--cream);
    }

    .compare-table tr:last-child td { border-bottom: none; }
    .cg { color: var(--green-d); font-weight: 700; }
    .cb { color: var(--brown-d); font-weight: 700; }
    .cn { color: var(--text-lt); font-size: 12px; }
    .cw { color: #C2501A; font-weight: 700; }

    /* ========== FAQ ========== */
    .faq-bg { background: var(--cream2); }

    .faq-list { display: flex; flex-direction: column; gap: 10px; }

    .faq-item {
      background: var(--white);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .faq-q {
      width: 100%;
      background: none;
      border: none;
      padding: 17px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
    }

    .faq-qi {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--brown-l);
      color: var(--brown-d);
      font-size: 13px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .faq-qt {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.5;
      flex: 1;
      padding-top: 2px;
    }

    .faq-ch {
      width: 14px;
      height: 14px;
      border-right: 2px solid var(--text-lt);
      border-bottom: 2px solid var(--text-lt);
      transform: rotate(45deg);
      flex-shrink: 0;
      margin-top: 5px;
      transition: transform 0.25s;
    }

    .faq-item.open .faq-ch { transform: rotate(-135deg); margin-top: 9px; }

    .faq-a {
      max-height: 0;
      overflow: hidden;
