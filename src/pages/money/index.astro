---
const title = "債務整理おすすめ3選｜借金スッキリnavi";
const description = "返済が苦しい・複数社から借入・督促が止まらない。本当に頼れる債務整理事務所を9項目で徹底比較。相談無料・全国対応。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18129603657"></script>
  <script is:inline>
    function toggleFaq(id) {
      var item = document.getElementById(id);
      item.classList.toggle('open');
    }
    var _hlCol = null;
    function hlCol(col) {
      _hlCol = (_hlCol === col) ? null : col;
      document.querySelectorAll('.ct-head-firm').forEach(function(el) {
        el.classList.toggle('hl', String(el.dataset.col) === String(_hlCol));
      });
      document.querySelectorAll('.ct-row-val').forEach(function(el) {
        el.classList.toggle('hl', String(el.dataset.col) === String(_hlCol));
      });
    }
  </script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
    function gtagSendEvent(url) {
      var callback = function () {
        if (typeof url === 'string') { window.location = url; }
      };
      gtag('event', 'money_cta', {
        'event_callback': callback,
        'event_timeout': 2000,
      });
      return false;
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@700;900&family=M+PLUS+Rounded+1c:wght@700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #FF6B35; --primary-dark: #E04E18; --primary-soft: #FFE3D1;
      --cream: #FFF8F0; --warm-white: #FFFDF9;
      --ink: #2A1F1A; --ink-soft: #7A5A45;
      --green: #2FB67E; --green-dark: #1F8F5F;
      --yellow: #FFC247; --border: #F0E2D2; --pink: #FFE3EE;
      --zen: "Zen Maru Gothic", sans-serif;
      --round: "M PLUS Rounded 1c", sans-serif;
      --sans: "Noto Sans JP", sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: #F5EDE0; color: var(--ink); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    button { font-family: inherit; cursor: pointer; }
    .page-wrap { max-width: 440px; margin: 0 auto; background: var(--warm-white); min-height: 100vh; position: relative; }
    @media (min-width: 600px) {
      body { padding: 24px 0; background: radial-gradient(circle at 20% 10%, #FFE2C0 0%, transparent 45%), radial-gradient(circle at 80% 90%, #FFD9C4 0%, transparent 45%), #F5EDE0; }
      .page-wrap { border-radius: 28px; overflow: hidden; box-shadow: 0 24px 60px rgba(196,110,60,0.18); }
    }

    /* AppBar */
    .appbar {
      position: sticky; top: 0; z-index: 30;
      background: rgba(255,253,249,0.92); backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 8px 14px; display: flex; align-items: center; gap: 10;
    }
    .appbar-logo {
      width: 30px; height: 30px; border-radius: 9px;
      background: linear-gradient(135deg, var(--primary), #FF9447);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-family: var(--zen); font-weight: 900; font-size: 17px;
      box-shadow: 0 3px 8px rgba(255,107,53,0.35); flex-shrink: 0;
    }
    .appbar-name { font-family: var(--zen); font-weight: 900; font-size: 15px; color: var(--ink); letter-spacing: -0.01em; line-height: 1.05; }
    .appbar-sub { font-size: 9px; color: var(--ink-soft); letter-spacing: 0.06em; }
    .appbar-spacer { flex: 1; }

    /* Hero */
    .hero {
      position: relative; overflow: hidden;
      padding: 20px 18px 28px;
      background: radial-gradient(160% 80% at 100% 0%, #FFCBA4 0%, transparent 55%),
                  radial-gradient(120% 70% at 0% 100%, #FFD9C4 0%, transparent 60%),
                  linear-gradient(180deg, #FFF6EC 0%, #FFEDDB 100%);
    }
    .hero-blob {
      position: absolute; top: -30px; right: -30px; width: 140px; height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,180,71,0.45), transparent 70%);
      filter: blur(8px); pointer-events: none;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #fff; border-radius: 999px; padding: 5px 12px 5px 8px;
      font-size: 11px; font-weight: 700; color: var(--primary-dark);
      box-shadow: 0 4px 10px rgba(255,107,53,0.18); position: relative; z-index: 1;
    }
    .hero-badge-dot {
      width: 18px; height: 18px; border-radius: 50%; background: var(--primary);
      color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 11px;
    }
    .hero h1 {
      margin: 12px 0 6px;
      font-family: var(--zen); font-weight: 900; font-size: 30px; line-height: 1.2;
      letter-spacing: -0.02em; color: var(--ink); position: relative; z-index: 1;
    }
    .hero-h1-mark { background: linear-gradient(180deg, transparent 60%, #FFD480 60%); padding: 0 4px; }
    .hero-lead { margin: 6px 0 18px; font-size: 13px; color: var(--ink-soft); line-height: 1.7; position: relative; z-index: 1; }
    .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 18px; position: relative; z-index: 1; }
    .hero-stat { background: #fff; border-radius: 14px; padding: 10px 6px; text-align: center; box-shadow: 0 4px 12px rgba(196,110,60,0.08); }
    .hero-stat-n { font-family: var(--zen); font-weight: 900; font-size: 20px; color: var(--primary); line-height: 1; }
    .hero-stat-l { font-size: 10px; color: var(--ink-soft); margin-top: 4px; }
    .hero-cta {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; border: none;
      background: linear-gradient(180deg, #FF8A4D, var(--primary));
      color: #fff; font-family: var(--round); font-weight: 800; font-size: 16px;
      padding: 14px; border-radius: 16px;
      box-shadow: 0 8px 18px rgba(255,107,53,0.4), inset 0 1px 0 rgba(255,255,255,0.3);
      position: relative; z-index: 1; cursor: pointer;
    }
    .hero-note { margin-top: 10px; font-size: 11px; color: var(--ink-soft); text-align: center; position: relative; z-index: 1; }

    /* Worry Strip */
    .worry { padding: 22px 16px 8px; background: var(--warm-white); }
    .worry-title { text-align: center; margin-bottom: 14px; font-family: var(--zen); font-weight: 800; font-size: 18px; color: var(--ink); }
    .worry-list { display: flex; flex-direction: column; gap: 8px; }
    .worry-item {
      display: flex; align-items: center; gap: 10;
      background: var(--cream); border-radius: 12px; padding: 10px 14px;
      border: 1px solid var(--border); font-size: 13px; color: var(--ink); font-weight: 500;
    }
    .worry-icon {
      width: 22px; height: 22px; border-radius: 50%; background: #FFE3D1; color: var(--primary-dark);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 800; flex-shrink: 0;
    }
    .worry-footer { text-align: center; margin-top: 14px; font-size: 13px; font-weight: 700; color: var(--primary-dark); }

    /* Section Header */
    .sec-head { padding: 24px 18px 8px; text-align: center; }
    .sec-kicker {
      display: inline-block; font-family: var(--round); font-size: 11px; font-weight: 800;
      letter-spacing: 0.18em; color: var(--primary); background: var(--primary-soft);
      padding: 4px 12px; border-radius: 999px;
    }
    .sec-head h2 { margin: 10px 0 4px; font-family: var(--zen); font-weight: 900; font-size: 22px; color: var(--ink); line-height: 1.3; letter-spacing: -0.01em; }
    .sec-head p { margin: 0; font-size: 12px; color: var(--ink-soft); }
    /* Firm Card */
    .ranking-list { padding: 14px 16px 8px; display: flex; flex-direction: column; gap: 18px; }
    .firm-card {
      position: relative; background: #fff; border-radius: 20px; padding: 18px 16px 16px;
      border: 1px solid var(--border); box-shadow: 0 6px 16px rgba(196,110,60,0.08);
      transition: all 0.25s cubic-bezier(.2,.8,.2,1);
    }
    .firm-card:hover { box-shadow: 0 14px 30px rgba(196,110,60,0.18); transform: translateY(-3px); }
    .pick-badge {
      position: absolute; top: -10px; left: 14px;
      color: #fff; font-family: var(--zen); font-weight: 900;
      font-size: 11px; padding: 4px 10px; border-radius: 999px; letter-spacing: 0.04em;
    }
    .firm-head { display: flex; gap: 12px; align-items: flex-start; }
    .firm-emblem {
      width: 56px; height: 56px; border-radius: 16px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-family: var(--zen); font-weight: 900; font-size: 28px;
      inset: 0 1px 0 rgba(255,255,255,0.25);
    }
    .firm-type { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; margin-bottom: 4px; }
    .firm-name { font-family: var(--zen); font-weight: 800; font-size: 15px; line-height: 1.3; color: var(--ink); letter-spacing: -0.01em; }

    .star { font-size: 12px; }
    .firm-tagline {
      margin-top: 12px; padding: 8px 12px; border-radius: 10px;
      font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 6px;
    }
    .firm-specs { margin-top: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .firm-spec { background: #FBF5EE; border-radius: 10px; padding: 8px 10px; }
    .firm-spec-label { font-size: 9px; color: var(--ink-soft); font-weight: 600; margin-bottom: 2px; }
    .firm-spec-val { font-family: var(--round); font-weight: 800; font-size: 13px; line-height: 1.2; }
    .firm-badges { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
    .firm-badge {
      font-size: 10px; font-weight: 700; color: var(--ink-soft); background: #F5EBDC;
      padding: 3px 8px; border-radius: 999px; border: 1px solid var(--border);
    }
    .firm-pros { margin-top: 12px; display: flex; flex-direction: column; gap: 5px; }
    .firm-pro { display: flex; gap: 6px; align-items: flex-start; font-size: 12px; color: var(--ink); line-height: 1.5; }
    .firm-cta {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      margin-top: 14px; text-decoration: none;
      background: linear-gradient(180deg, #FF8A4D, var(--primary));
      color: #fff; font-family: var(--round); font-weight: 800; font-size: 14px;
      padding: 14px 8px; border-radius: 14px;
      box-shadow: 0 6px 16px rgba(255,107,53,0.45);
      transition: transform 0.2s;
    }
    .firm-cta:hover { transform: translateY(-2px); }
    .firm-cta-note { margin-top: 6px; text-align: center; font-size: 10px; color: var(--ink-soft); }
    .firm-pick { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--border); font-size: 11px; color: var(--ink-soft); display: flex; align-items: center; gap: 6px; }
    .firm-pick strong { font-weight: 700; color: var(--primary-dark); }
    .firm-banner { margin-top: 14px; border-radius: 12px; overflow: hidden; line-height: 0; }
    .firm-banner a img { width: 100%; height: auto; display: block; }
    .firm-banner > img { position: absolute; width: 1px; height: 1px; }

    /* Compare Table */
    .compare-wrap { padding: 8px 12px 4px; }
    .compare-table { background: #fff; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 6px 16px rgba(196,110,60,0.06); }
    .ct-head { display: grid; grid-template-columns: 88px repeat(3, 1fr); background: linear-gradient(180deg, var(--primary-soft), #FFF1E2); border-bottom: 1px solid var(--border); }
    .ct-head-label { padding: 10px 8px; font-size: 10px; color: var(--ink-soft); font-weight: 700; border-right: 1px solid var(--border); }
    .ct-head-firm { padding: 8px 4px; text-align: center; cursor: pointer; border-right: 1px solid var(--border); transition: background 0.2s; }
    .ct-head-firm:last-child { border-right: none; }
    .ct-head-firm.hl { background: #fff; }
    .ct-head-emblem { display: flex; justify-content: center; margin-bottom: 4px; }
    .ct-emblem-sm { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 14px; }
    .ct-firm-name { font-family: var(--zen); font-weight: 800; font-size: 10px; color: var(--ink); line-height: 1.2; }
    .ct-row { display: grid; grid-template-columns: 88px repeat(3, 1fr); border-bottom: 1px solid var(--border); }
    .ct-row:last-child { border-bottom: none; }
    .ct-row-key { padding: 10px 10px; font-size: 11px; font-weight: 700; color: var(--ink); border-right: 1px solid var(--border); display: flex; align-items: center; }
    .ct-row-val { padding: 10px 6px; text-align: center; border-right: 1px solid var(--border); font-size: 11px; font-weight: 700; color: var(--ink); line-height: 1.3; display: flex; align-items: center; justify-content: center; }
    .ct-row-val:last-child { border-right: none; }
    .ct-row-val.hl { background: #FFF8EE; }
    .ct-row.stripe { background: #FBF5EE; }
    .ct-row.stripe .ct-row-key { background: #FBF5EE; }
    .ct-row.stripe .ct-row-val:not(.hl) { background: #FBF5EE; }
    .compare-note { text-align: center; font-size: 10px; color: var(--ink-soft); margin-top: 8px; }
    .svg-check { display: inline-flex; }
    .svg-cross { display: inline-flex; }

    /* Reviews */
    /* FAQ */
    .faq-list { padding: 8px 16px 20px; display: flex; flex-direction: column; gap: 8px; }
    .faq-item { background: #fff; border-radius: 14px; border: 1px solid var(--border); overflow: hidden; transition: box-shadow 0.2s; }
    .faq-item.open { box-shadow: 0 8px 18px rgba(196,110,60,0.1); }
    .faq-q { width: 100%; border: none; background: none; cursor: pointer; padding: 14px; text-align: left; display: flex; align-items: flex-start; gap: 10px; }
    .faq-q-icon { width: 22px; height: 22px; border-radius: 50%; background: var(--primary); color: #fff; font-family: var(--zen); font-weight: 900; font-size: 13px; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .faq-q-text { flex: 1; font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.5; text-align: left; }
    .faq-chevron { padding-top: 4px; transition: transform 0.2s; }
    .faq-item.open .faq-chevron { transform: rotate(180deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; }
    .faq-item.open .faq-a { max-height: 300px; }
    .faq-a-inner { padding: 0 14px 14px 14px; display: flex; gap: 10px; align-items: flex-start; padding-top: 10px; border-top: 1px dashed var(--border); }
    .faq-a-icon { width: 22px; height: 22px; border-radius: 50%; background: var(--green); color: #fff; font-family: var(--zen); font-weight: 900; font-size: 13px; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .faq-a-text { font-size: 12px; line-height: 1.7; color: var(--ink-soft); }

    /* Final CTA */
    .final-cta {
      margin: 8px 16px 16px; padding: 20px 16px; border-radius: 22px; color: #fff; position: relative; overflow: hidden;
      background: radial-gradient(120% 100% at 100% 0%, #FFB07A 0%, transparent 60%), linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    }
    .final-cta-deco { position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.1); }
    .final-cta-kicker { font-family: var(--zen); font-weight: 900; font-size: 11px; color: #FFD89C; letter-spacing: 0.1em; margin-bottom: 4px; }
    .final-cta h3 { font-family: var(--zen); font-weight: 900; font-size: 22px; line-height: 1.3; letter-spacing: -0.01em; }
    .final-cta p { margin: 8px 0 14px; font-size: 12px; line-height: 1.6; opacity: 0.92; }
    .final-cta-list { display: flex; flex-direction: column; gap: 10px; }
    .final-cta-link {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 14px; border-radius: 12px; text-decoration: none;
      background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.35);
      backdrop-filter: blur(4px);
    }
    .final-cta-link-left { display: flex; align-items: center; gap: 8px; }
    .final-cta-emblem { width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 13px; }
    .final-cta-firm-name { color: #fff; font-weight: 700; font-size: 13px; }
    .final-cta-btn { color: #fff; font-family: var(--round); font-weight: 800; font-size: 12px; background: rgba(255,255,255,0.25); padding: 4px 10px; border-radius: 999px; }
    .final-cta-shindan { display: flex; flex-direction: column; align-items: center; gap: 6px; text-decoration: none; background: #fff; border-radius: 16px; padding: 18px 20px; transition: transform 0.2s; }
    .final-cta-shindan:hover { transform: translateY(-2px); }
    .final-cta-shindan-main { font-family: var(--round); font-weight: 900; font-size: 18px; color: var(--primary); }
    .final-cta-shindan-sub { font-size: 11px; color: var(--ink-soft); }

    /* Footer */
    .site-footer { padding: 20px 18px 30px; background: #2A1F1A; color: #A89A88; }
    .footer-head { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .footer-logo { width: 26px; height: 26px; border-radius: 8px; background: var(--primary); display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 14px; }
    .footer-name { font-family: var(--zen); font-weight: 800; font-size: 14px; color: #fff; }
    .footer-text { font-size: 10px; line-height: 1.7; margin-bottom: 12px; }
    .footer-links { display: flex; gap: 16px; font-size: 10px; padding-top: 10px; border-top: 1px solid #3D2F26; }
    .footer-copy { margin-top: 12px; font-size: 9px; opacity: 0.6; }

  </style>
</head>
<body>
<div class="page-wrap">

  <header class="appbar">
    <div class="appbar-logo">整</div>
    <div style="line-height:1.05">
      <div class="appbar-name">借金スッキリnavi</div>
      <div class="appbar-sub">DEBT RELIEF COMPARE 2026</div>
    </div>
    <div class="appbar-spacer"></div>
  </header>

  <section class="hero">
    <div class="hero-blob"></div>
    <div class="hero-badge"><span class="hero-badge-dot">★</span>2026年4月 最新版</div>
    <h1>借金の悩み、<br/><span class="hero-h1-mark">3分で</span>スッキリ。</h1>
    <p class="hero-lead">本当に頼れる債務整理の事務所を、<br/>現役FPと元相談員が<b style="color:var(--ink)">9項目</b>で徹底比較。</p>
    <button class="hero-cta" onclick="document.getElementById('ranking').scrollIntoView({behavior:'smooth'})">おすすめ3選を見る ↓</button>
    <div class="hero-note">※相談無料・匿名OK・全国対応</div>
  </section>

  <section class="worry">
    <div class="worry-title">こんなお悩み、ありませんか？</div>
    <div class="worry-list">
      <div class="worry-item"><span class="worry-icon">?</span>リボ払いの残高が減らない…</div>
      <div class="worry-item"><span class="worry-icon">?</span>複数社から借入していて返済キツい</div>
      <div class="worry-item"><span class="worry-icon">?</span>家族にバレずに整理したい</div>
      <div class="worry-item"><span class="worry-icon">?</span>督促の電話が止まらない</div>
    </div>
    <div class="worry-footer">↓ ぜんぶ債務整理で解決できます ↓</div>
  </section>

  <div class="sec-head" id="ranking">
    <span class="sec-kicker">OUR TOP 3</span>
    <h2>おすすめの債務整理 3選</h2>
    <p>それぞれ得意分野が違うので、自分に合うところを選ぼう</p>
  </div>
  <div class="ranking-list">
    <!-- さくら中央 -->
    <div class="firm-card">
      <div class="pick-badge" style="background:#E8487A;box-shadow:0 4px 10px #E8487A55">安心NO.1</div>
      <div class="firm-head">
        <div class="firm-emblem" style="background:linear-gradient(135deg,#FF8FB1,#E8487A);box-shadow:0 6px 14px #E8487A33">さ</div>
        <div style="flex:1;min-width:0">
          <span class="firm-type" style="color:#E8487A;background:#FFD7E2">弁護士法人</span>
          <div class="firm-name">さくら中央法律事務所</div>
        </div>
      </div>
