---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2YLF06DC0E"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18129603657"></script>
  <script is:inline>
    function toggleFaq(id) {
      var item = document.getElementById(id);
      item.classList.toggle('open');
    }
    function scrollToId(id) {
      var el = document.getElementById(id);
      if (el) el.scrollIntoView({ behavior: 'smooth' });
      return false;
    }
  </script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-2YLF06DC0E');
    gtag('config', 'AW-18129603657');
    function gtagSendEvent(url) {
      var callback = function () {
        if (typeof url === 'string' && url !== '#') { window.location = url; }
      };
      gtag('event', 'money_cta', {
        'event_callback': callback,
        'event_timeout': 2000,
      });
      return false;
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@700;900&family=M+PLUS+Rounded+1c:wght@700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #FF6B35; --primary-dark: #E04E18; --primary-soft: #FFE3D1;
      --cream: #FFF8F0; --warm-white: #FFFDF9;
      --ink: #2A1F1A; --ink-soft: #7A5A45; --ink-faint: #A89A88;
      --green: #2FB67E; --border: #F0E2D2;
      --zen: "Zen Maru Gothic", sans-serif;
      --round: "M PLUS Rounded 1c", sans-serif;
      --sans: "Noto Sans JP", sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: #F5EDE0; color: var(--ink); -webkit-font-smoothing: antialiased; padding-bottom: 72px; }
    a { text-decoration: none; color: inherit; }
    button { font-family: inherit; cursor: pointer; }
    .page-wrap { max-width: 480px; margin: 0 auto; background: var(--warm-white); min-height: 100vh; position: relative; }
    @media (min-width: 600px) {
      body { padding: 24px 0 72px; background: radial-gradient(circle at 20% 10%, #FFE2C0 0%, transparent 45%), radial-gradient(circle at 80% 90%, #FFD9C4 0%, transparent 45%), #F5EDE0; }
      .page-wrap { border-radius: 28px; overflow: hidden; box-shadow: 0 24px 60px rgba(196,110,60,0.18); }
    }
    @media (min-width: 920px) {
      body { padding: 32px 24px; }
      .page-wrap { max-width: 960px; border-radius: 24px; }
    }

    /* PR bar */
    .pr-bar { background: #2A1F1A; color: #E8D8C6; font-size: 10px; text-align: center; padding: 6px 12px; letter-spacing: 0.04em; }

    /* AppBar */
    .appbar {
      position: sticky; top: 0; z-index: 30;
      background: rgba(255,253,249,0.93); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 9px 16px; display: flex; align-items: center; gap: 10px;
    }
    .appbar-logo {
      width: 30px; height: 30px; border-radius: 9px;
      background: linear-gradient(135deg, var(--primary), #FF9447);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-family: var(--zen); font-weight: 900; font-size: 16px;
      box-shadow: 0 3px 8px rgba(255,107,53,0.35); flex-shrink: 0;
    }
    .appbar-name { font-family: var(--zen); font-weight: 900; font-size: 14px; color: var(--ink); line-height: 1.1; }
    .appbar-sub { font-size: 9px; color: var(--ink-soft); letter-spacing: 0.06em; }

    /* Hero */
    .hero { position: relative; overflow: hidden; padding: 26px 20px 30px;
      background: radial-gradient(160% 80% at 100% 0%, #FFCBA4 0%, transparent 55%), radial-gradient(120% 70% at 0% 100%, #FFD9C4 0%, transparent 60%), linear-gradient(180deg, #FFF6EC 0%, #FFEDDB 100%); }
    .hero-blob { position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; border-radius: 50%; background: radial-gradient(circle, rgba(255,180,71,0.4), transparent 70%); filter: blur(8px); pointer-events: none; }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: #fff; border-radius: 999px; padding: 5px 12px 5px 8px; font-size: 11px; font-weight: 700; color: var(--primary-dark); box-shadow: 0 4px 10px rgba(255,107,53,0.18); position: relative; z-index: 1; }
    .hero-badge-dot { width: 18px; height: 18px; border-radius: 50%; background: var(--primary); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; }
    .hero h1 { margin: 14px 0 8px; font-family: var(--zen); font-weight: 900; font-size: 28px; line-height: 1.3; letter-spacing: -0.02em; color: var(--ink); position: relative; z-index: 1; }
    .hero h1 .mark { background: linear-gradient(180deg, transparent 60%, #FFD480 60%); padding: 0 4px; }
    .hero-lead { margin: 8px 0 4px; font-size: 13px; color: var(--ink-soft); line-height: 1.8; position: relative; z-index: 1; }
    .hero-note { margin: 8px 0 16px; font-size: 12px; color: var(--primary-dark); font-weight: 700; line-height: 1.7; position: relative; z-index: 1; }
    .hero-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px; position: relative; z-index: 1; }
    .hero-chip { display: inline-flex; align-items: center; gap: 4px; background: #fff; border: 1px solid #FFD3B5; border-radius: 999px; padding: 6px 11px; font-size: 11px; font-weight: 700; color: var(--ink); }
    .hero-chip::before { content: '✓'; color: var(--green); font-weight: 900; }
    .btn-primary {
      display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: none;
      background: linear-gradient(180deg, #FF8A4D, var(--primary)); color: #fff;
      font-family: var(--round); font-weight: 800; font-size: 16px; padding: 15px; border-radius: 16px;
      box-shadow: 0 8px 18px rgba(255,107,53,0.4), inset 0 1px 0 rgba(255,255,255,0.3); position: relative; z-index: 1;
    }
    .btn-primary:active { transform: scale(0.99); }

    /* Section head */
    .sec-head { padding: 30px 20px 6px; text-align: center; }
    .sec-kicker { display: inline-block; font-family: var(--round); font-size: 11px; font-weight: 800; letter-spacing: 0.16em; color: var(--primary); background: var(--primary-soft); padding: 4px 12px; border-radius: 999px; }
    .sec-head h2 { margin: 10px 0 4px; font-family: var(--zen); font-weight: 900; font-size: 21px; color: var(--ink); line-height: 1.35; }
    .sec-head p { margin: 0; font-size: 12px; color: var(--ink-soft); }

    /* Compare table (desktop) */
    .compare-wrap { padding: 12px 16px 4px; }
    .compare-table { display: none; background: #fff; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 6px 16px rgba(196,110,60,0.06); }
    .ct-head { display: grid; grid-template-columns: 110px repeat(3, 1fr); background: linear-gradient(180deg, var(--primary-soft), #FFF1E2); border-bottom: 1px solid var(--border); }
    .ct-head-label { padding: 12px 10px; font-size: 11px; color: var(--ink-soft); font-weight: 700; border-right: 1px solid var(--border); display: flex; align-items: flex-end; }
    .ct-head-firm { padding: 12px 8px; text-align: center; border-right: 1px solid var(--border); }
    .ct-head-firm:last-child { border-right: none; }
    .ct-emblem { width: 34px; height: 34px; border-radius: 10px; display: inline-flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 16px; margin-bottom: 6px; }
    .ct-firm-name { font-family: var(--zen); font-weight: 800; font-size: 12px; color: var(--ink); line-height: 1.3; }
    .ct-firm-type { font-size: 9px; color: var(--ink-soft); margin-top: 2px; }
    .ct-row { display: grid; grid-template-columns: 110px repeat(3, 1fr); border-bottom: 1px solid var(--border); }
    .ct-row:last-child { border-bottom: none; }
    .ct-row.stripe { background: #FBF5EE; }
    .ct-key { padding: 12px 10px; font-size: 11px; font-weight: 700; color: var(--ink); border-right: 1px solid var(--border); display: flex; align-items: center; }
    .ct-val { padding: 12px 8px; text-align: center; border-right: 1px solid var(--border); font-size: 11px; font-weight: 600; color: var(--ink); line-height: 1.4; display: flex; align-items: center; justify-content: center; }
    .ct-val:last-child { border-right: none; }
    .ct-ctarow .ct-val { padding: 12px 6px; }
    .ct-mini-cta { display: inline-block; background: var(--primary); color: #fff; font-family: var(--round); font-weight: 800; font-size: 11px; padding: 8px 10px; border-radius: 10px; line-height: 1.2; }

    /* Compare cards (mobile) */
    .compare-cards { display: flex; flex-direction: column; gap: 14px; }
    .cc-card { background: #fff; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 4px 12px rgba(196,110,60,0.07); }
    .cc-head { display: flex; align-items: center; gap: 10px; padding: 14px 16px; }
    .cc-emblem { width: 38px; height: 38px; border-radius: 11px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 18px; flex-shrink: 0; }
    .cc-name { font-family: var(--zen); font-weight: 800; font-size: 14px; color: var(--ink); line-height: 1.3; }
    .cc-type { font-size: 10px; color: var(--ink-soft); }
    .cc-rows { padding: 0 16px; }
    .cc-r { display: flex; justify-content: space-between; gap: 12px; padding: 9px 0; border-top: 1px dashed var(--border); font-size: 12px; }
    .cc-r-k { color: var(--ink-soft); font-weight: 600; flex-shrink: 0; }
    .cc-r-v { color: var(--ink); font-weight: 700; text-align: right; }
    .cc-cta { display: flex; align-items: center; justify-content: center; gap: 6px; margin: 14px 16px 16px; color: #fff; font-family: var(--round); font-weight: 800; font-size: 13px; padding: 12px; border-radius: 12px; }

    .center-cta { padding: 22px 20px 4px; }
    .center-cta .btn-primary { max-width: 420px; margin: 0 auto; }

    /* Firm detail cards */
    .firm-list { padding: 14px 16px 4px; display: flex; flex-direction: column; gap: 18px; }
    .firm-card { position: relative; background: #fff; border-radius: 20px; padding: 20px 18px 18px; border: 1px solid var(--border); box-shadow: 0 6px 16px rgba(196,110,60,0.08); }
    .firm-badge-top { position: absolute; top: -11px; left: 16px; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 11px; padding: 5px 12px; border-radius: 999px; }
    .firm-head { display: flex; gap: 12px; align-items: flex-start; }
    .firm-emblem { width: 54px; height: 54px; border-radius: 15px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 26px; }
    .firm-type { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; margin-bottom: 4px; }
    .firm-name { font-family: var(--zen); font-weight: 800; font-size: 15px; line-height: 1.3; color: var(--ink); }
    .firm-catch { margin-top: 12px; padding: 9px 12px; border-radius: 10px; font-size: 12px; font-weight: 700; line-height: 1.5; }
    .firm-points { margin-top: 12px; display: flex; flex-direction: column; gap: 6px; }
    .firm-point { display: flex; gap: 7px; align-items: flex-start; font-size: 12.5px; color: var(--ink); line-height: 1.55; }
    .firm-point::before { content: '✓'; color: var(--green); font-weight: 900; flex-shrink: 0; }
    .firm-specs { margin-top: 14px; border-top: 1px solid var(--border); }
    .firm-spec { display: flex; justify-content: space-between; gap: 12px; padding: 9px 0; border-bottom: 1px dashed var(--border); font-size: 12px; }
    .firm-spec-k { color: var(--ink-soft); font-weight: 600; flex-shrink: 0; }
    .firm-spec-v { color: var(--ink); font-weight: 700; text-align: right; line-height: 1.45; }
    .firm-caution { margin-top: 12px; font-size: 11px; color: var(--ink-soft); background: #FBF5EE; border-left: 3px solid #E7B98C; padding: 8px 11px; border-radius: 0 8px 8px 0; line-height: 1.6; }
    .firm-cta { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 14px; color: #fff; font-family: var(--round); font-weight: 800; font-size: 14px; padding: 14px 8px; border-radius: 14px; box-shadow: 0 6px 16px rgba(0,0,0,0.12); }
    .firm-cta-note { margin-top: 7px; text-align: center; font-size: 10px; color: var(--ink-soft); }

    /* Purpose grid */
    .purpose-wrap { padding: 12px 16px 4px; }
    .purpose-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .purpose-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 14px; display: flex; flex-direction: column; gap: 4px; transition: transform .15s, box-shadow .15s; }
    .purpose-card:hover { transform: translateY(-2px); box-shadow: 0 8px 18px rgba(196,110,60,0.12); }
    .purpose-icon { font-size: 22px; line-height: 1; }
    .purpose-title { font-family: var(--zen); font-weight: 800; font-size: 13px; color: var(--ink); line-height: 1.4; margin-top: 4px; }
    .purpose-desc { font-size: 11px; color: var(--ink-soft); line-height: 1.5; }

    /* FAQ */
    .faq-list { padding: 12px 16px 4px; display: flex; flex-direction: column; gap: 8px; }
    .faq-item { background: #fff; border-radius: 14px; border: 1px solid var(--border); overflow: hidden; }
    .faq-item.open { box-shadow: 0 8px 18px rgba(196,110,60,0.1); }
    .faq-q { width: 100%; border: none; background: none; padding: 14px; text-align: left; display: flex; align-items: flex-start; gap: 10px; }
    .faq-q-icon { width: 22px; height: 22px; border-radius: 50%; background: var(--primary); color: #fff; font-family: var(--zen); font-weight: 900; font-size: 13px; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .faq-q-text { flex: 1; font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.5; }
    .faq-chevron { padding-top: 3px; transition: transform .2s; color: var(--ink-soft); }
    .faq-item.open .faq-chevron { transform: rotate(180deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
    .faq-item.open .faq-a { max-height: 320px; }
    .faq-a-inner { padding: 0 14px 14px 46px; }
    .faq-a-text { font-size: 12px; line-height: 1.8; color: var(--ink-soft); }

    /* Final CTA */
    .final-cta { margin: 24px 16px 16px; padding: 24px 20px; border-radius: 22px; color: #fff; position: relative; overflow: hidden;
      background: radial-gradient(120% 100% at 100% 0%, #FFB07A 0%, transparent 60%), linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); }
    .final-cta-deco { position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.1); }
    .final-cta h3 { position: relative; font-family: var(--zen); font-weight: 900; font-size: 21px; line-height: 1.4; }
    .final-cta p { position: relative; margin: 10px 0 16px; font-size: 12.5px; line-height: 1.8; opacity: 0.95; }
    .final-cta .btn-light { position: relative; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: #fff; color: var(--primary-dark); font-family: var(--round); font-weight: 800; font-size: 15px; padding: 15px; border: none; border-radius: 14px; }

    /* Sticky bottom CTA (mobile) */
    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; z-index: 40; padding: 10px 14px calc(10px + env(safe-area-inset-bottom)); background: rgba(255,253,249,0.96); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 1px solid var(--border); }
    .sticky-cta button { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; max-width: 460px; margin: 0 auto; border: none; background: linear-gradient(180deg, #FF8A4D, var(--primary)); color: #fff; font-family: var(--round); font-weight: 800; font-size: 15px; padding: 14px; border-radius: 14px; box-shadow: 0 6px 16px rgba(255,107,53,0.4); }

    /* Disclaimer / footer */
    .legal { margin: 8px 16px 0; padding: 14px 16px; background: #FBF5EE; border: 1px solid var(--border); border-radius: 12px; }
    .legal p { font-size: 10.5px; color: var(--ink-soft); line-height: 1.8; margin-bottom: 4px; }
    .legal p:last-child { margin-bottom: 0; }
    .site-footer { padding: 22px 18px 30px; background: #2A1F1A; color: #A89A88; margin-top: 20px; }
    .footer-head { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .footer-logo { width: 26px; height: 26px; border-radius: 8px; background: var(--primary); display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--zen); font-weight: 900; font-size: 13px; }
    .footer-name { font-family: var(--zen); font-weight: 800; font-size: 14px; color: #fff; }
    .footer-text { font-size: 10px; line-height: 1.7; margin-bottom: 12px; }
    .footer-links { display: flex; gap: 16px; font-size: 10px; padding-top: 10px; border-top: 1px solid #3D2F26; }
    .footer-links a { color: #A89A88; }
    .footer-copy { margin-top: 12px; font-size: 9px; opacity: 0.6; }

    /* ── Desktop ── */
    @media (min-width: 920px) {
      .hero { padding: 44px 44px 40px; }
      .hero h1 { font-size: 38px; }
      .hero-lead { font-size: 15px; }
      .hero-note { font-size: 13px; }
      .hero .btn-primary { max-width: 460px; }
      .sec-head { padding: 40px 28px 8px; }
      .sec-head h2 { font-size: 26px; }
      .compare-wrap { padding: 16px 28px 4px; }
      .compare-table { display: block; }
      .compare-cards { display: none; }
      .firm-list { padding: 16px 28px 4px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; align-items: start; }
      .purpose-wrap { padding: 16px 28px 4px; }
      .purpose-grid { grid-template-columns: repeat(4, 1fr); }
      .faq-list { padding: 12px 28px 4px; }
      .final-cta { margin: 28px 28px 16px; }
      .legal { margin: 8px 28px 0; }
      /* hide sticky on desktop */
      .sticky-cta { display: none; }
      body { padding-bottom: 32px; }
    }
    @media (max-width: 919px) {
      .compare-table { display: none; }
      .compare-cards { display: flex; }
    }
  </style>
</head>
<body>
<div class="page-wrap">

  <div class="pr-bar">PR・広告を含みます</div>

  <header class="appbar">
    <div class="appbar-logo">整</div>
    <div>
      <div class="appbar-name">借金スッキリnavi</div>
      <div class="appbar-sub">DEBT RELIEF COMPARE 2026</div>
    </div>
  </header>

  <!-- 1. ファーストビュー -->
  <section class="hero">
    <div class="hero-blob"></div>
    <div class="hero-badge"><span class="hero-badge-dot">★</span>相談先を選ぶ前に比較</div>
    <h1>債務整理の<br/><span class="mark">相談先</span>を比較</h1>
    <p class="hero-lead">無料相談・費用・全国対応・分割払い・家族や職場への配慮を、まとめて確認できます。</p>
    <p class="hero-note">気になる事務所がある方も、相談前に他の候補と比べておくと安心です。</p>
    <div class="hero-chips">
      <span class="hero-chip">無料相談あり</span>
      <span class="hero-chip">全国対応</span>
      <span class="hero-chip">分割払い相談可</span>
      <span class="hero-chip">家族/職場への配慮</span>
      <span class="hero-chip">任意整理/個人再生/自己破産対応</span>
    </div>
    <button class="btn-primary" onclick="scrollToId('compare')">無料相談できる事務所を比較する →</button>
  </section>

  <!-- 2. 3社比較表 -->
  <div class="sec-head" id="compare">
    <span class="sec-kicker">COMPARE</span>
    <h2>まずは相談しやすい3社を比較</h2>
    <p>相談料・対応手続き・配慮の有無で見比べてみましょう</p>
  </div>
  <div class="compare-wrap">
    <!-- desktop table -->
    <div class="compare-table">
      <div class="ct-head">
        <div class="ct-head-label">項目</div>
        {firms.map((f) => (
          <div class="ct-head-firm">
            <div class="ct-emblem" style={`background:${f.accent}`}>{f.emblem}</div>
            <div class="ct-firm-name">{f.name.replace('弁護士法人','').replace('司法書士事務所','').replace('法律事務所','')}</div>
            <div class="ct-firm-type">{f.type}</div>
          </div>
        ))}
      </div>
      {compareRows.map((row, i) => (
        <div class={`ct-row${i % 2 === 1 ? ' stripe' : ''}`}>
          <div class="ct-key">{row.label}</div>
          {row.vals.map((v) => <div class="ct-val">{v}</div>)}
        </div>
      ))}
      <div class="ct-row ct-ctarow">
        <div class="ct-key">無料相談</div>
        {firms.map((f) => (
          <div class="ct-val">
            <a href={f.link} rel="nofollow" class="ct-mini-cta" style={`background:${f.accent}`} onclick={`return gtagSendEvent('${f.link}')`}>無料相談を確認</a>
          </div>
        ))}
      </div>
    </div>
    <!-- mobile cards -->
    <div class="compare-cards">
      {firms.map((f, fi) => (
        <div class="cc-card">
          <div class="cc-head">
            <div class="cc-emblem" style={`background:${f.accent}`}>{f.emblem}</div>
            <div>
              <div class="cc-name">{f.name}</div>
              <div class="cc-type">{f.type}</div>
            </div>
          </div>
          <div class="cc-rows">
            {compareRows.map((row) => (
              <div class="cc-r"><span class="cc-r-k">{row.label}</span><span class="cc-r-v">{row.vals[fi]}</span></div>
            ))}
          </div>
          <a href={f.link} rel="nofollow" class="cc-cta" style={`background:${f.accent}`} onclick={`return gtagSendEvent('${f.link}')`}>無料相談を確認 →</a>
        </div>
      ))}
    </div>
  </div>
  <div class="center-cta">
    <button class="btn-primary" onclick="scrollToId('firms')">3社を比較して相談先を選ぶ →</button>
  </div>

  <!-- 3. おすすめ候補の詳細 -->
  <div class="sec-head" id="firms">
    <span class="sec-kicker">DETAILS</span>
    <h2>迷ったら比較しておきたい相談先</h2>
    <p>それぞれの強みと確認ポイントをチェック</p>
  </div>
  <div class="firm-list">
    {firms.map((f) => (
      <div class="firm-card">
        <div class="firm-badge-top" style={`background:${f.accent}`}>{f.badge}</div>
        <div class="firm-head">
          <div class="firm-emblem" style={`background:${f.accent}`}>{f.emblem}</div>
          <div style="flex:1;min-width:0">
            <span class="firm-type" style={`color:${f.accent};background:${f.accentSoft}`}>{f.type}</span>
            <div class="firm-name">{f.name}</div>
          </div>
        </div>
        <div class="firm-catch" style={`background:${f.accentSoft};color:${f.accent}`}>{f.catch}</div>
        <div class="firm-points">
          {f.points.map((p) => <div class="firm-point">{p}</div>)}
        </div>
        <div class="firm-specs">
          <div class="firm-spec"><span class="firm-spec-k">相談料</span><span class="firm-spec-v">{f.fee}</span></div>
          <div class="firm-spec"><span class="firm-spec-k">対応エリア</span><span class="firm-spec-v">{f.area}</span></div>
          <div class="firm-spec"><span class="firm-spec-k">対応手続き</span><span class="firm-spec-v">{f.methods}</span></div>
          <div class="firm-spec"><span class="firm-spec-k">費用の確認</span><span class="firm-spec-v">{f.feeCheck}</span></div>
          <div class="firm-spec"><span class="firm-spec-k">向いている人</span><span class="firm-spec-v">{f.forWho}</span></div>
        </div>
        <div class="firm-caution">⚠ {f.caution}</div>
        <a href={f.link} rel="nofollow" class="firm-cta" style={`background:${f.accent}`} onclick={`return gtagSendEvent('${f.link}')`}>この相談先の無料相談を確認する →</a>
        <div class="firm-cta-note">相談料0円・全国対応・まずは話を聞くだけでもOK</div>
      </div>
    ))}
  </div>

  <!-- 4. 目的別に選ぶ -->
  <div class="sec-head">
    <span class="sec-kicker">BY PURPOSE</span>
    <h2>悩みに合わせて相談先を選ぶ</h2>
    <p>あなたの状況に近いものから比較を始めましょう</p>
  </div>
  <div class="purpose-wrap">
    <div class="purpose-grid">
      {purposes.map((p) => (
        <a class="purpose-card" href="#compare" onclick="return scrollToId('compare')">
          <span class="purpose-icon">{p.icon}</span>
          <span class="purpose-title">{p.title}</span>
          <span class="purpose-desc">{p.desc}</span>
        </a>
      ))}
    </div>
  </div>
  <div class="center-cta">
    <button class="btn-primary" onclick="scrollToId('compare')">自分に合う相談先を探す →</button>
  </div>

  <!-- 5. 相談前の不安FAQ -->
  <div class="sec-head">
    <span class="sec-kicker">FAQ</span>
    <h2>相談前によくある不安</h2>
    <p>気になるところをタップ</p>
  </div>
  <div class="faq-list">
    {faqs.map((f, i) => (
      <div class={`faq-item${i === 0 ? ' open' : ''}`} id={`faq${i}`}>
        <button class="faq-q" onclick={`toggleFaq('faq${i}')`}><span class="faq-q-icon">Q</span><span class="faq-q-text">{f.q}</span><span class="faq-chevron">▼</span></button>
        <div class="faq-a"><div class="faq-a-inner"><p class="faq-a-text">{f.a}</p></div></div>
      </div>
    ))}
  </div>
  <div class="center-cta">
    <button class="btn-primary" onclick="scrollToId('compare')">不安を相談できる事務所を比較する →</button>
  </div>

  <!-- 6. 最終CTA -->
  <section class="final-cta">
    <div class="final-cta-deco"></div>
    <h3>相談先は、<br/>比較してから決めましょう。</h3>
    <p>債務整理は、費用・対応範囲・相談方法が事務所によって異なります。まずは無料相談できる候補を比較し、納得できる相談先を選びましょう。</p>
    <button class="btn-light" onclick="scrollToId('compare')">無料相談できる事務所を比較する →</button>
  </section>

  <!-- 固定の注意書き -->
  <div class="legal">
    <p>※本ページはPR・広告を含みます。掲載は提携に基づくものです。</p>
    <p>※本ページは法律相談・法的助言ではありません。一般的な情報提供を目的としています。</p>
    <p>※相談料・費用・対応可否・対応エリア・分割払いの可否などは変更される場合があります。最新かつ正確な内容は、必ず各事務所に直接ご確認ください。</p>
  </div>

  <footer class="site-footer">
    <div class="footer-head">
      <div class="footer-logo">整</div>
      <div class="footer-name">借金スッキリnavi</div>
    </div>
    <p class="footer-text">本サイトは債務整理の相談先を比較するための情報サイトです。<br/>掲載情報は各事務所の公開情報をもとに作成しています。</p>
    <div class="footer-links">
      <a href="/money/operator/">運営者情報</a>
      <a href="/money/operator/">プライバシーポリシー</a>
    </div>
    <div class="footer-copy">© 2026 借金スッキリnavi</div>
  </footer>
</div>

<!-- スマホ下部固定CTA -->
<div class="sticky-cta">
  <button onclick="scrollToId('compare')">無料相談先を比較 →</button>
</div>

</body>
</html>
