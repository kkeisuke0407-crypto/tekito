---
const title = "借金の悩み、今日解決できます｜無料相談・キャッシング比較";
const description = "債務整理（任意整理・自己破産・個人再生・過払い金）の無料弁護士相談、または即日キャッシング。あなたに合った解決策をご案内します。";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #3B82F6;
      --blue-light: #EFF6FF;
      --blue-mid: #DBEAFE;
      --blue-dark: #1D4ED8;
      --blue-deep: #1E3A8A;
      --mint: #10B981;
      --mint-light: #ECFDF5;
      --mint-dark: #059669;
      --orange: #F97316;
      --orange-light: #FFF7ED;
      --red: #EF4444;
      --yellow: #F59E0B;
      --text: #0F172A;
      --text-mid: #334155;
      --text-muted: #64748B;
      --text-light: #94A3B8;
      --white: #FFFFFF;
      --bg: #F8FAFF;
      --bg-section: #EFF6FF;
      --border: #E2E8F0;
      --radius-sm: 10px;
      --radius: 16px;
      --radius-lg: 24px;
      --shadow-sm: 0 2px 8px rgba(15,23,42,0.06);
      --shadow: 0 4px 20px rgba(15,23,42,0.08);
      --shadow-lg: 0 8px 40px rgba(15,23,42,0.12);
      --shadow-blue: 0 8px 32px rgba(59,130,246,0.25);
      --shadow-mint: 0 8px 32px rgba(16,185,129,0.25);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Sans JP', sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      padding-bottom: 80px;
    }

    a { text-decoration: none; }

    /* ===== ANIMATION BASE ===== */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    .reveal-left {
      opacity: 0;
      transform: translateX(-20px);
      transition: opacity 0.45s ease, transform 0.45s ease;
    }
    .reveal-left.visible { opacity: 1; transform: translateX(0); }

    .reveal-scale {
      opacity: 0;
      transform: scale(0.93);
      transition: opacity 0.45s ease, transform 0.45s ease;
    }
    .reveal-scale.visible { opacity: 1; transform: scale(1); }

    /* ===== SECTION COMMON ===== */
    .wrap {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .sec { padding: 64px 0; }
    .sec-sm { padding: 48px 0; }

    .sec-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 8px;
    }

    .sec-title {
      font-size: clamp(22px, 5.5vw, 30px);
      font-weight: 900;
      line-height: 1.45;
      color: var(--text);
      margin-bottom: 8px;
    }

    .sec-lead {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.85;
      margin-bottom: 32px;
    }

    /* ===== HERO ===== */
    .hero {
      background: linear-gradient(160deg, #0F172A 0%, #1E3A8A 40%, #2563EB 75%, #3B82F6 100%);
      padding: 56px 20px 52px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 20% 20%, rgba(255,255,255,0.06) 0%, transparent 70%),
        radial-gradient(ellipse 50% 50% at 85% 80%, rgba(99,179,237,0.12) 0%, transparent 60%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.13);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.22);
      color: rgba(255,255,255,0.92);
      font-size: 12px;
      font-weight: 700;
      padding: 7px 18px;
      border-radius: 100px;
      letter-spacing: 0.06em;
      margin-bottom: 28px;
      position: relative;
    }

    .hero-badge::before {
      content: '';
      width: 7px;
      height: 7px;
      background: #4ADE80;
      border-radius: 50%;
      box-shadow: 0 0 6px #4ADE80;
      animation: pulse-dot 2s infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .hero-title {
      color: white;
      font-size: clamp(26px, 7vw, 40px);
      font-weight: 900;
      line-height: 1.35;
      margin-bottom: 14px;
      position: relative;
    }

    .hero-title .accent {
      background: linear-gradient(90deg, #FDE68A 0%, #FCA5A5 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      color: rgba(255,255,255,0.78);
      font-size: 14px;
      line-height: 1.9;
      margin-bottom: 36px;
      position: relative;
    }

    .hero-cta-group {
      display: flex;
      flex-direction: column;
      gap: 14px;
      max-width: 360px;
      margin: 0 auto 20px;
      position: relative;
    }

    .btn-hero-law {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
      border: 2px solid rgba(255,255,255,0.35);
      color: white;
      font-size: 17px;
      font-weight: 900;
      padding: 20px 24px;
      border-radius: 100px;
      box-shadow: 0 8px 30px rgba(29,78,216,0.5);
      transition: transform 0.18s, box-shadow 0.18s;
      letter-spacing: 0.02em;
    }

    .btn-hero-law:active { transform: scale(0.97); }

    .btn-hero-cash {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #059669 0%, #10B981 100%);
      border: 2px solid rgba(255,255,255,0.25);
      color: white;
      font-size: 17px;
      font-weight: 900;
      padding: 20px 24px;
      border-radius: 100px;
      box-shadow: 0 8px 30px rgba(5,150,105,0.45);
      transition: transform 0.18s, box-shadow 0.18s;
      letter-spacing: 0.02em;
    }

    .btn-hero-cash:active { transform: scale(0.97); }

    .btn-arrow { font-size: 18px; }

    .hero-note {
      color: rgba(255,255,255,0.5);
      font-size: 11px;
      position: relative;
    }

    .hero-chips {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 28px;
      position: relative;
    }

    .hero-chip {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      color: rgba(255,255,255,0.85);
      font-size: 12px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 100px;
    }

    .scroll-hint {
      position: absolute;
      bottom: 18px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      color: rgba(255,255,255,0.38);
      font-size: 10px;
      pointer-events: none;
    }

    .scroll-chevron {
      width: 16px;
      height: 16px;
      border-right: 1.5px solid rgba(255,255,255,0.35);
      border-bottom: 1.5px solid rgba(255,255,255,0.35);
      transform: rotate(45deg);
      animation: chev 1.6s infinite;
    }

    @keyframes chev {
      0%, 100% { transform: rotate(45deg) translate(0,0); opacity: 0.5; }
      50% { transform: rotate(45deg) translate(3px,3px); opacity: 1; }
    }

    /* ===== DECIDE SECTION ===== */
    .decide-bg { background: white; }

    .decide-cards {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .decide-card {
      border-radius: var(--radius);
      border: 2px solid var(--border);
      overflow: hidden;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .decide-card:hover { border-color: var(--blue); box-shadow: var(--shadow-blue); }

    .decide-card--cash:hover { border-color: var(--mint); box-shadow: var(--shadow-mint); }

    .decide-card-head {
      padding: 20px 20px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .decide-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }

    .decide-icon--law { background: var(--blue-light); }
    .decide-icon--cash { background: var(--mint-light); }

    .decide-card-name {
      font-size: 17px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 3px;
    }

    .decide-card-sub {
      font-size: 12px;
      color: var(--text-muted);
    }

    .decide-checks {
      padding: 0 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .decide-check {
      display: flex;
      align-items: flex-start;
      gap: 9px;
      font-size: 13.5px;
      color: var(--text-mid);
      line-height: 1.6;
    }

    .decide-check::before {
      content: '✓';
      font-weight: 900;
      color: var(--blue);
      flex-shrink: 0;
      margin-top: 1px;
    }

    .decide-card--cash .decide-check::before { color: var(--mint); }

    .decide-cta {
      display: block;
      margin: 4px 20px 20px;
      padding: 14px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      font-weight: 900;
      text-align: center;
      color: white;
      letter-spacing: 0.02em;
    }

    .decide-cta--law {
      background: linear-gradient(135deg, var(--blue-dark), var(--blue));
      box-shadow: 0 4px 16px rgba(59,130,246,0.3);
    }

    .decide-cta--cash {
      background: linear-gradient(135deg, var(--mint-dark), var(--mint));
      box-shadow: 0 4px 16px rgba(16,185,129,0.3);
    }

    .decide-divider {
      text-align: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-muted);
      padding: 4px 0;
      position: relative;
    }

    .decide-divider::before,
    .decide-divider::after {
      content: '';
      position: absolute;
      top: 50%;
      width: calc(50% - 24px);
      height: 1px;
      background: var(--border);
    }

    .decide-divider::before { left: 0; }
    .decide-divider::after { right: 0; }

    /* ===== LAW SECTION ===== */
    .law-bg { background: var(--bg-section); }

    .service-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
    }

    .service-logo-badge {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      flex-shrink: 0;
    }

    .service-logo-badge--law {
      background: linear-gradient(135deg, #1E3A8A, #2563EB);
      box-shadow: 0 4px 16px rgba(37,99,235,0.35);
    }

    .service-name {
      font-size: 18px;
      font-weight: 900;
      color: var(--text);
      line-height: 1.3;
      margin-bottom: 3px;
    }

    .service-tagline {
      font-size: 12px;
      color: var(--text-muted);
    }

    /* 実績バー */
    .stat-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 28px;
    }

    .stat-item {
      background: white;
      border-radius: var(--radius-sm);
      padding: 14px 8px;
      text-align: center;
      box-shadow: var(--shadow-sm);
    }

    .stat-num {
      font-size: 20px;
      font-weight: 900;
      color: var(--blue-dark);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 10px;
      color: var(--text-muted);
      font-weight: 600;
    }

    /* 4種の債務整理 */
    .debt-types {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 28px;
    }

    .debt-type-card {
      background: white;
      border-radius: var(--radius-sm);
      padding: 18px;
      box-shadow: var(--shadow-sm);
      border-left: 4px solid var(--blue);
    }

    .debt-type-title {
      font-size: 15px;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .debt-type-badge {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 100px;
      background: var(--blue-mid);
      color: var(--blue-dark);
    }

    .debt-type-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.7;
    }

    /* 特徴タグリスト */
    .feature-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px;
    }

    .feature-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--text-mid);
      line-height: 1.6;
    }

    .feature-dot {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--blue-mid);
      color: var(--blue-dark);
      font-size: 12px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* 料金ボックス */
    .fee-box {
      background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
      border-radius: var(--radius-sm);
      padding: 18px;
      margin-bottom: 24px;
      border: 1px solid #BFDBFE;
    }

    .fee-box-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--blue-dark);
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }

    .fee-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13.5px;
      padding: 6px 0;
      border-bottom: 1px solid rgba(59,130,246,0.12);
    }

    .fee-row:last-child { border-bottom: none; }
    .fee-key { color: var(--text-mid); font-weight: 500; }
    .fee-val { font-weight: 900; color: var(--blue-dark); }

    /* こんな人向け */
    .for-who {
      background: white;
      border-radius: var(--radius-sm);
      padding: 18px;
      box-shadow: var(--shadow-sm);
      margin-bottom: 24px;
    }

    .for-who-title {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-muted);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .for-who-list {
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .for-who-item {
      font-size: 13.5px;
      color: var(--text-mid);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.6;
    }

    .for-who-item::before {
      content: '→';
      color: var(--blue);
      font-weight: 900;
      flex-shrink: 0;
    }

    .btn-section-law {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 100%);
      color: white;
      font-size: 16px;
      font-weight: 900;
      padding: 18px 24px;
      border-radius: 100px;
      box-shadow: var(--shadow-blue);
      transition: transform 0.18s;
      letter-spacing: 0.02em;
    }

    .btn-section-law:active { transform: scale(0.97); }

    /* ===== CASH SECTION ===== */
    .cash-bg { background: white; }

    .service-logo-badge--cash {
      background: linear-gradient(135deg, #059669, #10B981);
      box-shadow: 0 4px 16px rgba(16,185,129,0.35);
    }

    .debt-type-card--cash { border-left-color: var(--mint); }

    .feature-dot--cash {
      background: #D1FAE5;
      color: var(--mint-dark);
    }

    .fee-box--cash {
      background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
      border-color: #6EE7B7;
    }

    .fee-box--cash .fee-box-title { color: var(--mint-dark); }
    .fee-box--cash .fee-val { color: var(--mint-dark); }

    .highlight-box {
      background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
      border: 2px solid #6EE7B7;
      border-radius: var(--radius-sm);
      padding: 18px;
      margin-bottom: 24px;
      text-align: center;
    }

    .highlight-box-label {
      font-size: 12px;
      font-weight: 700;
      color: var(--mint-dark);
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }

    .highlight-box-main {
      font-size: clamp(24px, 6vw, 32px);
      font-weight: 900;
      color: var(--mint-dark);
      line-height: 1.2;
    }

    .highlight-box-sub {
      font-size: 12px;
      color: var(--mint-dark);
      margin-top: 6px;
      opacity: 0.8;
    }

    .cash-specs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 24px;
    }

    .cash-spec-item {
      background: var(--bg-section);
      border-radius: var(--radius-sm);
      padding: 14px;
      text-align: center;
    }

    .cash-spec-val {
      font-size: 18px;
      font-weight: 900;
      color: var(--mint-dark);
      line-height: 1.2;
      margin-bottom: 4px;
    }

    .cash-spec-key {
      font-size: 11px;
      color: var(--text-muted);
      font-weight: 600;
    }

    .for-who--cash .for-who-item::before { color: var(--mint); }

    .btn-section-cash {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, var(--mint-dark) 0%, var(--mint) 100%);
      color: white;
      font-size: 16px;
      font-weight: 900;
      padding: 18px 24px;
      border-radius: 100px;
      box-shadow: var(--shadow-mint);
      transition: transform 0.18s;
      letter-spacing: 0.02em;
    }

    .btn-section-cash:active { transform: scale(0.97); }

    /* ===== COMPARISON TABLE ===== */
    .compare-bg { background: var(--bg-section); }

    .compare-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      background: white;
      margin-bottom: 16px;
    }

    .compare-table thead tr {
      background: linear-gradient(135deg, #1E3A8A, #2563EB);
    }

    .compare-table th {
      padding: 14px 12px;
      font-size: 13px;
      font-weight: 900;
      color: white;
      text-align: center;
    }

    .compare-table th:first-child {
      text-align: left;
      background: rgba(0,0,0,0.15);
      width: 36%;
    }

    .compare-table td {
      padding: 13px 12px;
      font-size: 13px;
      text-align: center;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    .compare-table td:first-child {
      text-align: left;
      font-weight: 700;
      color: var(--text-mid);
      background: var(--bg);
    }

    .compare-table tr:last-child td { border-bottom: none; }

    .compare-table tr:nth-child(even) td:not(:first-child) {
      background: #FAFCFF;
    }

    .compare-val-good { color: var(--mint-dark); font-weight: 700; }
    .compare-val-note { color: var(--text-muted); font-size: 12px; }
    .compare-val-warn { color: var(--orange); font-weight: 700; }

    .compare-th-law { color: #BAE6FD; font-size: 12px; display: block; }
    .compare-th-cash { color: #A7F3D0; font-size: 12px; display: block; }

    /* ===== FAQ ===== */
    .faq-bg { background: white; }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .faq-item {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      overflow: hidden;
      background: white;
    }

    .faq-q {
      width: 100%;
      background: none;
      border: none;
      padding: 18px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
      transition: background 0.2s;
    }

    .faq-q:hover { background: var(--bg); }

    .faq-q-icon {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--blue-mid);
      color: var(--blue-dark);
      font-size: 13px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .faq-q-text {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.5;
